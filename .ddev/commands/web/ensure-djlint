#!/bin/bash

set -euo pipefail

if ! command -v python3 >/dev/null 2>&1; then
    echo "python3 not available; cannot install djlint" >&2
    exit 1
fi

if command -v djlint >/dev/null 2>&1; then
    echo "djlint ready: $(djlint --version)"
    exit 0
fi

if ! command -v pip3 >/dev/null 2>&1; then
    echo "pip3 not available; ensure webimage_extra_packages includes python3-pip" >&2
    exit 1
fi

python3 -m pip install --break-system-packages djlint >/dev/null
echo "djlint ready: $(djlint --version)"