# Container Image
APP_IMAGE_TAG=latest
TZ=Europe/Vienna

# Database Configuration
DB_DATABASE=choir_db
DB_USERNAME=choir_user
DB_PASSWORD=change_this_database_password
DB_PORT=3306
MYSQL_ROOT_PASSWORD=change_this_root_password

# SMTP / Mail Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_AUTH=1
SMTP_USERNAME=mailer@example.com
SMTP_PASSWORD=change_this_smtp_password
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Chor-Manager

# Application Behaviour
REMEMBER_ME_DAYS=30

# Enable the embedded SnappyMail webmail (requires the snappymail service below).
# With false the snappymail service is not needed at all; users may instead store
# an external webmail URL in their profile (the mail badge links there).
FEATURE_WEBMAIL=false

# Webmail / Mailbox feature (SnappyMail)
# Generate BOTH secrets once with: openssl rand -base64 32
# MAIL_CREDENTIAL_KEY encrypts stored IMAP passwords at rest (required as soon
# as the mailbox settings are shown in the profile).
MAIL_CREDENTIAL_KEY=change_this_run_openssl_rand_base64_32
# Shared secret between the app and the SnappyMail SSO plugin. Must be identical
# for the "app" and "snappymail" services (it comes from this single variable).
SNAPPYMAIL_SSO_SECRET=change_this_run_openssl_rand_base64_32
# Public HTTPS URL of the app, used to build the webmail SSO redirect.
APP_URL=https://choir.example.com
# SSRF guard: keep 0 in production. Set 1 only if the IMAP server lives on a
# private/loopback network that the app must be allowed to reach.
MAIL_ALLOW_PRIVATE_HOSTS=0
# SnappyMail container limits (optional)
SNAPPYMAIL_UPLOAD_MAX_SIZE=25M
SNAPPYMAIL_MEMORY_LIMIT=128M
