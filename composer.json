{
    "name": "antigravity/choir-attendance",
    "description": "Choir Attendance Web Application",
    "type": "project",
    "require": {
        "php": "^8.5",
        "illuminate/database": "^10.0",
        "php-di/php-di": "^7.0",
        "phpmailer/phpmailer": "^7.0",
        "robmorgan/phinx": "^0.16.10",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.0",
        "slim/twig-view": "^3.3",
        "twbs/bootstrap": "^5.3",
        "twbs/bootstrap-icons": "^1.13",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true
    },
    "scripts": {
        "phpcs": "phpcs --standard=phpcs.xml src/",
        "phpcbf": "phpcbf --standard=phpcs.xml src/",
        "migrate": "phinx migrate -e development",
        "seed:dev": "php bin/dev_seed.php",
        "post-install-cmd": [
            "@copy-assets"
        ],
        "post-update-cmd": [
            "@copy-assets"
        ],
        "copy-assets": "@php bin/copy-assets.php"
    }
}