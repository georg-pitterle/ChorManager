{
    "name": "antigravity/choir-attendance",
    "description": "Choir Attendance Web Application",
    "type": "project",
    "require": {
        "php": "^8.5",
        "illuminate/database": "^10.0",
        "php-di/php-di": "^7.0",
        "phpmailer/phpmailer": "^7.0",
        "robmorgan/phinx": "^0.16.10",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.0",
        "slim/twig-view": "^3.3",
        "twbs/bootstrap": "^5.3",
        "twbs/bootstrap-icons": "^1.13",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true
    },
    "scripts": {
        "phpcs": "phpcs --standard=phpcs.xml src/",
        "phpcbf": "phpcbf --standard=phpcs.xml src/",
        "migrate": "phinx migrate -e development",
        "post-install-cmd": [
            "@copy-assets"
        ],
        "post-update-cmd": [
            "@copy-assets"
        ],
        "copy-assets": [
            "mkdir -p public/vendor/bootstrap/dist/css public/vendor/bootstrap/dist/js public/vendor/bootstrap-icons/font",
            "cp -f vendor/twbs/bootstrap/dist/css/bootstrap.min.css public/vendor/bootstrap/dist/css/",
            "cp -f vendor/twbs/bootstrap/dist/js/bootstrap.bundle.min.js public/vendor/bootstrap/dist/js/",
            "cp -rf vendor/twbs/bootstrap-icons/font/* public/vendor/bootstrap-icons/font/"
        ]
    }
}