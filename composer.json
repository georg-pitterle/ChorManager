{
    "name": "antigravity/choir-attendance",
    "description": "Choir Attendance Web Application",
    "type": "project",
    "require": {
        "php": "^8.4",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "slim/twig-view": "^3.3",
        "vlucas/phpdotenv": "^5.5",
        "illuminate/database": "^10.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true
    }
}