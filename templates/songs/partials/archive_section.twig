{# templates/songs/partials/archive_section.twig #}
{% if settings.modules.sheet_archive and session.can_manage_sheet_archive %}
<div class="archive-section mt-4" id="sheetArchiveSection">
    <div class="accordion" id="sheetArchiveAccordion">
        <div class="accordion-item border rounded-3">
            <h3 class="accordion-header" id="sheetArchiveHeading">
                <button class="accordion-button collapsed"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#sheetArchiveCollapse"
                        aria-expanded="false"
                        aria-controls="sheetArchiveCollapse">
                    <span class="d-flex flex-column flex-md-row align-items-md-center gap-md-3 w-100">
                        <span class="fw-semibold">Notenarchiv</span>
                        <span class="text-muted small">
                            Standort: <span id="sheetArchiveHeaderLocation">{{ archive.location ?? 'kein Standort' }}</span>
                        </span>
                        <span class="text-muted small">
                            Einzelstimmen: <span id="sheetArchiveHeaderSummary">keine Einzelstimmen</span>
                        </span>
                    </span>
                </button>
            </h3>
            <div id="sheetArchiveCollapse"
                 class="accordion-collapse collapse"
                 aria-labelledby="sheetArchiveHeading"
                 data-bs-parent="#sheetArchiveAccordion">
                <div class="accordion-body">
                    <div class="mb-3">
                        <label for="archive_number" class="form-label">Archivnummer</label>
                        <input type="text"
                               id="archive_number"
                               name="archive_number"
                               class="form-control"
                               value="{{ archive.archive_number ?? '' }}"
                               maxlength="100">
                    </div>

                    <div class="mb-3">
                        <label for="location" class="form-label">Standort</label>
                        <input type="text"
                               id="location"
                               name="location"
                               class="form-control"
                               value="{{ archive.location ?? '' }}"
                               maxlength="255">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Gesamtzahl</label>
                        <div class="form-control-plaintext fw-bold" id="totalCount">0</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Einzelstimmen</label>
                        <datalist id="sheetArchiveVoiceSuggestions"></datalist>
                        <div id="voiceItemsContainer">
                            {% if archive and archive.lineItems %}
                                {% for item in archive.lineItems %}
                                    <div class="voice-item-row mb-2">
                                        <div class="input-group">
                                            <input type="hidden" class="voice-id" value="{{ item.id }}">
                                            <input type="text"
                                                   class="form-control voice-category creatable-input"
                                                   list="sheetArchiveVoiceSuggestions"
                                                   placeholder="Stimme eingeben"
                                                   value="{{ item.voice_category }}">
                                            <input type="number"
                                                   class="form-control voice-count"
                                                   min="0"
                                                   value="{{ item.count }}"
                                                   style="max-width: 100px">
                                            <button type="button" class="btn btn-danger btn-sm delete-voice-item" aria-label="Einzelstimme löschen">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                {% endfor %}
                            {% endif %}
                        </div>

                        <button type="button" class="btn btn-secondary btn-sm" id="addVoiceItemButton">
                            <i class="bi bi-plus"></i> Stimme hinzufügen
                        </button>

                        <div id="sheetArchiveSaveStatus" class="small text-muted mt-2" aria-live="polite"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script defer src="{{ asset_path('/js/archive-manager.js') }}"></script>
{% endif %}
