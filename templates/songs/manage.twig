{% extends "layout.twig" %}

{% block title %}
    Repertoire - {{ app_settings.app_name|default('Chor-Manager') }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Bereiche</p>
            <h1 class="h2 mb-1">Repertoire</h1>
            <p class="text-muted mb-0">Alle Lieder zentral verwalten und Projekten zuweisen.</p>
        </div>
        <div class="page-actions">
            <button type="button"
                    class="btn btn-outline-secondary"
                    data-bs-toggle="modal"
                    data-bs-target="#manageCategoriesModal">
                <i class="bi bi-tags"></i> Kategorien
            </button>
            <a href="/song-library/create" class="btn btn-primary">
                <i class="bi bi-music-note-list"></i> Neues Lied
            </a>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    {% if success %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ success }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}
    {% if error %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ error }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}

    {% set category_options_attr %}
        {% for cat in categories %}{{ cat.id }}::{{ cat.name }}||{% endfor %}
    {% endset %}

    <div class="dashboard-shell">
        <section class="dashboard-section dashboard-section--context"
                 aria-labelledby="repertoire-list-title">
            <div class="dashboard-section-head">
                <h2 class="dashboard-section-title" id="repertoire-list-title">Repertoireübersicht</h2>
                <p class="dashboard-section-lead mb-0">
                    {{ songs|length }} Lieder im aktuellen Ergebnis. Suche und Kategorien über die Tabellenleiste.
                </p>
            </div>

            <div class="surface-card card border-0 table-shell"
                 data-table-engine="true"
                 data-table-id="songs.manage"
                 data-table-plugins="songCategory"
                 data-category-options="{{ category_options_attr|replace({'\n': '', '\r': '', '\t': ' '})|trim }}"
                 data-default-view="auto"
                 data-default-page-size="100"
                 data-page-size-options="25,50,100,200"
                 data-default-sort-key="title">
                {{ include('partials/table_toolbar.twig') }}
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped mb-0 table-responsive-cards"
                               id="songsTable">
                            <thead class="table-dark">
                                <tr>
                                    <th data-sort-key="title" data-sort-type="text">Titel</th>
                                    <th data-sort-key="meta" data-sort-type="text">Details</th>
                                    <th data-sort-key="categories" data-sort-type="text">Kategorien</th>
                                    <th data-sort-key="attachments" data-sort-type="number">Dateien</th>
                                    <th data-sort-key="projects" data-sort-type="number">Projekte</th>
                                    <th class="text-end">Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for song in songs %}
                                    {% set meta_parts = [] %}
                                    {% if song.composer %}
                                        {% set meta_parts = meta_parts|merge([song.composer]) %}
                                    {% endif %}
                                    {% if song.arranger %}
                                        {% set meta_parts = meta_parts|merge(['Arr. ' ~ song.arranger]) %}
                                    {% endif %}
                                    {% if song.publisher %}
                                        {% set meta_parts = meta_parts|merge([song.publisher]) %}
                                    {% endif %}
                                    {% set categories_sort = "" %}
                                    {% set category_filter_ids = "|" %}
                                    {% for cat in song.categories %}
                                        {% set categories_sort = categories_sort ~ ' ' ~ cat.name|lower %}
                                        {% set category_filter_ids = category_filter_ids ~ cat.id ~ '|' %}
                                    {% endfor %}
                                    <tr data-sort-title="{{ song.title|lower }}"
                                        data-sort-meta="{{ meta_parts|join(' | ')|lower }}"
                                        data-sort-categories="{{ categories_sort|trim }}"
                                        data-category="{{ category_filter_ids }}"
                                        data-sort-attachments="{{ song.attachments|length }}"
                                        data-sort-projects="{{ song.projectAssignments|length }}">
                                        <td data-label="Titel">
                                            <span class="fw-semibold">{{ song.title }}</span>
                                        </td>
                                        <td data-label="Details">
                                            {% if meta_parts|length > 0 %}
                                                {{ meta_parts|join(' | ') }}
                                            {% else %}
                                                -
                                            {% endif %}
                                        </td>
                                        <td data-label="Kategorien">
                                            {% if song.categories|length > 0 %}
                                                <div class="d-flex flex-wrap gap-1">
                                                    {% for cat in song.categories %}
                                                        <span class="badge bg-primary-subtle text-primary-emphasis">{{ cat.name }}</span>
                                                    {% endfor %}
                                                </div>
                                            {% else %}
                                                <span class="text-muted">-</span>
                                            {% endif %}
                                        </td>
                                        <td data-label="Dateien">{{ song.attachments|length }}</td>
                                        <td data-label="Projekte">{{ song.projectAssignments|length }}</td>
                                        <td data-label="Aktionen" class="text-end">
                                            <div class="d-flex gap-2 flex-wrap justify-content-end">
                                                <a href="/song-library/{{ song.id }}"
                                                   class="btn btn-outline-primary btn-sm">
                                                    <i class="bi bi-pencil-square me-1"></i>Details
                                                </a>
                                                <form action="/song-library/songs/{{ song.id }}/delete"
                                                      method="post"
                                                      class="d-inline"
                                                      data-confirm="Lied '{{ song.title }}' wirklich loeschen? Alle Anhaenge und Projektzuweisungen werden entfernt.">
                                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                                        <i class="bi bi-trash me-1"></i>Löschen
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">Das Repertoire ist noch leer. Lege das erste Lied an.</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </section>
    </div>

    {# ===== Manage categories modal ===== #}
    <div class="modal fade"
         id="manageCategoriesModal"
         tabindex="-1"
         aria-labelledby="manageCategoriesModalLabel"
         aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="manageCategoriesModalLabel">Kategorien verwalten</h5>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form action="/song-library/categories" method="post" class="row g-2 mb-4">
                        <div class="col-md-8">
                            <input type="text"
                                   name="name"
                                   class="form-control"
                                   placeholder="Neue Kategorie..."
                                   required>
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-plus"></i> Anlegen
                            </button>
                        </div>
                    </form>

                    {% if categories|length > 0 %}
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th class="text-end">Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for cat in categories %}
                                    <tr>
                                        <td>
                                            <form action="/song-library/categories/{{ cat.id }}/update"
                                                  method="post"
                                                  class="d-flex gap-2 align-items-center">
                                                <input type="text"
                                                       name="name"
                                                       class="form-control form-control-sm"
                                                       value="{{ cat.name }}"
                                                       required>
                                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-check"></i>
                                                </button>
                                            </form>
                                        </td>
                                        <td class="text-end">
                                            <form action="/song-library/categories/{{ cat.id }}/delete"
                                                  method="post"
                                                  class="d-inline"
                                                  data-confirm="Kategorie '{{ cat.name }}' wirklich loeschen?">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    {% else %}
                        <p class="text-muted mb-0">Noch keine Kategorien vorhanden.</p>
                    {% endif %}
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Schliessen</button>
                </div>
            </div>
        </div>
    </div>
{% endblock content %}

{% block scripts %}
    {{ parent() }}
    <script src="/js/table-plugins/song-category-plugin.js"></script>
{% endblock scripts %}
