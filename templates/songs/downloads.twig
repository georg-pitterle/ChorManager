{% extends "layout.twig" %}

{% block title %}
    Downloads - {{ app_settings.app_name|default('Chor-Manager') }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Bereiche</p>
            <h1 class="h2 mb-1">Downloads</h1>
            <p class="text-muted mb-0">Hier findest du die Lieder und Dateien zu den Projekten, an denen du teilnimmst.</p>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    <div class="dashboard-shell downloads-shell">
        <section class="dashboard-section dashboard-section--communication downloads-section"
                 aria-labelledby="downloads-project-title">
            <div class="dashboard-section-head">
                <h2 class="dashboard-section-title" id="downloads-project-title">Projekt-Downloads</h2>
                <p class="dashboard-section-lead mb-0">
                    Öffne ein Projekt, um alle zugeordneten Lieddateien abzuspielen oder herunterzuladen.
                </p>
            </div>

            <div class="surface-card p-3 p-md-4 downloads-surface">
                <div class="accordion" id="downloadsProjectsAccordion">
                    {% for project in projects %}
                        <div class="accordion-item mb-3 border-0 shadow-sm">
                            <h2 class="accordion-header" id="download-heading-{{ project.id }}">
                                <button class="accordion-button collapsed"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#download-collapse-{{ project.id }}"
                                        aria-expanded="false"
                                        aria-controls="download-collapse-{{ project.id }}">
                                    <span class="fw-semibold">{{ project.name }}</span>
                                    <span class="badge bg-secondary ms-3">{{ project.assignedSongs|length }} Lieder</span>
                                </button>
                            </h2>
                            <div id="download-collapse-{{ project.id }}"
                                 class="accordion-collapse collapse"
                                 aria-labelledby="download-heading-{{ project.id }}"
                                 data-bs-parent="#downloadsProjectsAccordion">
                                <div class="accordion-body downloads-accordion-body">
                                    {% if project.assignedSongs|length == 0 %}
                                        <p class="text-muted mb-0">Keine Lieder in diesem Projekt vorhanden.</p>
                                    {% endif %}

                                    {% for song in project.assignedSongs %}
                                        <article class="surface-card dashboard-panel dashboard-panel--communication downloads-song-panel mb-3">
                                            <div class="dashboard-panel__body mb-3">
                                                <p class="dashboard-panel__eyebrow">Lied</p>
                                                <h3 class="dashboard-panel__title">
                                                    <i class="bi bi-music-note-beamed"></i>{{ song.title }}
                                                </h3>
                                                <p class="dashboard-panel__text mb-0">
                                                    Komponist: {{ song.composer|default('-') }} | Arrangeur: {{ song.arranger|default('-') }} | Verlag: {{ song.publisher|default('-') }}
                                                </p>
                                            </div>

                                            <div data-table-engine="true"
                                                 data-table-id="downloads.project.{{ project.id }}.song.{{ song.id }}"
                                                 data-default-view="auto"
                                                 data-auto-cards-max-width="767"
                                                 data-default-page-size="100"
                                                 data-page-size-options="25,50,100,200"
                                                 data-default-sort-key="file_name">
                                                <div class="d-flex justify-content-end align-items-center gap-2 mb-2">
                                                    <div class="btn-group"
                                                         role="group"
                                                         aria-label="Ansicht umschalten"
                                                         data-table-view-toggle>
                                                        <button type="button"
                                                                class="btn btn-sm btn-outline-secondary"
                                                                data-table-mode="auto">Auto</button>
                                                        <button type="button"
                                                                class="btn btn-sm btn-outline-secondary"
                                                                data-table-view="cards">Karten</button>
                                                        <button type="button"
                                                                class="btn btn-sm btn-outline-secondary"
                                                                data-table-view="table">Tabelle</button>
                                                    </div>
                                                </div>
                                                <div class="table-responsive">
                                                    <table class="table table-sm align-middle mb-0 table-responsive-cards downloads-files-table"
                                                           id="downloadsSongTable{{ song.id }}">
                                                        <thead>
                                                            <tr>
                                                                <th data-sort-key="file_name" data-sort-type="text">Datei</th>
                                                                <th data-sort-key="mime_type" data-sort-type="text">Typ</th>
                                                                <th>Groesse</th>
                                                                <th>Wiedergabe</th>
                                                                <th class="text-end">Aktionen</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            {% for attachment in song.attachments %}
                                                                {% set mime = attachment.mime_type|lower %}
                                                                {% set is_mp3 = mime == 'audio/mpeg' %}
                                                                {% set is_midi = mime == 'audio/midi' or mime == 'audio/x-midi' or mime == 'application/x-midi' %}
                                                                <tr data-sort-file_name="{{ attachment.original_name|lower }}"
                                                                    data-sort-mime_type="{{ attachment.mime_type|lower }}">
                                                                    <td data-label="Datei">{{ attachment.original_name }}</td>
                                                                    <td data-label="Typ">
                                                                        <small>{{ attachment.mime_type }}</small>
                                                                    </td>
                                                                    <td data-label="Groesse">{{ ((attachment.file_size / 1024)|round(1)) }} KB</td>
                                                                    <td data-label="Wiedergabe">
                                                                        {% if is_mp3 %}
                                                                            <audio controls preload="none" class="w-100">
                                                                                <source src="/downloads/attachments/{{ attachment.id }}/stream"
                                                                                        type="audio/mpeg">
                                                                                Dein Browser unterstuetzt kein Audio-Playback.
                                                                            </audio>
                                                                        {% elseif is_midi %}
                                                                            <div class="midi-player-block" data-midi-id="{{ attachment.id }}">
                                                                                <midi-player src="/downloads/attachments/{{ attachment.id }}/stream" sound-font visualizer="#none" class="w-100"></midi-player>
                                                                                <small class="text-muted d-none midi-fallback">MIDI-Playback im Browser nicht verfuegbar. Bitte Datei herunterladen.</small>
                                                                            </div>
                                                                        {% else %}
                                                                            <span class="text-muted">Nicht direkt abspielbar</span>
                                                                        {% endif %}
                                                                    </td>
                                                                    <td data-label="Aktionen" class="text-end">
                                                                        <a class="btn btn-sm btn-outline-primary"
                                                                           href="/downloads/attachments/{{ attachment.id }}/download">
                                                                            <i class="bi bi-download"></i>
                                                                            <span class="d-none d-sm-inline">Download</span>
                                                                        </a>
                                                                    </td>
                                                                </tr>
                                                            {% else %}
                                                                <tr>
                                                                    <td colspan="5" class="text-muted">Keine Anhaenge zu diesem Lied vorhanden.</td>
                                                                </tr>
                                                            {% endfor %}
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>

                                            <div class="downloads-song-links mt-3">
                                                <h4 class="h6 mb-2">Links</h4>
                                                {% if song.linkResources|length > 0 %}
                                                    <div class="list-group list-group-flush">
                                                        {% for resource in song.linkResources %}
                                                            <div class="list-group-item px-0">
                                                                <a href="{{ resource.url }}"
                                                                   target="_blank"
                                                                   rel="noopener noreferrer"
                                                                   class="fw-semibold text-decoration-none">{{ resource.title }}</a>
                                                                {% if resource.description %}
                                                                    <p class="text-muted small mb-0 mt-1">{{ resource.description }}</p>
                                                                {% endif %}
                                                            </div>
                                                        {% endfor %}
                                                    </div>
                                                {% else %}
                                                    <p class="text-muted small mb-0">Keine Links zu diesem Lied vorhanden.</p>
                                                {% endif %}
                                            </div>
                                        </article>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <article class="surface-card dashboard-panel dashboard-panel--empty">
                            <div class="dashboard-panel__body">
                                <h3 class="dashboard-panel__title">
                                    <i class="bi bi-folder-x"></i>Keine Projekt-Downloads verfügbar
                                </h3>
                                <p class="dashboard-panel__text mb-0">Du bist derzeit keinem Projekt mit Liedern zugeordnet.</p>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            </div>
        </section>
    </div>
{% endblock content %}

{% block scripts %}
    <script src="/vendor/html-midi-player/dist/midi-player.min.js"></script>
    <script src="{{ asset_path('/js/downloads.js') }}"></script>
{% endblock scripts %}
