{% extends "layout.twig" %}

{% block title %}
    Mailversand-Verwaltung - {{ app_settings.app_name|default("Chor-Manager") }}
{% endblock title %}

{% block page_header %}
    <section class="page-header mail-queue-page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Verwaltung</p>
            <h1 class="h2 mb-1">Mailversand-Verwaltung</h1>
            <p class="text-muted mb-0">Queue, Dead-Letter und Versandzustände an einer Stelle überwachen.</p>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    {% set status_labels = {
        "queued": "In Warteschlange",
        "sending": "Wird gesendet",
        "sent": "Versendet",
        "skipped": "Übersprungen",
        "failed": "Fehlgeschlagen",
        "dead": "Endgültig fehlgeschlagen"
    } %}
    {% set status_badges = {
        "queued": "bg-secondary",
        "sending": "bg-primary",
        "sent": "bg-success",
        "skipped": "bg-info text-dark",
        "failed": "bg-warning text-dark",
        "dead": "bg-danger"
    } %}
    {% set type_labels = {"newsletter": "Newsletter", "invitation": "Einladung", "password_reset": "Passwort zurücksetzen"} %}
    {% set has_entries = entries|length > 0 %}

    <div class="mail-queue-overview-grid mb-4">
        <article class="surface-card mail-queue-stat-card">
            <span class="mail-queue-stat-card__label">In Warteschlange</span>
            <strong class="mail-queue-stat-card__value">{{ stats.queued }}</strong>
            <span class="mail-queue-stat-card__meta">Bereit für den nächsten Versandlauf</span>
        </article>
        <article class="surface-card mail-queue-stat-card">
            <span class="mail-queue-stat-card__label">Wird gesendet</span>
            <strong class="mail-queue-stat-card__value">{{ stats.sending }}</strong>
            <span class="mail-queue-stat-card__meta">Aktuell in Bearbeitung</span>
        </article>
        <article class="surface-card mail-queue-stat-card">
            <span class="mail-queue-stat-card__label">Versendet</span>
            <strong class="mail-queue-stat-card__value">{{ stats.sent }}</strong>
            <span class="mail-queue-stat-card__meta">Vom Provider akzeptierte Mails</span>
        </article>
        <article class="surface-card mail-queue-stat-card">
            <span class="mail-queue-stat-card__label">Übersprungen</span>
            <strong class="mail-queue-stat-card__value">{{ stats.skipped }}</strong>
            <span class="mail-queue-stat-card__meta">Absichtlich nicht versendete Mails</span>
        </article>
        <article class="surface-card mail-queue-stat-card">
            <span class="mail-queue-stat-card__label">Fehlgeschlagen</span>
            <strong class="mail-queue-stat-card__value">{{ stats.failed }}</strong>
            <span class="mail-queue-stat-card__meta">Warten auf erneuten Versuch</span>
        </article>
        <article class="surface-card mail-queue-stat-card mail-queue-stat-card--critical">
            <span class="mail-queue-stat-card__label">Endgültig fehlgeschlagen</span>
            <strong class="mail-queue-stat-card__value">{{ stats.dead }}</strong>
            <span class="mail-queue-stat-card__meta">Benötigen manuelle Prüfung</span>
        </article>
    </div>

    {% if stats.dead > 0 %}
        <div class="mail-queue-overview-actions mb-4">
            <form method="post"
                  action="/admin/mail-queue/retry-all-dead"
                  class="d-inline">
                <button type="submit"
                        class="btn btn-warning"
                        onclick="return confirm('{{ stats.dead }} endgültig fehlgeschlagene Einträge erneut einreihen?');">
                    Alle endgültig fehlgeschlagenen Einträge erneut einreihen
                </button>
            </form>
            <p class="mail-queue-overview-actions__hint mb-0">
                Endgültig fehlgeschlagene Einträge werden sofort wieder als reguläre Queue-Einträge markiert.
            </p>
        </div>
    {% endif %}

    <div class="mail-queue-content-shell">
        <div class="surface-card card border-0 table-shell"
             data-table-engine="true"
             data-table-id="mail-queue.index"
             data-table-plugins="mailQueueFilters"
             data-default-view="auto"
             data-default-page-size="50"
             data-page-size-options="25,50,100,200"
             data-default-sort-key="created"
             data-default-sort-dir="desc">
            <div class="card-header">
                <h5>Queue-Einträge</h5>
            </div>
            <div class="card-body">
                {{ include('partials/table_toolbar.twig') }}

                {% if has_entries %}
                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle mb-0 table-responsive-cards"
                               id="mailQueueTable">
                            <thead>
                                <tr>
                                    <th data-sort-key="id" data-sort-type="number">ID</th>
                                    <th data-sort-key="type" data-sort-type="text">Typ</th>
                                    <th data-sort-key="recipient" data-sort-type="text">Empfänger</th>
                                    <th data-sort-key="status" data-sort-type="text">Status</th>
                                    <th data-sort-key="attempts" data-sort-type="number">Versuche</th>
                                    <th data-sort-key="error" data-sort-type="text">Letzter Fehler</th>
                                    <th data-sort-key="created" data-sort-type="date">Erstellt</th>
                                    <th data-sort-key="nextAttempt" data-sort-type="date">Nächster Versuch</th>
                                    <th>Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for entry in entries %}
                                    {% set next_attempt_value = entry.next_attempt_at ? entry.next_attempt_at.format('Y-m-d H:i:s') : '' %}
                                    {% set created_value = entry.created_at ? entry.created_at.format('Y-m-d H:i:s') : '' %}
                                    <tr data-sort-id="{{ entry.id }}"
                                        data-queue-status="{{ entry.status|default('')|lower }}"
                                        data-queue-type="{{ entry.mail_type|default('')|lower }}"
                                        data-sort-type="{{ type_labels[entry.mail_type]|default(entry.mail_type|default('Unbekannt'))|lower }}"
                                        data-sort-recipient="{{ entry.recipient_email ?: '—' }}"
                                        data-sort-status="{{ status_labels[entry.status]|default(entry.status|default('Unbekannt'))|lower }}"
                                        data-sort-attempts="{{ entry.attempts }}"
                                        data-sort-error="{{ entry.error_code ?: '—' }}"
                                        data-sort-created="{{ created_value }}"
                                        data-sort-next-attempt="{{ next_attempt_value }}">
                                        <td data-label="ID">{{ entry.id }}</td>
                                        <td data-label="Typ">
                                            <span class="badge bg-info text-dark">{{ type_labels[entry.mail_type]|default(entry.mail_type|default('Unbekannt')) }}</span>
                                        </td>
                                        <td data-label="Empfänger">{{ entry.recipient_email ?: '—' }}</td>
                                        <td data-label="Status">
                                            <span class="badge {{ status_badges[entry.status]|default('bg-dark') }}">
                                                {{ status_labels[entry.status]|default(entry.status|default('Unbekannt')) }}
                                            </span>
                                        </td>
                                        <td data-label="Versuche">{{ entry.attempts }}/{{ entry.max_attempts }}</td>
                                        <td data-label="Letzter Fehler">
                                            {% if entry.error_code %}
                                                <a href="/admin/mail-queue/{{ entry.id }}"
                                                   title="{{ entry.error_message|slice(0, 100) }}">
                                                    {{ entry.error_code }}
                                                </a>
                                            {% else %}
                                                —
                                            {% endif %}
                                        </td>
                                        <td data-label="Erstellt">
                                            {% if entry.created_at %}
                                                {{ entry.created_at.format('d.m.Y H:i') }}
                                            {% else %}
                                                —
                                            {% endif %}
                                        </td>
                                        <td data-label="Nächster Versuch">
                                            {% if entry.next_attempt_at %}
                                                {{ entry.next_attempt_at.format('d.m.Y H:i') }}
                                            {% else %}
                                                —
                                            {% endif %}
                                        </td>
                                        <td data-label="Aktionen">
                                            {% if entry.status == 'dead' %}
                                                <form method="post"
                                                      action="/admin/mail-queue/{{ entry.id }}/retry"
                                                      class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-warning">Erneut einreihen</button>
                                                </form>
                                            {% else %}
                                                —
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <p class="text-muted">Keine Einträge gefunden.</p>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock content %}

{% block scripts %}
    <script src="/js/table-plugins/mail-queue-plugin.js"></script>
{% endblock scripts %}
