{% extends "layout.twig" %}

{% block title %}
    Mailversand-Detail - {{ app_settings.app_name|default("Chor-Manager") }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item">
                        <a href="/admin/mail-queue">Mailversand</a>
                    </li>
                    <li class="breadcrumb-item active">Eintrag #{{ entry.id }}</li>
                </ol>
            </nav>
            <p class="text-uppercase text-muted small mb-1">Verwaltung</p>
            <h1 class="h2 mb-1">Mail-Queue-Eintrag #{{ entry.id }}</h1>
            <p class="text-muted mb-0">Status, Versandhistorie und Inhalt auf einen Blick.</p>
        </div>
        <div class="page-actions">
            <a href="/admin/mail-queue" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Zur Übersicht
            </a>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    {% set status_labels = {
        queued: "In Warteschlange",
        sending: "Wird gesendet",
        sent: "Versendet",
        skipped: "Übersprungen",
        failed: "Fehlgeschlagen",
        dead: "Endgültig fehlgeschlagen",
    } %}
    {% set status_badges = {
        queued: "bg-secondary",
        sending: "bg-primary",
        sent: "bg-success",
        skipped: "bg-info text-dark",
        failed: "bg-warning text-dark",
        dead: "bg-danger",
    } %}
    {% set type_labels = {newsletter: "Newsletter", invitation: "Einladung", password_reset: "Passwort zurücksetzen"} %}

    <div class="dashboard-shell">
        <section class="dashboard-section dashboard-section--context"
                 aria-labelledby="mail-queue-details-title">
            <div class="dashboard-section-head">
                <h2 class="dashboard-section-title" id="mail-queue-details-title">Details</h2>
                <p class="dashboard-section-lead mb-0">Technische Daten zum Versandvorgang.</p>
            </div>

            <div class="surface-card card border-0">
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Typ:</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-info text-dark">{{ type_labels[entry.mail_type]|default(entry.mail_type|default('Unbekannt')) }}</span>
                        </dd>

                        <dt class="col-sm-3">Empfänger:</dt>
                        <dd class="col-sm-9">
                            {{ entry.recipient_email }}
                        </dd>

                        <dt class="col-sm-3">Status:</dt>
                        <dd class="col-sm-9">
                            <span class="badge {{ status_badges[entry.status]|default('bg-dark') }}">
                                {{ status_labels[entry.status]|default(entry.status|default('Unbekannt')) }}
                            </span>
                        </dd>

                        <dt class="col-sm-3">Betreff:</dt>
                        <dd class="col-sm-9">
                            {{ entry.subject }}
                        </dd>

                        <dt class="col-sm-3">Versuche:</dt>
                        <dd class="col-sm-9">
                            {{ entry.attempts }}/{{ entry.max_attempts }}
                        </dd>

                        <dt class="col-sm-3">Erstellt:</dt>
                        <dd class="col-sm-9">
                            {{ entry.created_at.format('d.m.Y H:i:s') }}
                        </dd>

                        <dt class="col-sm-3">Letzter Versuch:</dt>
                        <dd class="col-sm-9">
                            {% if entry.last_attempt_at %}
                                {{ entry.last_attempt_at.format('d.m.Y H:i:s') }}
                            {% else %}
                                <em>Nie</em>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-3">Versendet am:</dt>
                        <dd class="col-sm-9">
                            {% if entry.sent_at %}
                                {{ entry.sent_at.format('d.m.Y H:i:s') }}
                            {% else %}
                                <em>Noch nicht versendet</em>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-3">Nächster Versuch:</dt>
                        <dd class="col-sm-9">
                            {% if entry.next_attempt_at %}
                                {{ entry.next_attempt_at.format('d.m.Y H:i:s') }}
                            {% else %}
                                <em>Nicht geplant</em>
                            {% endif %}
                        </dd>
                    </dl>
                </div>
            </div>
        </section>

        {% if entry.error_code %}
            <section class="dashboard-section dashboard-section--context"
                     aria-labelledby="mail-queue-error-title">
                <div class="dashboard-section-head">
                    <h2 class="dashboard-section-title" id="mail-queue-error-title">Fehlerdetails</h2>
                    <p class="dashboard-section-lead mb-0">Letzte bekannte Zustellfehler.</p>
                </div>

                <div class="surface-card card border-danger">
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0">Fehlerprotokoll</h5>
                    </div>
                    <div class="card-body">
                        <p>
                            <strong>Fehlercode:</strong> {{ entry.error_code }}
                        </p>
                        <p>
                            <strong>Fehlermeldung:</strong>
                        </p>
                        <pre>{{ entry.error_message }}</pre>
                    </div>
                </div>
            </section>
        {% endif %}

        <section class="dashboard-section dashboard-section--context"
                 aria-labelledby="mail-queue-content-title">
            <div class="dashboard-section-head">
                <h2 class="dashboard-section-title" id="mail-queue-content-title">E-Mail-Inhalt</h2>
                <p class="dashboard-section-lead mb-0">Gerenderte Vorschau der versendeten Nachricht.</p>
            </div>

            <div class="surface-card card border-0">
                <div class="card-body">
                    <iframe srcdoc="{{ entry.body_html|escape('html_attr') }}"
                            class="mail-queue-preview-frame"></iframe>
                </div>
            </div>
        </section>

        <section class="dashboard-section dashboard-section--actions"
                 aria-labelledby="mail-queue-actions-title">
            <div class="dashboard-section-head">
                <h2 class="dashboard-section-title" id="mail-queue-actions-title">Aktionen</h2>
                <p class="dashboard-section-lead mb-0">Erneut einreihen oder zur Übersicht zurückkehren.</p>
            </div>

            <div class="surface-card card border-0">
                <div class="card-body d-grid gap-2">
                    {% if entry.status == 'dead' %}
                        <form method="post"
                              action="/admin/mail-queue/{{ entry.id }}/retry"
                              class="d-grid">
                            <button type="submit" class="btn btn-warning w-100">Eintrag erneut einreihen</button>
                        </form>
                    {% endif %}

                    <a href="/admin/mail-queue" class="btn btn-secondary w-100">Zur Übersicht</a>
                </div>
            </div>
        </section>
    </div>
{% endblock content %}
