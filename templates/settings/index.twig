{% extends "layout.twig" %}

{% block title %}
    App-Einstellungen - {{ app_settings.app_name|default("Chor-Manager") }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Verwaltung</p>
            <h1 class="h2 mb-1">App-Einstellungen</h1>
            <p class="text-muted mb-0">Name, Logo und Standardfarbe zentral verwalten.</p>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    {% if success %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ success }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}
    {% if error %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ error }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}

    <div class="row">
        <div class="col-md-8">
            <div class="surface-card card border-0">
                <div class="card-body p-4">
                    <form action="/settings"
                          method="post"
                          enctype="multipart/form-data"
                          autocomplete="off"
                          id="app-logo-form"
                          data-upload-compress="true">
                        <div class="mb-4">
                            <label for="app_name" class="form-label fw-bold">Name der App</label>
                            <input type="text"
                                   class="form-control"
                                   id="app_name"
                                   name="app_name"
                                   value="{{ settings.app_name|default("Chor-Manager") }}"
                                   required>
                            <div class="form-text">Dieser Name wird im Header und in den Titeln der App angezeigt.</div>
                        </div>

                        <div class="mb-4">
                            <label for="app_logo" class="form-label fw-bold">Logo hochladen</label>
                            <div class="d-flex align-items-start gap-4">
                                <div class="bg-light p-3 rounded border text-center logo-preview-frame">
                                    <img src="/logo"
                                         alt="Aktuelles Logo"
                                         width="200"
                                         height="80"
                                         class="mb-2 d-inline-block logo-preview">
                                    <div class="small text-muted">Aktuelles Logo</div>
                                </div>
                                <div class="flex-grow-1">
                                    <input class="form-control"
                                           type="file"
                                           id="app_logo"
                                           name="app_logo"
                                           accept="image/*">
                                    <div class="form-text">Empfohlen: Transparentes PNG oder WEBP mit ca. 200x50 Pixeln.</div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="primary_color" class="form-label fw-bold">Primärfarbe</label>
                            <input type="text"
                                   class="form-control"
                                   id="primary_color"
                                   name="primary_color"
                                   value="{{ settings.primary_color|default("#E8A817") }}"
                                   inputmode="text"
                                   pattern="^#?[A-Fa-f0-9]{3}([A-Fa-f0-9]{3})?$">
                            <div class="form-text">Hex-Farbwert, zum Beispiel #E8A817. Leer oder ungültig fällt auf das Standardgelb zurück.</div>
                        </div>

                        <hr class="my-4">

                        <h2 class="h5 mb-3">Mail-Queue</h2>

                        <div class="mb-4">
                            <label for="mailqueue_trigger_mode" class="form-label fw-bold">Trigger-Modus</label>
                            <select class="form-select"
                                    id="mailqueue_trigger_mode"
                                    name="mailqueue_trigger_mode">
                                <option value="hybrid" {% if settings.mailqueue_trigger_mode|default('hybrid') == 'hybrid' %}selected{% endif %}>Hybrid</option>
                                <option value="cron" {% if settings.mailqueue_trigger_mode|default('hybrid') == 'cron' %}selected{% endif %}>Nur Cron</option>
                                <option value="opportunistic" {% if settings.mailqueue_trigger_mode|default('hybrid') == 'opportunistic' %}selected{% endif %}>Nur opportunistisch</option>
                            </select>
                            <div class="form-text">Steuert, ob die Queue per Cron, opportunistisch oder gemischt verarbeitet werden soll.</div>
                        </div>

                        <div class="mb-4">
                            <label for="mailqueue_opportunistic_rate_limit" class="form-label fw-bold">Opportunistisches Rate-Limit pro Minute</label>
                            <input type="number"
                                   class="form-control"
                                   id="mailqueue_opportunistic_rate_limit"
                                   name="mailqueue_opportunistic_rate_limit"
                                   min="1"
                                   value="{{ settings.mailqueue_opportunistic_rate_limit|default('10') }}">
                            <div class="form-text">Maximale Anzahl opportunistischer Queue-Trigger pro Minute.</div>
                        </div>

                        <div class="mb-4">
                            <label for="mailqueue_batch_size" class="form-label fw-bold">Batch-Größe</label>
                            <input type="number"
                                   class="form-control"
                                   id="mailqueue_batch_size"
                                   name="mailqueue_batch_size"
                                   min="1"
                                   value="{{ settings.mailqueue_batch_size|default('50') }}">
                            <div class="form-text">Wie viele Queue-Einträge pro Lauf verarbeitet werden.</div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="/dashboard" class="btn btn-outline-secondary me-md-2">Abbrechen</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Einstellungen speichern
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

{% endblock content %}
