<!DOCTYPE html>
<html lang="de" data-bs-theme="light">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description"
              content="{{ app_settings.app_description|default("Chor Manager – Verwaltung von Mitgliedern, Terminen und Projekten.") }}">
        <meta name="keywords"
              content="{{ app_settings.app_keywords|default("chor, chorverwaltung, mitglieder, termine, projekte, newsletter") }}">
        <title>
            {% block title %}
                {{ app_settings.app_name|default("Chor Manager") }}
            {% endblock title %}
        </title>
        <!-- Bootstrap CSS -->
        <link rel="stylesheet" href="/vendor/bootstrap/dist/css/bootstrap.min.css">
        <!-- Bootstrap Icons -->
        <link rel="stylesheet"
              href="/vendor/bootstrap-icons/font/bootstrap-icons.css">
        <link rel="stylesheet" href="/css/style.css">
        <link rel="stylesheet" href="/theme.css">
        <link rel="stylesheet" href="/css/table-engine.css">
        <link rel="stylesheet" href="/css/responsive-tables.css">
    </head>
    <body class="app-shell">
        {% if session.user_id %}
            {% set path = current_path|default('/') %}
            {% set nav = active_nav|default('') %}
            {% set is_dashboard_active = nav_active(path, nav, ['/', '/dashboard'], ['dashboard']) %}
            {% set is_events_active = nav_active(path, nav, ['/events', '/attendance'], ['events']) %}
            {% set is_areas_active = nav_active(path, nav, ['/users', '/finances', '/sponsoring', '/song-library', '/downloads', '/newsletters'], ['users', 'finances', 'sponsoring', 'song_library', 'downloads', 'newsletters']) %}
            {% set is_admin_active = nav_active(path, nav, ['/projects', '/roles', '/voice-groups', '/event-types', '/settings'], ['projects', 'roles', 'voice_groups', 'event_types', 'settings']) %}
            {% set is_evaluations_active = nav_active(path, nav, ['/evaluations'], ['evaluations', 'evaluations_project_members']) %}
            {% set can_show_admin = session.can_manage_master_data or session.can_manage_users or session.role_level >= 40 %}
            {% set can_show_evaluations = session.can_manage_users or session.role_level >= 40 or session.can_manage_project_members %}
            <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top app-topbar">
                <div class="container-fluid app-topbar__inner">
                    <a class="navbar-brand d-flex align-items-center" href="/dashboard">
                        <img src="/logo" alt="Logo" class="me-2 navbar-logo">
                        <span class="app-topbar__brand-name">{{ app_settings.app_name|default("Chor Manager") }}</span></a>
                    <button class="navbar-toggler"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#navbarsExampleDefault"
                            aria-controls="navbarsExampleDefault"
                            aria-expanded="false"
                            aria-label="Toggle navigation">
                        <i class="bi bi-list fs-3 text-white toggler-icon toggler-icon-open"
                           aria-hidden="true"></i>
                        <i class="bi bi-x-lg fs-4 text-white toggler-icon toggler-icon-close"
                           aria-hidden="true"></i>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarsExampleDefault">
                        <ul class="navbar-nav me-auto mb-2 mb-md-0">
                            {{ include('partials/navigation/dashboard.twig', {
                            is_dashboard_active: is_dashboard_active,
                            }, false) }}
                            {{ include('partials/navigation/events.twig', {
                            is_events_active: is_events_active,
                            path: path,
                            nav: nav,
                            }, false) }}
                            {{ include('partials/navigation/areas.twig', {
                            is_areas_active: is_areas_active,
                            path: path,
                            nav: nav,
                            session: session,
                            }, false) }}
                            {{ include('partials/navigation/evaluations.twig', {
                            can_show_evaluations: can_show_evaluations,
                            is_evaluations_active: is_evaluations_active,
                            path: path,
                            nav: nav,
                            session: session,
                            }, false) }}
                            {{ include('partials/navigation/admin.twig', {
                            can_show_admin: can_show_admin,
                            is_admin_active: is_admin_active,
                            path: path,
                            nav: nav,
                            session: session,
                            }, false) }}
                        </ul>
                        {{ include('partials/navigation/user_menu.twig', [], false) }}

                    </div>
                </div>
            </nav>
        {% endif %}
        <main class="app-main container-fluid">
            {% block page_header %}
            {% endblock page_header %}
            <div class="app-content container-xl">
                {% block content %}
                {% endblock content %}
            </div>
        </main>
        <!-- Bootstrap JS Bundle -->
        <script src="/vendor/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="/js/table-preferences.js"></script>
        <script src="/js/table-engine.js"></script>
        <script src="/js/table-plugins/users-manage-plugin.js"></script>
        <script src="/js/common.js"></script>
        <script src="/vendor/tinymce/tinymce/tinymce.min.js"></script>
        <script src="/js/tinymce-init.js"></script>
        {% block scripts %}
        {% endblock scripts %}
    </body>
</html>
