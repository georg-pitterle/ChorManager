<!DOCTYPE html>
<html lang="de" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ app_settings.app_name|default('Chor Manager') }}{% endblock %}</title>
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="/vendor/bootstrap/dist/css/bootstrap.min.css">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="/vendor/bootstrap-icons/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/responsive-tables.css">
</head>
<body>
    {% if session.user_id %}
    {% set path = current_path|default('/') %}
    {% set is_dashboard_active = path == '/' or path starts with '/dashboard' or active_nav|default('') == 'dashboard' %}
    {% set is_events_active = path starts with '/events' or path starts with '/attendance' or active_nav|default('') == 'events' %}
    {% set is_areas_active = path starts with '/finances' or path starts with '/sponsoring' or path starts with '/song-library' or path starts with '/downloads' or active_nav|default('') in ['finances', 'sponsoring', 'song_library', 'downloads'] %}
    {% set is_admin_active = path starts with '/users' or path starts with '/projects' or path starts with '/roles' or path starts with '/voice-groups' or path starts with '/event-types' or path starts with '/settings' or active_nav|default('') in ['users', 'projects', 'roles', 'voice_groups', 'event_types', 'settings'] %}
    {% set is_evaluations_active = path starts with '/evaluations' or active_nav|default('') == 'evaluations' %}

    {% set can_show_admin = session.can_manage_master_data or session.can_manage_users or session.role_level >= 40 %}
    {% set can_show_evaluations = session.can_manage_users or session.role_level >= 40 or session.can_manage_project_members %}

    <nav class="navbar navbar-expand-md navbar-dark bg-dark fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center" href="/dashboard"><img src="/logo" alt="Logo" height="36" class="me-2"> {{ app_settings.app_name|default('Chor Manager') }}</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarsExampleDefault" aria-controls="navbarsExampleDefault" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarsExampleDefault">
                <ul class="navbar-nav me-auto mb-2 mb-md-0">
                    <li class="nav-item">
                        <a class="nav-link {% if is_dashboard_active %}active{% endif %}" href="/dashboard"><i class="bi bi-house me-1"></i> Dashboard</a>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle {% if is_events_active %}active{% endif %}" href="#" data-bs-toggle="dropdown" aria-expanded="false"><i class="bi bi-calendar-event me-1"></i> Termine</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item {% if path starts with '/events' or active_nav|default('') == 'events' %}active{% endif %}" href="/events"><i class="bi bi-calendar-event me-2"></i> Termine</a></li>
                            <li><a class="dropdown-item {% if path starts with '/attendance' %}active{% endif %}" href="/attendance"><i class="bi bi-check2-square me-2"></i> Anwesenheit</a></li>
                        </ul>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle {% if is_areas_active %}active{% endif %}" href="#" data-bs-toggle="dropdown" aria-expanded="false"><i class="bi bi-grid-3x3-gap-fill me-1"></i> Bereiche</a>
                        <ul class="dropdown-menu">
                            {% if session.can_manage_finances %}
                            <li><a class="dropdown-item {% if path starts with '/finances' or active_nav|default('') == 'finances' %}active{% endif %}" href="/finances"><i class="bi bi-bank me-2"></i> Kassa</a></li>
                            {% endif %}
                            {% if session.can_manage_sponsoring %}
                            <li><a class="dropdown-item {% if path starts with '/sponsoring' or active_nav|default('') == 'sponsoring' %}active{% endif %}" href="/sponsoring"><i class="bi bi-briefcase me-2"></i> Sponsoring</a></li>
                            {% endif %}
                            {% if session.can_manage_song_library %}
                            <li><a class="dropdown-item {% if path starts with '/song-library' or active_nav|default('') == 'song_library' %}active{% endif %}" href="/song-library"><i class="bi bi-music-note-list me-2"></i> Liedbibliothek</a></li>
                            {% endif %}
                            <li><a class="dropdown-item {% if path starts with '/downloads' or active_nav|default('') == 'downloads' %}active{% endif %}" href="/downloads"><i class="bi bi-download me-2"></i> Downloads</a></li>
                        </ul>
                    </li>

                    {% if can_show_admin %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle {% if is_admin_active %}active{% endif %}" href="#" data-bs-toggle="dropdown" aria-expanded="false"><i class="bi bi-gear-fill me-1"></i> Verwaltung</a>
                        <ul class="dropdown-menu">
                            {% if session.can_manage_users or session.role_level >= 40 %}
                            <li><a class="dropdown-item {% if path starts with '/users' or active_nav|default('') == 'users' %}active{% endif %}" href="/users"><i class="bi bi-people-fill me-2"></i> Mitgliederverwaltung</a></li>
                            {% endif %}
                            {% if session.can_manage_master_data or session.can_manage_users %}
                            <li><a class="dropdown-item {% if path starts with '/projects' or active_nav|default('') == 'projects' %}active{% endif %}" href="/projects"><i class="bi bi-folder-fill me-2"></i> Projekte</a></li>
                            <li><a class="dropdown-item {% if path starts with '/roles' or active_nav|default('') == 'roles' %}active{% endif %}" href="/roles"><i class="bi bi-shield-lock-fill me-2"></i> Rollen</a></li>
                            <li><a class="dropdown-item {% if path starts with '/voice-groups' or active_nav|default('') == 'voice_groups' %}active{% endif %}" href="/voice-groups"><i class="bi bi-music-note-beamed me-2"></i> Stimmgruppen</a></li>
                            <li><a class="dropdown-item {% if path starts with '/event-types' or active_nav|default('') == 'event_types' %}active{% endif %}" href="/event-types"><i class="bi bi-tag me-2"></i> Event-Typen</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item {% if path starts with '/settings' or active_nav|default('') == 'settings' %}active{% endif %}" href="/settings"><i class="bi bi-sliders me-2"></i> App-Einstellungen</a></li>
                            {% endif %}
                        </ul>
                    </li>
                    {% endif %}

                    {% if can_show_evaluations %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle {% if is_evaluations_active %}active{% endif %}" href="#" data-bs-toggle="dropdown" aria-expanded="false"><i class="bi bi-bar-chart-fill me-1"></i> Auswertungen</a>
                        <ul class="dropdown-menu">
                            {% if session.can_manage_users or session.role_level >= 40 %}
                            <li><a class="dropdown-item {% if path starts with '/evaluations' and not (path starts with '/evaluations/project-members') %}active{% endif %}" href="/evaluations"><i class="bi bi-bar-chart-line-fill me-2"></i> Anwesenheitsquoten</a></li>
                            {% endif %}
                            <li><a class="dropdown-item {% if path starts with '/evaluations/project-members' %}active{% endif %}" href="/evaluations/project-members"><i class="bi bi-people-fill me-2"></i> Projektmitglieder</a></li>
                        </ul>
                    </li>
                    {% endif %}
                </ul>
                <div class="d-flex align-items-center text-white dropdown">
                    <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-person-circle fs-5 me-2"></i>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userDropdown">
                        <li><a class="dropdown-item" href="/profile"><i class="bi bi-person-fill me-2"></i> Mein Profil</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Abmelden</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>
    {% endif %}

    <main class="container">
        {% block content %}{% endblock %}
    </main>

    <!-- Bootstrap JS Bundle -->
    <script src="/vendor/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/common.js"></script>

    <!-- TinyMCE WYSIWYG Editor -->
    <script src="https://cdn.tiny.cloud/1/no-api-key/tinymce/6/tinymce.min.js"></script>
    <script>
        if (document.querySelector('.tinymce-editor')) {
            tinymce.init({
                selector: '.tinymce-editor',
                plugins: 'image link media table lists code fullscreen',
                toolbar: 'undo redo | formatselect | bold italic underline | forecolor | alignleft aligncenter alignright | bullist numlist outdent indent | link image media table | code fullscreen',
                height: 400,
                menubar: 'file edit view insert format tools table help',
                content_style: 'body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; font-size: 14px; }',
                setup: function(editor) {
                    editor.on('change', function() {
                        tinymce.triggerSave();
                    });
                }
            });
        }
    </script>

    {% block scripts %}{% endblock %}
</body>
</html>
