<!DOCTYPE html>
<html lang="de" data-bs-theme="light">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="theme-color" content="#1f3a5f">
        <meta name="mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-status-bar-style" content="default">
        <meta name="csrf-token" content="{{ csrf_token }}">
        <meta name="description"
              content="{{ app_settings.app_description|default('Chor-Manager – Verwaltung von Mitgliedern, Terminen und Projekten.') }}">
        <meta name="keywords"
              content="{{ app_settings.app_keywords|default('chor, chorverwaltung, mitglieder, termine, projekte, newsletter') }}">
        <title>
            {% block title %}
                {{ app_settings.app_name|default('Chor-Manager') }}
            {% endblock title %}
        </title>
        <link rel="manifest" href="/manifest.webmanifest">
        <link rel="icon" href="/favicon.ico" sizes="any">
        <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">
        <!-- Bootstrap CSS -->
        <link rel="stylesheet" href="/vendor/bootstrap/dist/css/bootstrap.min.css">
        <!-- Bootstrap Icons -->
        <link rel="stylesheet"
              href="/vendor/bootstrap-icons/font/bootstrap-icons.css">
        <link rel="stylesheet" href="{{ asset_path('/css/style.css') }}">
        <link rel="stylesheet" href="{{ asset_path('/theme.css') }}">
        <link rel="stylesheet" href="{{ asset_path('/css/table-engine.css') }}">
    </head>
    <body class="app-shell">
        {% if session.user_id %}
            {% set navigation = navigation(active_nav|default("")) %}
            <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top app-topbar">
                <div class="container-fluid app-topbar__inner">
                    <a class="navbar-brand d-flex align-items-center" href="/dashboard">
                        <img src="/logo"
                             alt="Logo"
                             width="200"
                             height="64"
                             class="me-2 navbar-logo">
                        <span class="app-topbar__brand-name">{{ app_settings.app_name|default('Chor-Manager') }}</span></a>
                    <button class="navbar-toggler"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#navbarsExampleDefault"
                            aria-controls="navbarsExampleDefault"
                            aria-expanded="false"
                            aria-label="Toggle navigation">
                        <i class="bi bi-list fs-3 text-white toggler-icon toggler-icon-open"
                           aria-hidden="true"></i>
                        <i class="bi bi-x-lg fs-4 text-white toggler-icon toggler-icon-close"
                           aria-hidden="true"></i>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarsExampleDefault">
                        <ul class="navbar-nav me-auto mb-2 mb-md-0">
                            {{ include('partials/navigation/menu.twig', {navigation: navigation}, false) }}
                        </ul>
                        {{ include('partials/navigation/user_menu.twig', [], false) }}

                    </div>
                </div>
            </nav>
        {% endif %}
        <main class="app-main container-fluid">
            {% block page_header %}
            {% endblock page_header %}
            <div class="app-content container-xl">
                {% block content %}
                {% endblock content %}
            </div>
        </main>
        <!-- Bootstrap JS Bundle -->
        <script src="/vendor/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="{{ asset_path('/js/table-preferences.js') }}"></script>
        <script src="{{ asset_path('/js/table-engine.js') }}"></script>
        <script src="{{ asset_path('/js/table-plugins/users-manage-plugin.js') }}"></script>
        <script src="{{ asset_path('/js/table-plugins/users-group-plugin.js') }}"></script>
        <script src="{{ asset_path('/js/common.js') }}"></script>
        <script src="{{ asset_path('/js/upload-helper.js') }}"></script>
        <script src="/vendor/tinymce/tinymce/tinymce.min.js"></script>
        <script src="{{ asset_path('/js/tinymce-init.js') }}"></script>
        {% block scripts %}
        {% endblock scripts %}
    </body>
</html>
