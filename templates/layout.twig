<!DOCTYPE html>
<html lang="de" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ app_settings.app_name|default('Chor Manager') }}{% endblock %}</title>
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="/vendor/bootstrap/dist/css/bootstrap.min.css">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="/vendor/bootstrap-icons/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/theme.css">
    <link rel="stylesheet" href="/css/table-engine.css">
    <link rel="stylesheet" href="/css/responsive-tables.css">
</head>
<body class="app-shell">
    {% if session.user_id %}
    {% set path = current_path|default('/') %}
    {% set nav = active_nav|default('') %}
    {% set is_dashboard_active = nav_active(path, nav, ['/', '/dashboard'], ['dashboard']) %}
    {% set is_events_active = nav_active(path, nav, ['/events', '/attendance'], ['events']) %}
    {% set is_areas_active = nav_active(path, nav, ['/finances', '/sponsoring', '/song-library', '/downloads', '/newsletters'], ['finances', 'sponsoring', 'song_library', 'downloads', 'newsletters', 'newsletters_archive', '/newsletters/archive']) %}
    {% set is_admin_active = nav_active(path, nav, ['/users', '/projects', '/roles', '/voice-groups', '/event-types', '/settings'], ['users', 'projects', 'roles', 'voice_groups', 'event_types', 'settings']) %}
    {% set is_evaluations_active = nav_active(path, nav, ['/evaluations'], ['evaluations', 'evaluations_project_members']) %}

    {% set can_show_admin = session.can_manage_master_data or session.can_manage_users or session.role_level >= 40 %}
    {% set can_show_evaluations = session.can_manage_users or session.role_level >= 40 or session.can_manage_project_members %}

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top app-topbar">
        <div class="container-fluid app-topbar__inner">
            <a class="navbar-brand d-flex align-items-center" href="/dashboard"><img src="/logo" alt="Logo" height="36" class="me-2"><span class="app-topbar__brand-name">{{ app_settings.app_name|default('Chor Manager') }}</span></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarsExampleDefault" aria-controls="navbarsExampleDefault" aria-expanded="false" aria-label="Toggle navigation">
                <i class="bi bi-list fs-3 text-white" aria-hidden="true"></i>
            </button>

            <div class="collapse navbar-collapse" id="navbarsExampleDefault">
                <ul class="navbar-nav me-auto mb-2 mb-md-0">
                    <li class="nav-item">
                        <a class="nav-link {% if is_dashboard_active %}active{% endif %}" href="/dashboard"><i class="bi bi-house me-1"></i> Dashboard</a>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle {% if is_events_active %}active{% endif %}" href="#" data-bs-toggle="dropdown" aria-expanded="false"><i class="bi bi-calendar-event me-1"></i> Termine</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item {% if nav_active(path, nav, ['/events'], ['events']) %}active{% endif %}" href="/events"><i class="bi bi-calendar-event me-2"></i> Termine</a></li>
                            <li><a class="dropdown-item {% if nav_active(path, nav, ['/attendance'], ['attendance']) %}active{% endif %}" href="/attendance"><i class="bi bi-check2-square me-2"></i> Anwesenheit</a></li>
                        </ul>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle {% if is_areas_active %}active{% endif %}" href="#" data-bs-toggle="dropdown" aria-expanded="false"><i class="bi bi-grid-3x3-gap-fill me-1"></i> Bereiche</a>
                        <ul class="dropdown-menu">
                            {% if session.can_manage_finances %}
                            <li><a class="dropdown-item {% if nav_active(path, nav, ['/finances'], ['finances']) %}active{% endif %}" href="/finances"><i class="bi bi-bank me-2"></i> Kassa</a></li>
                            {% endif %}
                            {% if session.can_manage_sponsoring %}
                            <li><a class="dropdown-item {% if nav_active(path, nav, ['/sponsoring'], ['sponsoring']) %}active{% endif %}" href="/sponsoring"><i class="bi bi-briefcase me-2"></i> Sponsoring</a></li>
                            {% endif %}
                            {% if session.can_manage_song_library %}
                            <li><a class="dropdown-item {% if nav_active(path, nav, ['/song-library'], ['song_library']) %}active{% endif %}" href="/song-library"><i class="bi bi-music-note-list me-2"></i> Liedbibliothek</a></li>
                            {% endif %}
                            <li><a class="dropdown-item {% if nav_active(path, nav, ['/downloads'], ['downloads']) %}active{% endif %}" href="/downloads"><i class="bi bi-download me-2"></i> Downloads</a></li>
                            <li><a class="dropdown-item {% if nav_active(path, nav, ['/newsletters/archive'], ['newsletters_archive', '/newsletters/archive']) %}active{% endif %}" href="/newsletters/archive"><i class="bi bi-envelope me-2"></i> Meine Newsletter</a></li>
                            {% if session.can_manage_newsletters %}
                            <li><a class="dropdown-item {% if nav_active(path, nav, ['/newsletters'], ['newsletters'], ['/newsletters/archive']) %}active{% endif %}" href="/newsletters"><i class="bi bi-envelope-open me-2"></i> Newsletter</a></li>
                            {% endif %}
                        </ul>
                    </li>

                    {% if can_show_admin %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle {% if is_admin_active %}active{% endif %}" href="#" data-bs-toggle="dropdown" aria-expanded="false"><i class="bi bi-gear-fill me-1"></i> Verwaltung</a>
                        <ul class="dropdown-menu">
                            {% if session.can_manage_users or session.role_level >= 40 %}
                            <li><a class="dropdown-item {% if nav_active(path, nav, ['/users'], ['users']) %}active{% endif %}" href="/users"><i class="bi bi-people-fill me-2"></i> Mitgliederverwaltung</a></li>
                            {% endif %}
                            {% if session.can_manage_master_data or session.can_manage_users %}
                            <li><a class="dropdown-item {% if nav_active(path, nav, ['/projects'], ['projects']) %}active{% endif %}" href="/projects"><i class="bi bi-folder-fill me-2"></i> Projekte</a></li>
                            <li><a class="dropdown-item {% if nav_active(path, nav, ['/roles'], ['roles']) %}active{% endif %}" href="/roles"><i class="bi bi-shield-lock-fill me-2"></i> Rollen</a></li>
                            <li><a class="dropdown-item {% if nav_active(path, nav, ['/voice-groups'], ['voice_groups']) %}active{% endif %}" href="/voice-groups"><i class="bi bi-music-note-beamed me-2"></i> Stimmgruppen</a></li>
                            <li><a class="dropdown-item {% if nav_active(path, nav, ['/event-types'], ['event_types']) %}active{% endif %}" href="/event-types"><i class="bi bi-tag me-2"></i> Event-Typen</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item {% if nav_active(path, nav, ['/settings'], ['settings']) %}active{% endif %}" href="/settings"><i class="bi bi-sliders me-2"></i> App-Einstellungen</a></li>
                            {% endif %}
                        </ul>
                    </li>
                    {% endif %}

                    {% if can_show_evaluations %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle {% if is_evaluations_active %}active{% endif %}" href="#" data-bs-toggle="dropdown" aria-expanded="false"><i class="bi bi-bar-chart-fill me-1"></i> Auswertungen</a>
                        <ul class="dropdown-menu">
                            {% if session.can_manage_users or session.role_level >= 40 %}
                            <li><a class="dropdown-item {% if nav_active(path, nav, ['/evaluations'], ['evaluations'], ['/evaluations/project-members']) %}active{% endif %}" href="/evaluations"><i class="bi bi-bar-chart-line-fill me-2"></i> Anwesenheitsquoten</a></li>
                            {% endif %}
                            <li><a class="dropdown-item {% if nav_active(path, nav, ['/evaluations/project-members'], ['evaluations_project_members']) %}active{% endif %}" href="/evaluations/project-members"><i class="bi bi-people-fill me-2"></i> Projektmitglieder</a></li>
                        </ul>
                    </li>
                    {% endif %}
                </ul>
                <div class="d-flex align-items-center text-white dropdown">
                    <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-person-circle fs-5 me-2"></i>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userDropdown">
                        <li><a class="dropdown-item" href="/profile"><i class="bi bi-person-fill me-2"></i> Mein Profil</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Abmelden</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>
    {% endif %}

    <main class="app-main container-fluid">
        {% block page_header %}{% endblock %}
        <div class="app-content container-xl">
            {% block content %}{% endblock %}
        </div>
    </main>

    <!-- Bootstrap JS Bundle -->
    <script src="/vendor/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/table-preferences.js"></script>
    <script src="/js/table-engine.js"></script>
    <script src="/js/common.js"></script>

    <script src="/vendor/tinymce/tinymce/tinymce.min.js"></script>
    <script src="/js/tinymce-init.js"></script>

    {% block scripts %}{% endblock %}
</body>
</html>
