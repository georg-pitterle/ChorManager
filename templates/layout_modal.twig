<!DOCTYPE html>
<html lang="de" data-bs-theme="light">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="theme-color" content="#1f3a5f">
        <meta name="mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-status-bar-style" content="default">
        <meta name="csrf-token" content="{{ csrf_token }}">
        <meta name="description"
              content="{{ app_settings.app_description|default("Chor-Manager – Verwaltung von Mitgliedern, Terminen und Projekten.") }}">
        <meta name="keywords"
              content="{{ app_settings.app_keywords|default("chor, chorverwaltung, mitglieder, termine, projekte, newsletter") }}">
        <title>
            {% block title %}
                app_settings.app_name|default("Chor-Manager")
            {% endblock title %}
        </title>
        <link rel="manifest" href="/manifest.webmanifest">
        <link rel="icon" href="/favicon.ico" sizes="any">
        <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">
        <link rel="stylesheet" href="/vendor/bootstrap/dist/css/bootstrap.min.css">
        <link rel="stylesheet"
              href="/vendor/bootstrap-icons/font/bootstrap-icons.css">
        <link rel="stylesheet" href="/css/style.css">
        <link rel="stylesheet" href="/theme.css">
    </head>
    <body class="p-3">
        {% block content %}
        {% endblock content %}

        <script src="/vendor/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="/js/common.js"></script>
        <script src="/vendor/tinymce/tinymce/tinymce.min.js"></script>
        <script src="/js/tinymce-init.js"></script>
        {% block scripts %}
        {% endblock scripts %}
    </body>
</html>
