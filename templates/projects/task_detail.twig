{% extends "layout.twig" %}

{% block title %}
    Aufgabe: {{ task.name }} - {{ app_settings.app_name|default("Chor-Manager") }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">
                <a href="/projects/{{ project.id }}/tasks"
                   class="text-decoration-none text-muted"><i class="bi bi-arrow-left"></i> Planung ({{ project.name }})</a>
            </p>
            <h1 class="h2 mb-1">{{ task.name }}</h1>
            <p class="text-muted mb-0">
                Erstellt von {{ task.createdBy.first_name }} {{ task.createdBy.last_name }} am {{ task.created_at|date("d.m.Y") }}
            </p>
        </div>
        <div class="page-actions">
            <button type="button"
                    class="btn btn-outline-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#editTaskModal">
                <i class="bi bi-pencil"></i> Bearbeiten
            </button>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    {% if success %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ success }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}
    {% if error %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ error }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}

    <div class="row">
        <div class="col-lg-8">
            <!-- Main Details -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <div class="mb-4">
                        <h6 class="text-muted text-uppercase small fw-bold mb-2">Beschreibung</h6>
                        <div class="p-3 bg-light rounded-3 task-description-html">
                            {% if task.description %}
                                {{ task.description|raw }}
                            {% else %}
                                <span class="text-muted fst-italic">Keine Beschreibung angegeben.</span>
                            {% endif %}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-6 mb-3">
                            <span class="text-muted small d-block mb-1">Status</span>
                            {% if task.status == 'Abgeschlossen' %}
                                <span class="badge bg-success fs-6"><i class="bi bi-check-circle"></i> Erledigt</span>
                            {% elseif task.status == 'In Bearbeitung' %}
                                <span class="badge bg-info text-dark fs-6"><i class="bi bi-arrow-repeat"></i> In Arbeit</span>
                            {% else %}
                                <span class="badge bg-secondary bg-opacity-75 fs-6"><i class="bi bi-circle"></i> Offen</span>
                            {% endif %}
                        </div>
                        <div class="col-sm-6 mb-3">
                            <span class="text-muted small d-block mb-1">Priorität</span>
                            {% if task.priority == 'Niedrig' %}
                                <span class="badge bg-secondary fs-6">Niedrig</span>
                            {% elseif task.priority == 'Mittel' %}
                                <span class="badge bg-primary fs-6">Mittel</span>
                            {% elseif task.priority == 'Hoch' %}
                                <span class="badge bg-danger fs-6">Hoch</span>
                            {% endif %}
                        </div>
                        <div class="col-sm-6 mb-3">
                            <span class="text-muted small d-block mb-1">Zugewiesen an</span>
                            {% if task.assignee %}
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-person-circle fs-4 text-primary me-2"></i>
                                    <span>{{ task.assignee.first_name }} {{ task.assignee.last_name }}</span>
                                </div>
                            {% else %}
                                <span class="text-muted fst-italic">Nicht zugewiesen</span>
                            {% endif %}
                        </div>
                        <div class="col-sm-6 mb-3">
                            <span class="text-muted small d-block mb-1">Zeitraum</span>
                            {% if task.start_date or task.end_date %}
                                <i class="bi bi-calendar-event text-secondary me-1"></i>
                                {{ task.start_date ? task.start_date|date("d.m.Y") : '?' }} — {{ task.end_date ? task.end_date|date("d.m.Y") : '?' }}
                            {% else %}
                                <span class="text-muted fst-italic">Ohne Datum</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Comments -->
            {{ include('partials/comments.twig', {
            comments: task.comments,
            submit_url: '/tasks/' ~ task.id ~ '/comments',
            }) }}

        </div>

        <div class="col-lg-4">
            <!-- Attachments -->
            {{ include('partials/attachments.twig', {
            attachments: task.attachments,
            upload_url: '/tasks/' ~ task.id ~ '/attachments',
            download_url: '/tasks/' ~ task.id ~ '/attachments',
            delete_url: '/tasks/' ~ task.id ~ '/attachments',
            }) }}

            <!-- Activity History -->
            {{ include('partials/history.twig', {
            activities: task.activities|reverse,
            }) }}

            <!-- Danger Zone -->
            <div class="card border-danger shadow-sm mb-4">
                <div class="card-header bg-danger text-white pb-2">
                    <h6 class="mb-0">
                        <i class="bi bi-exclamation-triangle me-2"></i>Gefahrenzone
                    </h6>
                </div>
                <div class="card-body">
                    <p class="small text-muted mb-3">
                        Wenn Sie diese Aufgabe löschen, werden alle zugehörigen Kommentare, Anhänge und Historien unwiderruflich entfernt.
                    </p>
                    <form action="/tasks/{{ task.id }}/delete"
                          method="post"
                          onsubmit="return confirm('Möchten Sie diese Aufgabe wirklich löschen? Dies kann nicht rückgängig gemacht werden.');">
                        <button type="submit" class="btn btn-outline-danger w-100">
                            <i class="bi bi-trash"></i> Aufgabe löschen
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Task Modal -->
    <div class="modal fade"
         id="editTaskModal"
         tabindex="-1"
         aria-labelledby="editTaskModalLabel"
         aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <form action="/tasks/{{ task.id }}/update"
                  method="post"
                  class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editTaskModalLabel">Aufgabe bearbeiten</h5>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="title" class="form-label">Titel der Aufgabe *</label>
                        <input type="text"
                               class="form-control"
                               id="title"
                               name="title"
                               value="{{ task.name }}"
                               required>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="assigned_user_id" class="form-label">Zugewiesen an (optional)</label>
                            <select class="form-select" id="assigned_user_id" name="assigned_user_id">
                                <option value="">-- Nicht zugewiesen --</option>
                                {% for u in projectUsers %}
                                    <option value="{{ u.id }}" {{ task.assigned_to == u.id ? 'selected' : '' }}>{{ u.first_name }} {{ u.last_name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="priority" class="form-label">Priorität</label>
                            <select class="form-select" id="priority" name="priority">
                                <option value="Niedrig" {{ task.priority == 'Niedrig' ? 'selected' : '' }}>Niedrig
                                </option>
                                <option value="Mittel" {{ task.priority == 'Mittel' ? 'selected' : '' }}>Mittel
                                </option>
                                <option value="Hoch" {{ task.priority == 'Hoch' ? 'selected' : '' }}>Hoch
                                </option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="status" class="form-label">Status</label>
                            <select class="form-select" id="status" name="status">
                                <option value="Offen" {{ task.status == 'Offen' ? 'selected' : '' }}>Offen
                                </option>
                                <option value="In Bearbeitung"
                                        {{ task.status == 'In Bearbeitung' ? 'selected' : '' }}>In Arbeit
                                </option>
                                <option value="Abgeschlossen"
                                        {{ task.status == 'Abgeschlossen' ? 'selected' : '' }}>Erledigt
                                </option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="start_date" class="form-label">Startdatum</label>
                            <input type="date"
                                   class="form-control"
                                   id="start_date"
                                   name="start_date"
                                   value="{{ task.start_date ? task.start_date|date("Y-m-d") : '' }}">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="due_date" class="form-label">Fälligkeitsdatum</label>
                            <input type="date"
                                   class="form-control"
                                   id="due_date"
                                   name="due_date"
                                   value="{{ task.end_date ? task.end_date|date("Y-m-d") : '' }}">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Beschreibung</label>
                        <textarea class="form-control tinymce-editor"
                                  id="description"
                                  name="description"
                                  rows="5">{{ task.description|raw }}</textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Änderungen Speichern</button>
                </div>
            </form>
        </div>
    </div>
{% endblock content %}
