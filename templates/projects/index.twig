{% extends 'layout.twig' %}

{% block title %}Projekte - Chor Manager{% endblock %}

{% block page_header %}
<section class="page-header">
    <div>
        <p class="text-uppercase text-muted small mb-1">Verwaltung</p>
        <h1 class="h2 mb-1">Projekte verwalten</h1>
        <p class="text-muted mb-0">Projektstammdaten und Mitgliederzuordnungen zentral pflegen.</p>
    </div>
    <div class="page-actions">
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addProjectModal">
            <i class="bi bi-folder-plus"></i> Neues Projekt
        </button>
    </div>
</section>
{% endblock %}

{% block content %}
{% if success %}
<div class="alert alert-success alert-dismissible fade show" role="alert">
    {{ success }}
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
{% endif %}
{% if error %}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    {{ error }}
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
{% endif %}

<div class="surface-card card border-0 table-shell" data-table-engine="true" data-table-id="projects.index" data-default-view="table">
    {% include 'partials/table_toolbar.twig' %}
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0 table-responsive-cards" id="projectsTable">
                <thead class="table-dark">
                    <tr>
                        <th>Projektname</th>
                        <th>Beschreibung</th>
                        <th>Startdatum</th>
                        <th>Enddatum</th>
                        <th class="text-end">Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    {% for project in projects %}
                    <tr>
                        <td data-label="Projektname"><strong>{{ project.name }}</strong></td>
                        <td data-label="Beschreibung">{{ project.description|default('-') }}</td>
                        <td data-label="Startdatum">{{ project.start_date|default('-') }}</td>
                        <td data-label="Enddatum">{{ project.end_date|default('-') }}</td>
                        <td data-label="Aktionen" class="text-end">
                            {% if session.can_manage_tasks or session.can_manage_master_data or session.can_manage_users or (project.id in userProjectIds) %}
                            <a href="/projects/{{ project.id }}/tasks" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-list-check"></i> Planung
                            </a>
                            {% endif %}
                            
                            {% if session.can_manage_project_members %}
                            <a href="/projects/{{ project.id }}/members" class="btn btn-sm btn-outline-primary ms-1">
                                <i class="bi bi-people"></i> Mitglieder
                            </a>
                            {% endif %}
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="{{ session.can_manage_project_members ? 5 : 4 }}" class="text-center py-4 text-muted">Bisher wurden keine Projekte angelegt.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Project Modal -->
<div class="modal fade" id="addProjectModal" tabindex="-1" aria-labelledby="addProjectModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <form action="/projects" method="post" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addProjectModalLabel">Projekt anlegen</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="name" class="form-label">Projektname *</label>
                    <input type="text" class="form-control" id="name" name="name" required>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Beschreibung</label>
                    <textarea class="form-control" id="description" name="description" rows="3"></textarea>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="start_date" class="form-label">Startdatum</label>
                        <input type="date" class="form-control" id="start_date" name="start_date">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="end_date" class="form-label">Enddatum</label>
                        <input type="date" class="form-control" id="end_date" name="end_date">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                <button type="submit" class="btn btn-primary">Speichern</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
