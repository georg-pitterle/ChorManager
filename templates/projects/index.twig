{% extends "layout.twig" %}

{% block title %}
    Projekte - {{ app_settings.app_name|default("Chor Manager") }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Verwaltung</p>
            <h1 class="h2 mb-1">Projekte verwalten</h1>
            <p class="text-muted mb-0">Projektstammdaten und Mitgliederzuordnungen zentral pflegen.</p>
        </div>
        <div class="page-actions">
            <button type="button"
                    class="btn btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#addProjectModal">
                <i class="bi bi-folder-plus"></i> Neues Projekt
            </button>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    {% if success %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ success }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}
    {% if error %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ error }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}

    <div class="surface-card card border-0 table-shell"
         data-table-engine="true"
         data-table-id="projects.index"
         data-default-view="auto"
         data-default-page-size="100"
         data-page-size-options="25,50,100,200"
         data-default-sort-key="start_date"
         data-default-sort-dir="desc">
        {{ include("partials/table_toolbar.twig") }}
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0 table-responsive-cards"
                       id="projectsTable">
                    <thead class="table-dark">
                        <tr>
                            <th data-sort-key="project_name" data-sort-type="text">Projektname</th>
                            <th data-sort-key="description" data-sort-type="text">Beschreibung</th>
                            <th data-sort-key="start_date" data-sort-type="date">Startdatum</th>
                            <th data-sort-key="end_date" data-sort-type="date">Enddatum</th>
                            <th class="text-end">Aktionen</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for project in projects %}
                            <tr data-sort-project_name="{{ project.name|lower }}"
                                data-sort-description="{{ project.description|default("")|lower }}"
                                data-sort-start_date="{{ project.start_date|default("") }}"
                                data-sort-end_date="{{ project.end_date|default("") }}">
                                <td data-label="Projektname">
                                    <strong>{{ project.name }}</strong>
                                </td>
                                <td data-label="Beschreibung">{{ project.description|default("-") }}</td>
                                <td data-label="Startdatum">{{ project.start_date|default("-") }}</td>
                                <td data-label="Enddatum">{{ project.end_date|default("-") }}</td>
                                <td data-label="Aktionen" class="text-end">
                                    <div class="dropdown">
                                        <button type="button"
                                                class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                                data-bs-toggle="dropdown"
                                                aria-expanded="false">Aktionen</button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li>
                                                <button type="button"
                                                        class="dropdown-item"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#editProjectModal{{ project.id }}">
                                                    <i class="bi bi-pencil me-2"></i>Bearbeiten
                                                </button>
                                            </li>

                                            {% if session.can_manage_tasks %}
                                                <li>
                                                    <a href="/projects/{{ project.id }}/tasks" class="dropdown-item">
                                                        <i class="bi bi-list-check me-2"></i>Planung
                                                    </a>
                                                </li>
                                            {% endif %}

                                            {% if session.can_manage_project_members %}
                                                <li>
                                                    <a href="/projects/{{ project.id }}/members" class="dropdown-item">
                                                        <i class="bi bi-people me-2"></i>Mitglieder
                                                    </a>
                                                </li>
                                            {% endif %}
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">Bisher wurden keine Projekte angelegt.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {% for project in projects %}
        <div class="modal fade"
             id="editProjectModal{{ project.id }}"
             tabindex="-1"
             aria-labelledby="editProjectModalLabel{{ project.id }}"
             aria-hidden="true">
            <div class="modal-dialog">
                <form action="/projects/{{ project.id }}/update"
                      method="post"
                      class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="editProjectModalLabel{{ project.id }}">Projekt bearbeiten</h5>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="edit_name_{{ project.id }}" class="form-label">Projektname *</label>
                            <input type="text"
                                   class="form-control"
                                   id="edit_name_{{ project.id }}"
                                   name="name"
                                   value="{{ project.name }}"
                                   required>
                        </div>
                        <div class="mb-3">
                            <label for="edit_description_{{ project.id }}" class="form-label">Beschreibung</label>
                            <textarea class="form-control"
                                      id="edit_description_{{ project.id }}"
                                      name="description"
                                      rows="3">{{ project.description|default('') }}</textarea>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="edit_start_date_{{ project.id }}" class="form-label">Startdatum</label>
                                <input type="date"
                                       class="form-control"
                                       id="edit_start_date_{{ project.id }}"
                                       name="start_date"
                                       value="{{ project.start_date|default('') }}">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="edit_end_date_{{ project.id }}" class="form-label">Enddatum</label>
                                <input type="date"
                                       class="form-control"
                                       id="edit_end_date_{{ project.id }}"
                                       name="end_date"
                                       value="{{ project.end_date|default('') }}">
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                        <button type="submit" class="btn btn-primary">Änderungen speichern</button>
                    </div>
                </form>
            </div>
        </div>
    {% endfor %}

    <!-- Add Project Modal -->
    <div class="modal fade"
         id="addProjectModal"
         tabindex="-1"
         aria-labelledby="addProjectModalLabel"
         aria-hidden="true">
        <div class="modal-dialog">
            <form action="/projects" method="post" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addProjectModalLabel">Projekt anlegen</h5>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="name" class="form-label">Projektname *</label>
                        <input type="text" class="form-control" id="name" name="name" required>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Beschreibung</label>
                        <textarea class="form-control" id="description" name="description" rows="3"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="start_date" class="form-label">Startdatum</label>
                            <input type="date" class="form-control" id="start_date" name="start_date">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="end_date" class="form-label">Enddatum</label>
                            <input type="date" class="form-control" id="end_date" name="end_date">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Speichern</button>
                </div>
            </form>
        </div>
    </div>
{% endblock content %}
