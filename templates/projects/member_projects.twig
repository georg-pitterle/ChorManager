{% extends "layout.twig" %}

{% block title %}
    Meine Projekte - {{ app_settings.app_name|default("Chor-Manager") }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Bereiche</p>
            <h1 class="h2 mb-1">Meine Projekte</h1>
            <p class="text-muted mb-0">Projekte, deren Mitglieder du verwalten kannst.</p>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    {% if projects is empty %}
        <div class="alert alert-info">Du bist keinem Projekt zugeordnet.</div>
    {% else %}
        <div class="list-group">
            {% for project in projects %}
                <a href="/projects/{{ project.id }}/members" class="list-group-item list-group-item-action">
                    <div class="d-flex w-100 justify-content-between">
                        <h5 class="mb-1">{{ project.name }}</h5>
                        {% if project.start_date %}
                            <small class="text-muted">{{ project.start_date|date("d.m.Y") }}</small>
                        {% endif %}
                    </div>
                    {% if project.description %}
                        <p class="mb-1 text-muted">{{ project.description }}</p>
                    {% endif %}
                </a>
            {% endfor %}
        </div>
    {% endif %}
{% endblock content %}
