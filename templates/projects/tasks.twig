{% extends "layout.twig" %}

{% block title %}
    Aufgaben - {{ project.name }} - Chor Manager
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">
                <a href="/projects" class="text-decoration-none text-muted"><i class="bi bi-arrow-left"></i> Projekte</a> / {{ project.name }}
            </p>
            <h1 class="h2 mb-1">Projektplanung (Aufgaben)</h1>
            <p class="text-muted mb-0">Zuweisungen und Statusberichte für das Projekt.</p>
        </div>
        <div class="page-actions">
            <button type="button"
                    class="btn btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#addTaskModal">
                <i class="bi bi-plus-lg"></i> Neue Aufgabe
            </button>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    {% if success %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ success }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}
    {% if error %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ error }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}

    <div class="surface-card card border-0 table-shell"
         data-table-engine="true"
         data-table-id="tasks.index"
         data-default-view="auto"
         data-default-page-size="100"
         data-page-size-options="25,50,100,200"
         data-default-sort-key="due_date">
        {{ include("partials/table_toolbar.twig") }}
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0 table-responsive-cards"
                       id="tasksTable">
                    <thead class="table-dark">
                        <tr>
                            <th data-sort-key="task_title" data-sort-type="text">Titel</th>
                            <th data-sort-key="assignee_name" data-sort-type="text">Verantwortlich</th>
                            <th data-sort-key="due_date" data-sort-type="date">Fällig am</th>
                            <th>Priorität</th>
                            <th data-sort-key="task_status" data-sort-type="text">Status</th>
                            <th class="text-end">Aktionen</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for task in tasks %}
                            <tr data-sort-task_title="{{ task.name|lower }}"
                                data-sort-assignee_name="{{ task.assignee ? (task.assignee.first_name ~ ' ' ~ task.assignee.last_name)|lower : '' }}"
                                data-sort-due_date="{{ task.end_date ? task.end_date|date("Y-m-d") : '9999-12-31' }}"
                                data-sort-task_status="{{ task.status|lower }}">
                                <td data-label="Titel">
                                    <strong>{{ task.name }}</strong>
                                    {% if task.comments_count > 0 %}
                                        <span class="badge bg-light text-dark ms-2"
                                              title="{{ task.comments_count }} Kommentare"><i class="bi bi-chat"></i> {{ task.comments_count }}</span>
                                    {% endif %}
                                </td>
                                <td data-label="Verantwortlich">
                                    {% if task.assignee %}
                                        {{ task.assignee.first_name }} {{ task.assignee.last_name }}
                                    {% else %}
                                        <span class="text-muted fst-italic">Nicht zugewiesen</span>
                                    {% endif %}
                                </td>
                                <td data-label="Fällig am">
                                    {% if task.end_date %}
                                        {% set due = task.end_date|date('Y-m-d') %}
                                        {% set today = 'now'|date('Y-m-d') %}
                                        <span class="{{ due < today and task.status != 'Abgeschlossen' ? 'text-danger fw-bold' : '' }}">
                                            {{ task.end_date|date("d.m.Y") }}
                                        </span>
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                                <td data-label="Priorität">
                                    {% if task.priority == 'Niedrig' %}
                                        <span class="badge bg-secondary">Niedrig</span>
                                    {% elseif task.priority == 'Mittel' %}
                                        <span class="badge bg-primary">Mittel</span>
                                    {% elseif task.priority == 'Hoch' %}
                                        <span class="badge bg-danger">Hoch</span>
                                    {% endif %}
                                </td>
                                <td data-label="Status">
                                    {% if task.status == 'Abgeschlossen' %}
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Erledigt</span>
                                    {% elseif task.status == 'In Bearbeitung' %}
                                        <span class="badge bg-info text-dark"><i class="bi bi-arrow-repeat"></i> In Arbeit</span>
                                    {% else %}
                                        <span class="badge bg-secondary bg-opacity-75"><i class="bi bi-circle"></i> Offen</span>
                                    {% endif %}
                                </td>
                                <td data-label="Aktionen" class="text-end">
                                    <a href="/tasks/{{ task.id }}" class="btn btn-sm btn-outline-primary">
                                        Details <i class="bi bi-chevron-right"></i>
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">Bisher wurden keine Aufgaben für dieses Projekt angelegt.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Add Task Modal -->
    <div class="modal fade"
         id="addTaskModal"
         tabindex="-1"
         aria-labelledby="addTaskModalLabel"
         aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <form action="/projects/{{ project.id }}/tasks"
                  method="post"
                  class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addTaskModalLabel">Neue Aufgabe anlegen</h5>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="title" class="form-label">Titel der Aufgabe *</label>
                        <input type="text" class="form-control" id="title" name="title" required>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="assigned_user_id" class="form-label">Zugewiesen an (optional)</label>
                            <select class="form-select" id="assigned_user_id" name="assigned_user_id">
                                <option value="">-- Nicht zugewiesen --</option>
                                {% for u in projectUsers %}<option value="{{ u.id }}">{{ u.first_name }} {{ u.last_name }}</option>{% endfor %}
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="priority" class="form-label">Priorität</label>
                            <select class="form-select" id="priority" name="priority">
                                <option value="Niedrig">Niedrig</option>
                                <option value="Mittel" selected>Mittel</option>
                                <option value="Hoch">Hoch</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="status" class="form-label">Status</label>
                            <select class="form-select" id="status" name="status">
                                <option value="Offen" selected>Offen</option>
                                <option value="In Bearbeitung">In Arbeit</option>
                                <option value="Abgeschlossen">Erledigt</option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="start_date" class="form-label">Startdatum</label>
                            <input type="date" class="form-control" id="start_date" name="start_date">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="due_date" class="form-label">Fälligkeitsdatum</label>
                            <input type="date" class="form-control" id="due_date" name="due_date">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Beschreibung</label>
                        <textarea class="form-control tinymce-editor" id="description" name="description" rows="4"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Aufgabe Speichern</button>
                </div>
            </form>
        </div>
    </div>
{% endblock content %}
