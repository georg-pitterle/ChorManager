<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white pb-0 border-bottom-0">
        <h5 class="mb-0">
            <i class="bi bi-paperclip text-info me-2"></i>Anhänge
        </h5>
    </div>
    <div class="card-body">
        {% if attachments|length > 0 %}
            <ul class="list-group list-group-flush mb-3">
                {% for attachment in attachments %}
                    <li class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-file-earmark-text text-muted fs-4 me-3"></i>
                            <div>
                                <a href="{{ download_url }}/{{ attachment.id }}/download"
                                   class="text-decoration-none fw-medium text-dark">{{ attachment.original_name }}</a>
                                <div class="text-muted small">
                                    {{ attachment.file_size ? (attachment.file_size / 1024)|round(1) ~ ' KB' : '?' }} • {{ attachment.created_at|date("d.m.Y") }}
                                </div>
                            </div>
                        </div>
                        <div>
                            <form action="{{ delete_url }}/{{ attachment.id }}/delete"
                                  method="post"
                                  class="d-inline"
                                  data-confirm="Möchten Sie diesen Anhang wirklich löschen?">
                                <button type="submit"
                                        class="btn btn-sm btn-link text-danger p-0"
                                        title="Löschen">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p class="text-muted small mb-3">Noch keine Anhänge vorhanden.</p>
        {% endif %}

        <form action="{{ upload_url }}"
              method="post"
              enctype="multipart/form-data"
              class="bg-light p-3 rounded-3"
              id="attachments-form">
            <label class="form-label small fw-bold mb-1">Neue Dateien hochladen</label>
            <div class="input-group input-group-sm">
                <input type="file"
                       class="form-control"
                       name="attachments[]"
                       multiple
                       required>
                <button class="btn btn-outline-primary" type="submit">
                    <i class="bi bi-upload"></i> Hochladen
                </button>
            </div>
        </form>

        <script>
          document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('attachments-form');
            if (form && window.uploadHelper) {
              window.uploadHelper.setupFormCompression(form);
            }
          });
        </script>
    </div>
</div>
