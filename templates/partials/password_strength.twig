<ul id="passwordStrengthList"
    class="list-unstyled small mt-2 mb-0"
    aria-live="polite">
    <li data-rule="length" class="text-danger">
        <i class="bi bi-x-circle-fill me-1" aria-hidden="true"></i>Mindestens 12 Zeichen
    </li>
    <li data-rule="upper" class="text-danger">
        <i class="bi bi-x-circle-fill me-1" aria-hidden="true"></i>Mindestens ein Großbuchstabe
    </li>
    <li data-rule="lower" class="text-danger">
        <i class="bi bi-x-circle-fill me-1" aria-hidden="true"></i>Mindestens ein Kleinbuchstabe
    </li>
    <li data-rule="digit" class="text-danger">
        <i class="bi bi-x-circle-fill me-1" aria-hidden="true"></i>Mindestens eine Zahl
    </li>
    <li data-rule="special" class="text-danger">
        <i class="bi bi-x-circle-fill me-1" aria-hidden="true"></i>Mindestens ein Sonderzeichen
    </li>
</ul>
