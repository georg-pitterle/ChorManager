<ul id="passwordStrengthList" class="list-unstyled small mt-2 mb-0" aria-live="polite">
    <li data-rule="length" class="text-danger">
        <i class="bi bi-x-circle-fill me-1" aria-hidden="true"></i>Mindestens 12 Zeichen
    </li>
    <li data-rule="upper" class="text-danger">
        <i class="bi bi-x-circle-fill me-1" aria-hidden="true"></i>Mindestens ein Großbuchstabe
    </li>
    <li data-rule="lower" class="text-danger">
        <i class="bi bi-x-circle-fill me-1" aria-hidden="true"></i>Mindestens ein Kleinbuchstabe
    </li>
    <li data-rule="digit" class="text-danger">
        <i class="bi bi-x-circle-fill me-1" aria-hidden="true"></i>Mindestens eine Zahl
    </li>
    <li data-rule="special" class="text-danger">
        <i class="bi bi-x-circle-fill me-1" aria-hidden="true"></i>Mindestens ein Sonderzeichen
    </li>
</ul>
<script>
(function () {
    var input = document.getElementById("passwordInput");
    if (!input) { return; }
    var rules = {
        length:  function (v) { return v.length >= 12; },
        upper:   function (v) { return /[A-Z]/.test(v); },
        lower:   function (v) { return /[a-z]/.test(v); },
        digit:   function (v) { return /[0-9]/.test(v); },
        special: function (v) { return /[^A-Za-z0-9]/.test(v); }
    };
    var icons = {
        ok:  "bi-check-circle-fill",
        err: "bi-x-circle-fill"
    };
    function update() {
        var val = input.value;
        Object.keys(rules).forEach(function (key) {
            var li = document.querySelector("#passwordStrengthList [data-rule=\"" + key + "\"]");
            if (!li) { return; }
            var ok = rules[key](val);
            var icon = li.querySelector("i");
            if (icon) {
                icon.classList.toggle(icons.ok, ok);
                icon.classList.toggle(icons.err, !ok);
            }
            li.classList.toggle("text-success", ok);
            li.classList.toggle("text-danger", !ok);
        });
    }
    input.addEventListener("input", update);
}());
</script>