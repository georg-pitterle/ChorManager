<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white pb-0 border-bottom-0">
        <h5 class="mb-0">
            <i class="bi bi-chat-text text-primary me-2"></i>Kommentare
        </h5>
    </div>
    <div class="card-body">
        <div class="comments-list mb-3">
            {% for comment in comments %}
                <div class="d-flex mb-3">
                    <div class="flex-shrink-0">
                        <div class="bg-light rounded-circle p-2 text-primary avatar-circle">
                            {{ comment.user.first_name|first }}{{ comment.user.last_name|first }}
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <div class="bg-light p-3 rounded-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <strong>{{ comment.user.first_name }} {{ comment.user.last_name }}</strong>
                                <small class="text-muted">{{ comment.created_at|date('d.m.Y H:i') }}</small>
                            </div>
                            <p class="mb-0">{{ comment.comment|nl2br }}</p>
                        </div>
                    </div>
                </div>
            {% else %}
                <p class="text-muted small">Noch keine Kommentare vorhanden.</p>
            {% endfor %}
        </div>

        <form action="{{ submit_url }}" method="post">
            <div class="mb-3">
                <label for="commentContent" class="visually-hidden">Neuer Kommentar</label>
                <textarea class="form-control"
                          id="commentContent"
                          name="content"
                          rows="2"
                          placeholder="Schreibe einen Kommentar..."
                          required></textarea>
            </div>
            <div class="text-end">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-send"></i> Senden
                </button>
            </div>
        </form>
    </div>
</div>
