{% if can_show_admin %}
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle {% if is_admin_active %}active{% endif %}"
           href="#"
           data-bs-toggle="dropdown"
           aria-expanded="false"><i class="bi bi-gear-fill me-1"></i> Verwaltung</a>
        <ul class="dropdown-menu">
            {% if session.can_manage_master_data or session.can_manage_users %}
                <li>
                    <a class="dropdown-item {% if nav_active(path, nav, ['/projects'], ['projects']) %}active{% endif %}"
                       href="/projects"><i class="bi bi-folder-fill me-2"></i> Projekte</a>
                </li>
                <li>
                    <a class="dropdown-item {% if nav_active(path, nav, ['/roles'], ['roles']) %}active{% endif %}"
                       href="/roles"><i class="bi bi-shield-lock-fill me-2"></i> Rollen</a>
                </li>
                <li>
                    <a class="dropdown-item {% if nav_active(path, nav, ['/voice-groups'], ['voice_groups']) %}active{% endif %}"
                       href="/voice-groups"><i class="bi bi-music-note-beamed me-2"></i> Stimmgruppen</a>
                </li>
                <li>
                    <a class="dropdown-item {% if nav_active(path, nav, ['/event-types'], ['event_types']) %}active{% endif %}"
                       href="/event-types"><i class="bi bi-tag me-2"></i> Event-Typen</a>
                </li>
                <li>
                    <hr class="dropdown-divider">
                </li>
                <li>
                    <a class="dropdown-item {% if nav_active(path, nav, ['/settings'], ['settings']) %}active{% endif %}"
                       href="/settings"><i class="bi bi-sliders me-2"></i> App-Einstellungen</a>
                </li>
            {% endif %}
        </ul>
    </li>
{% endif %}
