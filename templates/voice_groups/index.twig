{% extends 'layout.twig' %}

{% import 'macros/modal_form.twig' as modal %}

{% block title %}
    Stimmgruppen - {{ app_settings.app_name|default('Chor-Manager') }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Verwaltung</p>
            <h1 class="h2 mb-1">Stimmgruppen verwalten</h1>
            <p class="text-muted mb-0">Stimmgruppen und Unterstimmen konsistent organisieren.</p>
        </div>
        <div class="page-actions">
            <button class="btn btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#createGroupModal">
                <i class="bi bi-plus-lg"></i> Stimmgruppe hinzufügen
            </button>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    {% if success %}<div class="alert alert-success mt-3">{{ success }}</div>{% endif %}
    {% if error and not has_modal_error %}
        <div class="alert alert-danger mt-3">{{ error }}</div>
    {% endif %}

    <section class="surface-card form-surface p-4 mb-4">
        <div class="row row-cols-1 row-cols-md-2 g-4">
            {% for group in voice_groups %}
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-header bg-white d-flex justify-content-between align-items-center">
                            <h5 class="mb-0 fw-bold">{{ group.name }}</h5>
                            <div>
                                <button class="btn btn-sm btn-outline-secondary"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editGroupModal{{ group.id }}"
                                        title="Bearbeiten">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteGroupModal{{ group.id }}"
                                        title="Löschen">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                        <div class="card-body">
                            <p class="text-muted small mb-3">Unterstimmen:</p>
                            <div class="d-flex flex-column gap-2">
                                {% for sub_voice in group.subVoices %}
                                    <div class="d-flex justify-content-between align-items-center bg-light p-2 rounded">
                                        <span>{{ sub_voice.name }}</span>
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-link text-secondary p-0 px-2"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#editSubVoiceModal{{ sub_voice.id }}"
                                                    title="Bearbeiten">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-link text-danger p-0 px-2"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#deleteSubVoiceModal{{ sub_voice.id }}"
                                                    title="Löschen">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <!-- Edit SubVoice Modal -->
                                    <div class="modal fade"
                                         id="editSubVoiceModal{{ sub_voice.id }}"
                         data-open-edit-sub-modal="{{ modal_form_edit_subs[sub_voice.id].open_modal ? '1' : '0' }}"
                         tabindex="-1"
                         aria-hidden="true">
                        <div class="modal-dialog">
                            <form method="post"
                                  action="/voice-groups/{{ group.id }}/sub/{{ sub_voice.id }}/update">
                                <div class="modal-content border-0 shadow">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Unterstimme bearbeiten</h5>
                                        <button type="button"
                                                class="btn-close"
                                                data-bs-dismiss="modal"
                                                aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        {{ modal.show_modal_error(error, modal_form_edit_subs[sub_voice.id].error, 'voice_sub_edit_' ~ sub_voice.id) }}

                                        <div class="mb-3">
                                            <label class="form-label">Name</label>
                                            {% set edit_sub_form = modal_form_edit_subs[sub_voice.id].form|default({}) %}
                                            <input type="text"
                                                   name="name"
                                                   class="form-control"
                                                   value="{{ edit_sub_form.name|default(sub_voice.name) }}"
                                                    <div class="modal-footer pb-0 border-0">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                                                        <button type="submit" class="btn btn-primary">Speichern</button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>

                                    <!-- Delete SubVoice Modal -->
                                    <div class="modal fade"
                                         id="deleteSubVoiceModal{{ sub_voice.id }}"
                                         tabindex="-1"
                                         aria-hidden="true">
                                        <div class="modal-dialog">
                                            <form method="post"
                                                  action="/voice-groups/{{ group.id }}/sub/{{ sub_voice.id }}/delete">
                                                <div class="modal-content border-0 shadow">
                                                    <div class="modal-header bg-danger text-white">
                                                        <h5 class="modal-title">Unterstimme löschen</h5>
                                                        <button type="button"
                                                                class="btn-close btn-close-white"
                                                                data-bs-dismiss="modal"
                                                                aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        Möchtest du die Unterstimme <strong>{{ sub_voice.name }}</strong> wirklich löschen? Dieser Vorgang entfernt die Zuweisung bei allen betroffenen Mitgliedern!
                                                    </div>
                                                    <div class="modal-footer border-0">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                                                        <button type="submit" class="btn btn-danger">Löschen</button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>

                                {% else %}
                                    <div class="text-muted small">Keine Unterstimmen vorhanden.</div>
                                {% endfor %}
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 text-center pb-3 pt-0">
                            <button class="btn btn-sm btn-outline-primary"
                                    data-bs-toggle="modal"
                                    data-bs-target="#createSubVoiceModal{{ group.id }}">
                                <i class="bi bi-plus"></i> Unterstimme hinzufügen
                            </button>
                        </div>
                    </div>

                    <!-- Edit Group Modal -->
                    <div class="modal fade"
                         id="editGroupModal{{ group.id }}"
                         data-open-edit-group-modal="{{ modal_form_edit_groups[group.id].open_modal ? '1' : '0' }}"
                         tabindex="-1"
                         aria-hidden="true">
                        <div class="modal-dialog">
                            <form method="post" action="/voice-groups/{{ group.id }}/update">
                                <div class="modal-content border-0 shadow">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Stimmgruppe bearbeiten</h5>
                                        <button type="button"
                                                class="btn-close"
                                                data-bs-dismiss="modal"
                                                aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        {{ modal.show_modal_error(error, modal_form_edit_groups[group.id].error, 'voice_group_edit_' ~ group.id) }}

                                        <div class="mb-3">
                                            <label class="form-label">Name</label>
                                            {% set edit_group_form = modal_form_edit_groups[group.id].form|default({}) %}
                                            <input type="text"
                                                   name="name"
                                                   class="form-control"
                                                   value="{{ edit_group_form.name|default(group.name) }}"
                                                   required>
                                        </div>
                                    </div>
                                    <div class="modal-footer pb-0 border-0">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                                        <button type="submit" class="btn btn-primary">Speichern</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Delete Group Modal -->
                    <div class="modal fade"
                         id="deleteGroupModal{{ group.id }}"
                         tabindex="-1"
                         aria-hidden="true">
                        <div class="modal-dialog">
                            <form method="post" action="/voice-groups/{{ group.id }}/delete">
                                <div class="modal-content border-0 shadow">
                                    <div class="modal-header bg-danger text-white">
                                        <h5 class="modal-title">Stimmgruppe löschen</h5>
                                        <button type="button"
                                                class="btn-close btn-close-white"
                                                data-bs-dismiss="modal"
                                                aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        Möchtest du die Stimmgruppe <strong>{{ group.name }}</strong> (sowie alle zugehörigen Unterstimmen) wirklich löschen? Dieser Vorgang kann nicht rückgängig gemacht werden!
                                    </div>
                                    <div class="modal-footer border-0">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                                        <button type="submit" class="btn btn-danger">Löschen</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Create SubVoice Modal -->
                    <div class="modal fade"
                         id="createSubVoiceModal{{ group.id }}"
                         data-open-create-sub-modal="{{ modal_form_create_subs[group.id].open_modal ? '1' : '0' }}"
                         tabindex="-1"
                         aria-hidden="true">
                        <div class="modal-dialog">
                            <form method="post" action="/voice-groups/{{ group.id }}/sub">
                                <div class="modal-content border-0 shadow">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Neue Unterstimme in {{ group.name }}</h5>
                                        <button type="button"
                                                class="btn-close"
                                                data-bs-dismiss="modal"
                                                aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        {{ modal.show_modal_error(error, modal_form_create_subs[group.id].error, 'voice_sub_create_' ~ group.id) }}

                                        <div class="mb-3">
                                            <label class="form-label">Name der Unterstimme (z.B. Sopran 1)</label>
                                            {% set create_sub_form = modal_form_create_subs[group.id].form|default({}) %}
                                            <input type="text"
                                                   name="name"
                                                   class="form-control"
                                                   value="{{ create_sub_form.name|default('') }}"
                                                   required>
                                        </div>
                                    </div>
                                    <div class="modal-footer pb-0 border-0">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                                        <button type="submit" class="btn btn-primary">Anlegen</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </section>

    <!-- Create Group Modal -->
    <div class="modal fade"
         id="createGroupModal"
         data-open-create-group-modal="{{ modal_form_create_group.open_modal ? '1' : '0' }}"
         tabindex="-1"
         aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" action="/voice-groups">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header">
                        <h5 class="modal-title">Neue Stimmgruppe anlegen</h5>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        {{ modal.show_modal_error(error, modal_form_create_group.error, 'voice_group_create') }}

                        <div class="mb-3">
                            <label class="form-label">Name der Stimmgruppe (z.B. Tenor)</label>
                            <input type="text"
                                   name="name"
                                   class="form-control"
                                   value="{{ modal_form_create_group.form.name|default('') }}"
                                   required>
                        </div>
                    </div>
                    <div class="modal-footer pb-0 border-0">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                        <button type="submit" class="btn btn-primary">Anlegen</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

{% endblock content %}

{% block scripts %}
    {{ parent() }}
    <script src="/js/voice-groups.js"></script>
{% endblock scripts %}
