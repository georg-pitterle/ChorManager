{% extends "layout.twig" %}

{% block title %}
    Dashboard - {{ app_settings.app_name|default("Chor-Manager") }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Dashboard</p>
            <h1 class="h2 mb-1">Willkommen, {{ session.user_name|default("Mitglied") }}</h1>
            <p class="text-muted mb-0">Dein Arbeitsbereich für Termine, Aufgaben und Schnellzugriffe.</p>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    <div class="dashboard-shell">
        <section class="dashboard-section dashboard-section--actions"
                 aria-labelledby="dashboard-actions-title">
            <div class="dashboard-section-head">
                <h2 class="dashboard-section-title" id="dashboard-actions-title">Schnellzugriff</h2>
                <p class="dashboard-section-lead mb-0">
                    Die wichtigsten Bereiche für deinen Tagesablauf, direkt aus dem Dashboard heraus.
                </p>
            </div>

            <div class="dashboard-action-grid">
                {% if session.can_manage_attendance or session.can_manage_users %}
                    <article class="surface-card dashboard-panel dashboard-panel--action">
                        <div class="dashboard-panel__body">
                            <p class="dashboard-panel__eyebrow">Organisation</p>
                            <h3 class="dashboard-panel__title">
                                <i class="bi bi-person-check-fill"></i>
                                Anwesenheiten
                            </h3>
                            <p class="dashboard-panel__text">Erfasse die Anwesenheit der Mitglieder für geplante Termine.</p>
                        </div>
                        <a href="/attendance" class="btn btn-outline-primary">Anwesenheiten eintragen</a>
                    </article>
                {% endif %}

                {% set _finance_perm = session.can_read_finances or session.can_manage_users %}
                {% set _finance_panel_visible = settings.modules.finance and _finance_perm %}
                {% if _finance_panel_visible %}
                    <article class="surface-card dashboard-panel dashboard-panel--action">
                        <div class="dashboard-panel__body">
                            <p class="dashboard-panel__eyebrow">Finanzen</p>
                            <h3 class="dashboard-panel__title">
                                <i class="bi bi-bank"></i>
                                Kassa
                            </h3>
                            <p class="dashboard-panel__text">Gehe direkt zur Kassa und prüfe aktuelle Buchungen.</p>
                        </div>
                        <a href="/finances" class="btn btn-outline-warning">Zur Kassa</a>
                    </article>
                {% endif %}

                {% if session.can_manage_users %}
                    <article class="surface-card dashboard-panel dashboard-panel--action">
                        <div class="dashboard-panel__body">
                            <p class="dashboard-panel__eyebrow">Mitglieder</p>
                            <h3 class="dashboard-panel__title">
                                <i class="bi bi-people-fill"></i>
                                Mitgliederverwaltung
                            </h3>
                            <p class="dashboard-panel__text">Füge neue Mitglieder hinzu oder bearbeite Rollen und Stimmgruppen.</p>
                        </div>
                        <a href="/users" class="btn btn-outline-success">Mitglieder verwalten</a>
                    </article>

                    <article class="surface-card dashboard-panel dashboard-panel--action">
                        <div class="dashboard-panel__body">
                            <p class="dashboard-panel__eyebrow">Auswertung</p>
                            <h3 class="dashboard-panel__title">
                                <i class="bi bi-bar-chart-fill"></i>
                                Auswertungen
                            </h3>
                            <p class="dashboard-panel__text">Überprüfe die Anwesenheitsstatistiken des gesamten Chors pro Projekt.</p>
                        </div>
                        <a href="/evaluations" class="btn btn-outline-dark">Statistiken ansehen</a>
                    </article>
                {% endif %}

                {% if not (session.can_manage_attendance or _finance_panel_visible or session.can_manage_users) %}
                    <article class="surface-card dashboard-panel dashboard-panel--empty">
                        <div class="dashboard-panel__body">
                            <h3 class="dashboard-panel__title">Keine Schnellzugriffe verfügbar</h3>
                            <p class="dashboard-panel__text mb-0">
                                Für deinen aktuellen Berechtigungsumfang sind momentan keine direkten Bereiche hinterlegt.
                            </p>
                        </div>
                    </article>
                {% endif %}
            </div>
        </section>

        {% if session.can_manage_tasks %}
            <section class="dashboard-section dashboard-section--context"
                     aria-labelledby="dashboard-context-title">
                <div class="dashboard-section-head">
                    <h2 class="dashboard-section-title" id="dashboard-context-title">Projektkontext</h2>
                    <p class="dashboard-section-lead mb-0">Aktuelle und kommende Projekte mit direktem Einstieg in die Aufgabenplanung.</p>
                </div>

                <div class="dashboard-context-grid">
                    {% if session.can_manage_tasks and current_project %}
                        <article class="surface-card dashboard-panel dashboard-panel--context">
                            <div class="dashboard-panel__body">
                                <p class="dashboard-panel__eyebrow">Laufendes Projekt</p>
                                <h3 class="dashboard-panel__title">
                                    <i class="bi bi-list-check"></i>
                                    Aufgaben: {{ current_project.name }}
                                </h3>
                                <p class="dashboard-panel__text">Sieh dir die Aufgaben und Planungsübersicht für das aktuelle Projekt an.</p>
                            </div>
                            <a href="/projects/{{ current_project.id }}/tasks"
                               class="btn btn-outline-info">Zur Aufgabenübersicht</a>
                        </article>
                    {% endif %}

                    {% if session.can_manage_tasks and upcoming_project %}
                        <article class="surface-card dashboard-panel dashboard-panel--context">
                            <div class="dashboard-panel__body">
                                <p class="dashboard-panel__eyebrow">Kommendes Projekt</p>
                                <h3 class="dashboard-panel__title">
                                    <i class="bi bi-calendar2-week"></i>
                                    Aufgaben: {{ upcoming_project.name }}
                                </h3>
                                <p class="dashboard-panel__text">Bereite das nächste Projekt frühzeitig vor und plane Aufgaben im Team.</p>
                            </div>
                            <a href="/projects/{{ upcoming_project.id }}/tasks"
                               class="btn btn-outline-secondary">Zur Aufgabenübersicht</a>
                        </article>
                    {% endif %}

                    {% if session.can_manage_tasks and not current_project and not upcoming_project %}
                        <article class="surface-card dashboard-panel dashboard-panel--empty">
                            <div class="dashboard-panel__body">
                                <h3 class="dashboard-panel__title">Keine projektbezogenen Aufgabenbereiche verfügbar.</h3>
                                <p class="dashboard-panel__text mb-0">
                                    Lege ein neues Projekt an, um Aufgaben und Planungsinformationen hier anzuzeigen.
                                </p>
                            </div>
                        </article>
                    {% endif %}
                </div>
            </section>
        {% endif %}

        <section class="dashboard-section dashboard-section--communication"
                 aria-labelledby="dashboard-communication-title">
            <div class="dashboard-section-head">
                <h2 class="dashboard-section-title" id="dashboard-communication-title">Kommunikation</h2>
                <p class="dashboard-section-lead mb-0">Newsletter und Mailversand im Blick behalten, inklusive offener Dead-Letter.</p>
            </div>

            <div class="dashboard-communication-grid">
                {% if latest_sent_newsletter %}
                    <article class="surface-card dashboard-panel dashboard-panel--communication">
                        <div class="dashboard-panel__body">
                            <p class="dashboard-panel__eyebrow">Zuletzt versendeter Newsletter</p>
                            <h3 class="dashboard-panel__title">{{ latest_sent_newsletter.title }}</h3>
                            <p class="dashboard-panel__text">
                                Projekt: {{ latest_sent_newsletter.project.name|default("-") }}
                                {% if latest_sent_newsletter.sent_at %}
                                    <br>
                                    Gesendet am {{ latest_sent_newsletter.sent_at|date("d.m.Y H:i") }}
                                {% endif %}
                            </p>
                        </div>
                        <button type="button"
                                class="btn btn-outline-danger"
                                data-newsletter-modal-url="/newsletters/{{ latest_sent_newsletter.id }}/preview?modal=1"
                                data-newsletter-modal-title="Newsletter Vorschau">Newsletter ansehen</button>
                    </article>
                {% endif %}

                {% if dead_mail_count is not null %}
                    <article class="surface-card dashboard-panel {% if dead_mail_count > 0 %}dashboard-panel--critical{% else %}dashboard-panel--communication{% endif %}">
                        <div class="dashboard-panel__body">
                            <p class="dashboard-panel__eyebrow">Mail-Queue</p>
                            <h3 class="dashboard-panel__title">Mail-Queue</h3>
                            <p class="dashboard-panel__text">
                                {% if dead_mail_count > 0 %}
                                    <strong>{{ dead_mail_count }} Dead-Letter warten auf Bearbeitung.</strong>
                                {% else %}
                                    <strong>Keine Dead-Letter vorhanden.</strong>
                                {% endif %}
                            </p>
                            <p class="dashboard-panel__text mb-0">Direkter Einstieg in die Mailversand-Verwaltung.</p>
                        </div>
                        <a href="/admin/mail-queue"
                           class="btn {% if dead_mail_count > 0 %}btn-danger{% else %}btn-outline-success{% endif %}">
                            Mailversand öffnen
                        </a>
                    </article>
                {% endif %}

                {% if not latest_sent_newsletter and dead_mail_count is null %}
                    <article class="surface-card dashboard-panel dashboard-panel--empty">
                        <div class="dashboard-panel__body">
                            <h3 class="dashboard-panel__title">Aktuell stehen für dich keine Kommunikationskarten bereit.</h3>
                            <p class="dashboard-panel__text mb-0">
                                Sobald Newsletter-Rechte oder Mail-Queue-Zugriff verfügbar sind, erscheinen die Bereiche hier.
                            </p>
                        </div>
                    </article>
                {% endif %}
            </div>
        </section>
    </div>

    {% if settings.modules.newsletter %}
        <div class="modal fade"
             id="newsletterActionModal"
             tabindex="-1"
             aria-labelledby="newsletterActionModalLabel"
             aria-hidden="true">
            <div class="modal-dialog modal-xl modal-dialog-scrollable">
                <div class="modal-content border-0 shadow rounded-3">
                    <div class="modal-header">
                        <h5 class="modal-title" id="newsletterActionModalLabel">Newsletter</h5>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-2 p-md-3">
                        <div id="newsletterActionContent" class="container-fluid px-0"></div>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock content %}

{% block scripts %}
    {% if settings.modules.newsletter %}
        <script src="/js/newsletters.js"></script>
    {% endif %}
{% endblock scripts %}
