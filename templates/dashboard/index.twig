{% extends "layout.twig" %}

{% block title %}
    Dashboard - {{ app_settings.app_name|default("Chor-Manager") }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Dashboard</p>
            <h1 class="h2 mb-1">Willkommen, {{ session.user_name|default("Mitglied") }}</h1>
            <p class="text-muted mb-0">Dein Arbeitsbereich für Termine, Aufgaben und Schnellzugriffe.</p>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="surface-card card h-100 border-primary">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title text-primary">
                        <i class="bi bi-calendar-check-fill"></i> Nächste Probe
                    </h5>
                    <p class="card-text">Hier siehst du geplante Termine und kannst die Anwesenheit für berechtigte Stimmgruppen eintragen.</p>
                    <a href="/attendance" class="btn btn-outline-primary mt-auto">Zur Anwesenheitsliste</a>
                </div>
            </div>
        </div>

         {% if session.can_manage_finances %}
            <div class="col-md-4 mb-4">
                <div class="surface-card card h-100 border-warning">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-warning">
                            <i class="bi bi-bank"></i> Kassa
                        </h5>
                        <p class="card-text">Gehe direkt zur Kassa</p>
                        <a href="/finances" class="btn btn-outline-warning mt-auto">Zur Kassa</a>
                    </div>
                </div>
            </div>
        {% endif %}

        {% if session.can_manage_tasks and current_project %}
            <div class="col-md-4 mb-4">
                <div class="surface-card card h-100 border-warning">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-warning">
                            <i class="bi bi-list-check"></i> Aufgaben: {{ current_project.name }}
                        </h5>
                        <p class="card-text">Sieh dir die Aufgaben und Planungsübersicht für das aktuelle Projekt an.</p>
                        <a href="/projects/{{ current_project.id }}/tasks" class="btn btn-outline-warning mt-auto">Zur Aufgabenübersicht</a>
                    </div>
                </div>
            </div>
        {% endif %}

        {% if session.can_manage_tasks and upcoming_project %}
            <div class="col-md-4 mb-4">
                <div class="surface-card card h-100 border-secondary">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-secondary">
                            <i class="bi bi-list-check"></i> Aufgaben: {{ upcoming_project.name }}
                        </h5>
                        <p class="card-text">Kommendes Projekt – Planungsübersicht und Aufgaben bereits einsehen und vorbereiten.</p>
                        <a href="/projects/{{ upcoming_project.id }}/tasks" class="btn btn-outline-secondary mt-auto">Zur Aufgabenübersicht</a>
                    </div>
                </div>
            </div>
        {% endif %}

        {% if session.can_manage_users %}
            <div class="col-md-4 mb-4">
                <div class="surface-card card h-100 border-success">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-success">
                            <i class="bi bi-people-fill"></i> Mitgliederverwaltung
                        </h5>
                        <p class="card-text">Füge neue Mitglieder hinzu oder bearbeite Rollen und Stimmgruppen.</p>
                        <a href="/users" class="btn btn-outline-success mt-auto">Mitglieder verwalten</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="surface-card card h-100 border-info">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-info">
                            <i class="bi bi-bar-chart-fill"></i> Auswertungen
                        </h5>
                        <p class="card-text">Überprüfe die Anwesenheitsstatistiken des gesamten Chors pro Projekt.</p>
                        <a href="/evaluations" class="btn btn-outline-info mt-auto">Statistiken ansehen</a>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
{% endblock content %}
