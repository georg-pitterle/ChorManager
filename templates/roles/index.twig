{% extends "layout.twig" %}

{% block title %}
    Rollen verwalten - {{ app_settings.app_name|default("Chor-Manager") }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Verwaltung</p>
            <h1 class="h2 mb-1">Rollen verwalten</h1>
            <p class="text-muted mb-0">Berechtigungen und Hierarchien transparent steuern.</p>
        </div>
        <div class="page-actions">
            <button type="button"
                    class="btn btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#addRoleModal">
                <i class="bi bi-shield-plus"></i> Neue Rolle
            </button>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    {% if success %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ success }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}
    {% if error %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ error }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}

    <div class="dashboard-shell">
        <section class="dashboard-section dashboard-section--context"
                 aria-labelledby="roles-matrix-title">
            <div class="dashboard-section-head">
                <h2 class="dashboard-section-title" id="roles-matrix-title">Berechtigungsmatrix</h2>
                <p class="dashboard-section-lead mb-0">Rollen, Rechte und Hierarchiestufen im direkten Vergleich.</p>
            </div>

            <div class="surface-card card border-0 table-shell"
                 data-table-engine="true"
                 data-table-id="roles.index"
                 data-default-view="auto"
                 data-default-sort-key=""
                 data-default-page-size="100"
                 data-page-size-options="25,50,100,200">
                {{ include('partials/table_toolbar.twig') }}
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped mb-0 table-responsive-cards"
                               id="rolesTable">
                            <thead class="table-dark">
                                <tr>
                                    <th scope="col" class="text-nowrap">Berechtigung</th>
                                    {% for role in roles %}
                                        <th scope="col" class="text-nowrap">
                                            <div class="fw-semibold text-center align-middle">{{ role.name }}</div>
                                            <small class="text-body-secondary d-block text-center">Level {{ role.hierarchy_level }}</small>
                                        </th>
                                    {% else %}
                                        <th scope="col">Rollen</th>
                                    {% endfor %}
                                </tr>
                            </thead>
                            <tbody>
                                {% if roles is not empty %}
                                    <tr>
                                        <th scope="row">Admin-Rechte</th>
                                        {% for role in roles %}
                                            <td data-label="{{ role.name }}" class="text-center align-middle">
                                                {% if role.can_manage_users %}
                                                    <span class="badge rounded-pill bg-success" aria-label="Ja" title="Ja"><i class="bi bi-check-lg text-white"></i></span>
                                                {% else %}
                                                    <span class="badge rounded-pill bg-danger" aria-label="Nein" title="Nein"><i class="bi bi-x-lg text-white"></i></span>
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                    <tr>
                                        <th scope="row">Edit-Rechte</th>
                                        {% for role in roles %}
                                            <td data-label="{{ role.name }}" class="text-center align-middle">
                                                {% if role.can_edit_users %}
                                                    <span class="badge rounded-pill bg-success" aria-label="Ja" title="Ja"><i class="bi bi-check-lg text-white"></i></span>
                                                {% else %}
                                                    <span class="badge rounded-pill bg-danger" aria-label="Nein" title="Nein"><i class="bi bi-x-lg text-white"></i></span>
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                    <tr>
                                        <th scope="row">Anwesenheit</th>
                                        {% for role in roles %}
                                            <td data-label="{{ role.name }}" class="text-center align-middle">
                                                {% if role.can_manage_attendance %}
                                                    <span class="badge rounded-pill bg-success" aria-label="Ja" title="Ja"><i class="bi bi-check-lg text-white"></i></span>
                                                {% else %}
                                                    <span class="badge rounded-pill bg-danger" aria-label="Nein" title="Nein"><i class="bi bi-x-lg text-white"></i></span>
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                    <tr>
                                        <th scope="row">Projektmitglieder</th>
                                        {% for role in roles %}
                                            <td data-label="{{ role.name }}" class="text-center align-middle">
                                                {% if role.can_manage_project_members %}
                                                    <span class="badge rounded-pill bg-success" aria-label="Ja" title="Ja"><i class="bi bi-check-lg text-white"></i></span>
                                                {% else %}
                                                    <span class="badge rounded-pill bg-danger" aria-label="Nein" title="Nein"><i class="bi bi-x-lg text-white"></i></span>
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                    <tr>
                                        <th scope="row">Stammdaten</th>
                                        {% for role in roles %}
                                            <td data-label="{{ role.name }}" class="text-center align-middle">
                                                {% if role.can_manage_master_data %}
                                                    <span class="badge rounded-pill bg-success" aria-label="Ja" title="Ja"><i class="bi bi-check-lg text-white"></i></span>
                                                {% else %}
                                                    <span class="badge rounded-pill bg-danger" aria-label="Nein" title="Nein"><i class="bi bi-x-lg text-white"></i></span>
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                    <tr>
                                        <th scope="row">Finanzen nur lesen</th>
                                        {% for role in roles %}
                                            <td data-label="{{ role.name }}" class="text-center align-middle">
                                                {% if role.can_read_finances %}
                                                    <span class="badge rounded-pill bg-success" aria-label="Ja" title="Ja"><i class="bi bi-check-lg text-white"></i></span>
                                                {% else %}
                                                    <span class="badge rounded-pill bg-danger" aria-label="Nein" title="Nein"><i class="bi bi-x-lg text-white"></i></span>
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                    <tr>
                                        <th scope="row">Finanzen lesen und schreiben</th>
                                        {% for role in roles %}
                                            <td data-label="{{ role.name }}" class="text-center align-middle">
                                                {% if role.can_manage_finances %}
                                                    <span class="badge rounded-pill bg-success" aria-label="Ja" title="Ja"><i class="bi bi-check-lg text-white"></i></span>
                                                {% else %}
                                                    <span class="badge rounded-pill bg-danger" aria-label="Nein" title="Nein"><i class="bi bi-x-lg text-white"></i></span>
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                    <tr>
                                        <th scope="row">Sponsoring</th>
                                        {% for role in roles %}
                                            <td data-label="{{ role.name }}" class="text-center align-middle">
                                                {% if role.can_manage_sponsoring %}
                                                    <span class="badge rounded-pill bg-success" aria-label="Ja" title="Ja"><i class="bi bi-check-lg text-white"></i></span>
                                                {% else %}
                                                    <span class="badge rounded-pill bg-danger" aria-label="Nein" title="Nein"><i class="bi bi-x-lg text-white"></i></span>
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                    <tr>
                                        <th scope="row">Repertoire</th>
                                        {% for role in roles %}
                                            <td data-label="{{ role.name }}" class="text-center align-middle">
                                                {% if role.can_manage_song_library %}
                                                    <span class="badge rounded-pill bg-success" aria-label="Ja" title="Ja"><i class="bi bi-check-lg text-white"></i></span>
                                                {% else %}
                                                    <span class="badge rounded-pill bg-danger" aria-label="Nein" title="Nein"><i class="bi bi-x-lg text-white"></i></span>
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                    <tr>
                                        <th scope="row">Newsletter</th>
                                        {% for role in roles %}
                                            <td data-label="{{ role.name }}" class="text-center align-middle">
                                                {% if role.can_manage_newsletters %}
                                                    <span class="badge rounded-pill bg-success" aria-label="Ja" title="Ja"><i class="bi bi-check-lg text-white"></i></span>
                                                {% else %}
                                                    <span class="badge rounded-pill bg-danger" aria-label="Nein" title="Nein"><i class="bi bi-x-lg text-white"></i></span>
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                    <tr>
                                        <th scope="row">Mailversand verwalten</th>
                                        {% for role in roles %}
                                            <td data-label="{{ role.name }}" class="text-center align-middle">
                                                {% if role.can_manage_mail_queue %}
                                                    <span class="badge rounded-pill bg-success" aria-label="Ja" title="Ja"><i class="bi bi-check-lg text-white"></i></span>
                                                {% else %}
                                                    <span class="badge rounded-pill bg-danger" aria-label="Nein" title="Nein"><i class="bi bi-x-lg text-white"></i></span>
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                    <tr>
                                        <th scope="row">Notenarchiv verwalten</th>
                                        {% for role in roles %}
                                            <td data-label="{{ role.name }}" class="text-center align-middle">
                                                {% if role.can_manage_sheet_archive %}
                                                    <span class="badge rounded-pill bg-success" aria-label="Ja" title="Ja"><i class="bi bi-check-lg text-white"></i></span>
                                                {% else %}
                                                    <span class="badge rounded-pill bg-danger" aria-label="Nein" title="Nein"><i class="bi bi-x-lg text-white"></i></span>
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                    {% if settings.modules.budget %}
                                        <tr>
                                            <th scope="row">Budget verwalten</th>
                                            {% for role in roles %}
                                                <td data-label="{{ role.name }}" class="text-center align-middle">
                                                    {% if role.can_manage_budget %}
                                                        <span class="badge rounded-pill bg-success" aria-label="Ja" title="Ja"><i class="bi bi-check-lg text-white"></i></span>
                                                    {% else %}
                                                        <span class="badge rounded-pill bg-danger" aria-label="Nein" title="Nein"><i class="bi bi-x-lg text-white"></i></span>
                                                    {% endif %}
                                                </td>
                                            {% endfor %}
                                        </tr>
                                    {% endif %}
                                    <tr>
                                        <th scope="row">Aufgaben/Planung</th>
                                        {% for role in roles %}
                                            <td data-label="{{ role.name }}" class="text-center align-middle">
                                                {% if role.can_manage_tasks %}
                                                    <span class="badge rounded-pill bg-success" aria-label="Ja" title="Ja"><i class="bi bi-check-lg text-white"></i></span>
                                                {% else %}
                                                    <span class="badge rounded-pill bg-danger" aria-label="Nein" title="Nein"><i class="bi bi-x-lg text-white"></i></span>
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                    <tr>
                                        <th scope="row">Aktive Mitglieder</th>
                                        {% for role in roles %}
                                            <td data-label="{{ role.name }}" class="text-center align-middle">
                                                <span class="badge bg-primary rounded-pill text-center">{{ role.active_users_count }}</span>
                                            </td>
                                        {% endfor %}
                                    </tr>
                                    <tr>
                                        <th scope="row">Aktionen</th>
                                        {% for role in roles %}
                                            <td data-label="{{ role.name }}" class="text-center align-middle">
                                                <div class="btn-group"
                                                     role="group"
                                                     aria-label="Rollenaktionen für {{ role.name }}">
                                                    <button type="button"
                                                            class="btn btn-sm btn-outline-secondary edit-role-btn"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#editRoleModal"
                                                            data-id="{{ role.id }}"
                                                            data-name="{{ role.name }}"
                                                            data-level="{{ role.hierarchy_level }}"
                                                            data-manage="{{ role.can_manage_users ? '1' : '0' }}"
                                                            data-edit="{{ role.can_edit_users ? '1' : '0' }}"
                                                            data-attendance="{{ role.can_manage_attendance ? '1' : '0' }}"
                                                            data-project-members="{{ role.can_manage_project_members ? '1' : '0' }}"
                                                            data-finance-read="{{ role.can_read_finances ? '1' : '0' }}"
                                                            data-finances="{{ role.can_manage_finances ? '1' : '0' }}"
                                                            data-master-data="{{ role.can_manage_master_data ? '1' : '0' }}"
                                                            data-sponsoring="{{ role.can_manage_sponsoring ? '1' : '0' }}"
                                                            data-song-library="{{ role.can_manage_song_library ? '1' : '0' }}"
                                                            data-newsletters="{{ role.can_manage_newsletters ? '1' : '0' }}"
                                                            data-mail-queue="{{ role.can_manage_mail_queue ? '1' : '0' }}"
                                                            data-sheet-archive="{{ role.can_manage_sheet_archive ? '1' : '0' }}"
                                                            data-budget="{{ role.can_manage_budget ? '1' : '0' }}"
                                                            data-tasks="{{ role.can_manage_tasks ? '1' : '0' }}">
                                                        <i class="bi bi-pencil"></i> Bearbeiten
                                                    </button>
                                                </div>
                                            </td>
                                        {% endfor %}
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="2" class="text-center py-4 text-muted">Keine Rollen gefunden.</td>
                                    </tr>
                                {% endif %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <!-- Add Role Modal -->
    <div class="modal fade"
         id="addRoleModal"
         tabindex="-1"
         aria-labelledby="addRoleModalLabel"
         aria-hidden="true">
        <div class="modal-dialog">
            <form action="{{ role_create_action }}" method="post" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addRoleModalLabel">Neue Rolle anlegen</h5>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="name" class="form-label">Rollenname *</label>
                        <input type="text" class="form-control" id="name" name="name" required>
                    </div>

                    <div class="mb-3">
                        <label for="hierarchy_level" class="form-label">Hierarchie-Level (0-100) *</label>
                        <input type="number"
                               class="form-control"
                               id="hierarchy_level"
                               name="hierarchy_level"
                               min="0"
                               max="100"
                               value="0"
                               required>
                        <div class="form-text">
                            Höhere Level (z.B. 80-100) stehen für den Vorstand und die Chorleitung. "Mitglied" hat oft Level 0.
                        </div>
                    </div>

                    <div class="form-check form-switch mb-3 mt-4">
                        <input class="form-check-input"
                               type="checkbox"
                               role="switch"
                               id="can_manage_users"
                               name="can_manage_users"
                               value="1">
                        <label class="form-check-label fw-bold text-danger" for="can_manage_users">Mitgliederverwaltung erlauben</label>
                        <div class="form-text">
                            Wenn aktiv, erhalten Mitglieder mit dieser Rolle Zugriff auf die globale Verwaltung, Rollen, Projekte und Events.
                        </div>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input"
                               type="checkbox"
                               role="switch"
                               id="can_edit_users"
                               name="can_edit_users"
                               value="1">
                        <label class="form-check-label fw-bold text-warning" for="can_edit_users">Mitglieder editieren erlauben</label>
                        <div class="form-text">Wenn aktiv, darf diese Person die Zuweisungen anderer Mitglieder bearbeiten.</div>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input"
                               type="checkbox"
                               role="switch"
                               id="can_manage_project_members"
                               name="can_manage_project_members"
                               value="1">
                        <label class="form-check-label fw-bold text-info"
                               for="can_manage_project_members">Projektmitglieder verwalten</label>
                        <div class="form-text">Wenn aktiv, darf diese Person Benutzer Projekten zuordnen oder entfernen.</div>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input"
                               type="checkbox"
                               role="switch"
                               id="can_manage_attendance"
                               name="can_manage_attendance"
                               value="1">
                        <label class="form-check-label fw-bold text-secondary"
                               for="can_manage_attendance">Anwesenheit eintragen</label>
                        <div class="form-text">Wenn aktiv, darf diese Person Anwesenheiten erfassen und aktualisieren.</div>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input"
                               type="checkbox"
                               role="switch"
                               id="can_manage_master_data"
                               name="can_manage_master_data"
                               value="1">
                        <label class="form-check-label fw-bold text-primary"
                               for="can_manage_master_data">Stammdaten verwalten</label>
                        <div class="form-text">
                            Wenn aktiv, darf diese Person Projekte, Rollen, Stimmgruppen und App-Einstellungen bearbeiten.
                        </div>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input"
                               type="checkbox"
                               role="switch"
                               id="can_read_finances"
                               name="can_read_finances"
                               value="1">
                        <label class="form-check-label fw-bold text-success" for="can_read_finances">Finanzen nur lesen</label>
                        <div class="form-text">
                            Wenn aktiv, darf diese Person das Finanzmodul ansehen und Auswertungen sowie Anhänge öffnen.
                        </div>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input"
                               type="checkbox"
                               role="switch"
                               id="can_manage_finances"
                               name="can_manage_finances"
                               value="1">
                        <label class="form-check-label fw-bold text-success"
                               for="can_manage_finances">Finanzen lesen und schreiben</label>
                        <div class="form-text">Wenn aktiv, darf diese Person Finanzeinträge und Konfigurationen bearbeiten sowie löschen.</div>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input"
                               type="checkbox"
                               role="switch"
                               id="can_manage_sponsoring"
                               name="can_manage_sponsoring"
                               value="1">
                        <label class="form-check-label fw-bold text-info"
                               for="can_manage_sponsoring">Sponsoring verwalten</label>
                        <div class="form-text">
                            Wenn aktiv, darf diese Person das Sponsoring-Modul sehen und Sponsoren, Vereinbarungen und Kontakte verwalten.
                        </div>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input"
                               type="checkbox"
                               role="switch"
                               id="can_manage_song_library"
                               name="can_manage_song_library"
                               value="1">
                        <label class="form-check-label fw-bold text-primary"
                               for="can_manage_song_library">Repertoire verwalten</label>
                        <div class="form-text">Wenn aktiv, darf diese Person Lieder und zugehoerige Dateien pro Projekt verwalten.</div>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input"
                               type="checkbox"
                               role="switch"
                               id="can_manage_newsletters"
                               name="can_manage_newsletters"
                               value="1">
                        <label class="form-check-label fw-bold text-success"
                               for="can_manage_newsletters">Newsletter verwalten</label>
                        <div class="form-text">Wenn aktiv, darf diese Person Newsletter erstellen, bearbeiten und verschicken.</div>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input"
                               type="checkbox"
                               role="switch"
                               id="can_manage_mail_queue"
                               name="can_manage_mail_queue"
                               value="1">
                        <label class="form-check-label fw-bold text-primary"
                               for="can_manage_mail_queue">Mailversand verwalten</label>
                        <div class="form-text">Wenn aktiv, darf diese Person die Mail-Queue einsehen und Dead-Letter erneut senden.</div>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input"
                               type="checkbox"
                               role="switch"
                               id="can_manage_sheet_archive"
                               name="can_manage_sheet_archive"
                               value="1">
                        <label class="form-check-label fw-bold text-primary"
                               for="can_manage_sheet_archive">Notenarchiv verwalten</label>
                        <div class="form-text">Wenn aktiv, darf diese Person den Notenarchiv-Bereich im Repertoire sehen und bearbeiten.</div>
                    </div>

                          {% if settings.modules.budget %}
                           <div class="form-check form-switch mb-3">
                            <input class="form-check-input"
                                type="checkbox"
                                role="switch"
                                id="can_manage_budget"
                                name="can_manage_budget"
                                value="1">
                            <label class="form-check-label fw-bold text-primary"
                                for="can_manage_budget">Budget verwalten</label>
                            <div class="form-text">Wenn aktiv, darf diese Person den Budget-Bereich sehen und bearbeiten.</div>
                           </div>
                          {% endif %}

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input"
                               type="checkbox"
                               role="switch"
                               id="can_manage_tasks"
                               name="can_manage_tasks"
                               value="1">
                        <label class="form-check-label fw-bold text-primary" for="can_manage_tasks">Projektplanung (Aufgaben)</label>
                        <div class="form-text">Wenn aktiv, darf diese Person Aufgaben (auch übergreifend) verwalten.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Rolle Speichern</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Role Modal -->
    <div class="modal fade"
         id="editRoleModal"
         tabindex="-1"
         aria-labelledby="editRoleModalLabel"
         aria-hidden="true">
        <div class="modal-dialog">
            <form action="{{ role_edit_action }}"
                  method="post"
                  id="editRoleForm"
                  class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editRoleModalLabel">Rolle bearbeiten</h5>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="edit_name" class="form-label">Rollenname *</label>
                        <input type="text" class="form-control" id="edit_name" name="name" required>
                    </div>

                    <div class="mb-3">
                        <label for="edit_hierarchy_level" class="form-label">Hierarchie-Level (0-100) *</label>
                        <input type="number"
                               class="form-control"
                               id="edit_hierarchy_level"
                               name="hierarchy_level"
                               min="0"
                               max="100"
                               required>
                        <div class="form-text">
                            Höhere Level (z.B. 80-100) stehen für den Vorstand und die Chorleitung. "Mitglied" hat oft Level 0.
                        </div>
                    </div>

                    <div class="form-check form-switch mb-3 mt-4">
                        <input class="form-check-input"
                               type="checkbox"
                               role="switch"
