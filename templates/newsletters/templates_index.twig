{% extends "layout.twig" %}

{% block title %}
    Newsletter-Vorlagen - {{ app_settings.app_name|default("Chor-Manager") }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Bereiche</p>
            <h1 class="h2 mb-1">Newsletter-Vorlagen</h1>
            <p class="text-muted mb-0">Globale und projektbezogene Vorlagen zentral verwalten.</p>
        </div>
        <div class="page-actions d-flex gap-2">
            <button type="button"
                    class="btn btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#createTemplateModal">
                <i class="bi bi-plus-circle"></i> Vorlage erstellen
            </button>
            <a href="/newsletters" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Zurück zu Newslettern
            </a>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    <div class="container-fluid px-0">
        {% if success %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                {{ success }}
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert"
                        aria-label="Close"></button>
            </div>
        {% endif %}
        {% if error %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                {{ error }}
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert"
                        aria-label="Close"></button>
            </div>
        {% endif %}

        <div class="dashboard-shell">
            <section class="dashboard-section dashboard-section--context"
                     aria-labelledby="newsletter-templates-list-title">
                <div class="dashboard-section-head">
                    <h2 class="dashboard-section-title" id="newsletter-templates-list-title">Vorlagenübersicht</h2>
                    <p class="dashboard-section-lead mb-0">{{ templates|length }} Vorlagen im aktuellen Ergebnis.</p>
                </div>

                <div class="surface-card card border-0 table-shell"
                     data-table-engine="true"
                     data-table-id="newsletters.templates.index"
                     data-default-view="auto"
                     data-default-page-size="100"
                     data-page-size-options="25,50,100,200"
                     data-default-sort-key="name">
                    {{ include("partials/table_toolbar.twig") }}
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 table-responsive-cards"
                                   id="newsletterTemplatesTable">
                                <thead class="table-dark">
                                    <tr>
                                        <th data-sort-key="name" data-sort-type="text">Name</th>
                                        <th data-sort-key="context" data-sort-type="text">Kontext</th>
                                        <th class="text-end">Aktionen</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for template in templates %}
                                        <tr data-sort-name="{{ template.name|lower }}"
                                            data-sort-context="{{ template.project_id ? "projekt" : "global" }}">
                                            <td data-label="Name">{{ template.name }}</td>
                                            <td data-label="Kontext">
                                                <span class="badge rounded-pill {{ template.project_id ? "bg-info text-dark" : "bg-secondary" }}">
                                                    {{ template.project_id ? "Projekt" : "Global" }}
                                                </span>
                                            </td>
                                            <td data-label="Aktionen" class="text-end">
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-primary"
                                                        data-newsletter-modal-url="/newsletters/templates/{{ template.id }}/edit?modal=1"
                                                        data-newsletter-modal-title="Vorlage bearbeiten">
                                                    Bearbeiten
                                                </button>
                                                <form method="post"
                                                      action="/newsletters/templates/{{ template.id }}/clone"
                                                      class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary">Klonen</button>
                                                </form>
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="3" class="text-center py-4 text-muted">Es sind noch keine Vorlagen vorhanden.</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <div class="modal fade"
             id="createTemplateModal"
             tabindex="-1"
             aria-labelledby="createTemplateModalLabel"
             aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                <div class="modal-content">
                    <form method="post" action="/newsletters/templates">
                        <div class="modal-header">
                            <h2 class="modal-title h5" id="createTemplateModalLabel">Neue Vorlage erstellen</h2>
                            <button type="button"
                                    class="btn-close"
                                    data-bs-dismiss="modal"
                                    aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row g-3">
                                <div class="col-md-8">
                                    <label class="form-label" for="name">Name</label>
                                    <input class="form-control" id="name" name="name" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label" for="project_id">Kontext</label>
                                    <select class="form-select" id="project_id" name="project_id">
                                        <option value="">Global</option>
                                        {% for project in projects %}<option value="{{ project.id }}">{{ project.name }}</option>{% endfor %}
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label" for="description">Beschreibung</label>
                                    <textarea class="form-control" id="description" name="description" rows="2"></textarea>
                                </div>
                                <div class="col-12">
                                    <label class="form-label" for="content_html">Inhalt</label>
                                    <textarea class="form-control tinymce-editor"
                                              id="content_html"
                                              name="content_html"
                                              required></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    data-bs-dismiss="modal">Abbrechen</button>
                            <button type="submit" class="btn btn-primary">Vorlage erstellen</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="modal fade"
             id="newsletterActionModal"
             tabindex="-1"
             aria-labelledby="newsletterActionModalLabel"
             aria-hidden="true">
            <div class="modal-dialog modal-xl modal-dialog-scrollable">
                <div class="modal-content border-0 shadow rounded-3">
                    <div class="modal-header">
                        <h5 class="modal-title" id="newsletterActionModalLabel">Newsletter</h5>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-2 p-md-3">
                        <div id="newsletterActionContent" class="container-fluid px-0"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock content %}

{% block scripts %}
    <script src="/js/newsletters.js"></script>
{% endblock scripts %}
