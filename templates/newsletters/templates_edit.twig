{% extends 'layout.twig' %}
{% block content %}
<div class="container py-3">
  <h1 class="h2 mb-3">Vorlage bearbeiten</h1>
  <form method="post" action="/newsletters/templates/{{ template.id }}">
    <div class="mb-3">
      <label class="form-label" for="name">Name</label>
      <input class="form-control" id="name" name="name" value="{{ template.name }}" required>
    </div>
    <div class="mb-3">
      <label class="form-label" for="category">Kategorie</label>
      <input class="form-control" id="category" name="category" value="{{ template.category }}">
    </div>
    <div class="mb-3">
      <label class="form-label" for="description">Beschreibung</label>
      <textarea class="form-control" id="description" name="description" rows="2">{{ template.description }}</textarea>
    </div>
    <div class="mb-3">
      <label class="form-label" for="content_html">Inhalt</label>
      <textarea class="form-control" id="content_html" name="content_html" rows="10" required>{{ template.content_html }}</textarea>
    </div>
    <div class="d-flex gap-2 justify-content-end">
      <a href="/newsletters/templates" class="btn btn-outline-secondary">Abbrechen</a>
      <button type="submit" class="btn btn-primary">Speichern</button>
    </div>
  </form>
</div>
{% endblock content %}

