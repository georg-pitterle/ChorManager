{% extends is_modal|default(false) ? 'layout_modal.twig' : 'layout.twig' %}

{% block title %}
    Newsletter bearbeiten - {{ app_settings.app_name|default("Chor-Manager") }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Kommunikation</p>
            <h1 class="h2 mb-1">Newsletter bearbeiten</h1>
            <p class="text-muted mb-0">
                Projekt: <strong>{{ project.name }}</strong>
            </p>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    <div class="container-fluid px-0">
        <!-- Lock Warning -->
        {% if newsletter.isLocked() and newsletter.locked_by != session.user_id %}
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle"></i>
                <strong>Newsletter wird bearbeitet!</strong>
                Dieser Newsletter wird gerade von
                <strong>{{ newsletter.lockedBy.first_name }} {{ newsletter.lockedBy.last_name }}</strong>
                bearbeitet. Aktualisierung alle 30 Sekunden.
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endif %}

        <form id="edit-newsletter-form"
              method="post"
              action="/newsletters/{{ newsletter.id }}"
              data-newsletter-id="{{ newsletter.id }}"
              data-is-modal="{{ is_modal|default(false) ? '1' : '0' }}">
            <div class="surface-card form-surface card mb-4 border-0">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Newsletter-Einstellungen</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label for="project_id" class="form-label">
                            Projekt <span class="text-danger">*</span>
                        </label>
                        <select class="form-select" id="project_id" name="project_id" required>
                            {% for selectable_project in projects %}
                                <option value="{{ selectable_project.id }}"
                                        {% if newsletter.project_id == selectable_project.id %}selected{% endif %}>
                                    {{ selectable_project.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="title" class="form-label">
                            Titel <span class="text-danger">*</span>
                        </label>
                        <input type="text"
                               class="form-control"
                               id="title"
                               name="title"
                               value="{{ newsletter.title }}"
                               required>
                    </div>

                    <div class="mb-3">
                        <label for="event_id" class="form-label">Event (optional)</label>
                        <select class="form-select" id="event_id" name="event_id">
                            <option value="">-- Keine Auswahl --</option>
                            {% for event in events %}
                                <option value="{{ event.id }}"
                                        data-project-id="{{ event.project_id }}"
                                        {% if newsletter.event_id == event.id %}selected{% endif %}>
                                    {{ event.title }} ({{ event.event_date|date("d.m.Y") }}) - {{ event.project.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="alert alert-info">
                        <strong>Empfänger:</strong> <span class="badge bg-info">{{ newsletter.recipient_count }}</span>
                        {% if newsletter.event_id %}
                            Teilnehmer des Events
                        {% else %}
                            Alle Projektmitglieder
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="surface-card form-surface card mb-4 border-0">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Inhalt</h5>
                </div>
                <div class="card-body">
                    <textarea id="content_html" name="content_html" class="tinymce-editor">{{ newsletter.content_html }}</textarea>
                </div>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-between">
                <div>
                    <a href="/newsletters?project_id={{ project.id }}&status=draft"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Zurück
                    </a>
                </div>
                <div>
                    <form method="post"
                          action="/newsletters/{{ newsletter.id }}/delete"
                          class="d-inline"
                          data-confirm="Diesen Newsletter-Entwurf wirklich löschen?">
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="bi bi-trash"></i> Löschen
                        </button>
                    </form>
                    <button type="button" class="btn btn-outline-warning" id="save-draft-btn">
                        <i class="bi bi-floppy"></i> Speichern
                    </button>
                    <button type="button"
                            class="btn btn-outline-info"
                            id="preview-btn"
                            {% if not is_modal|default(false) %}
                                data-bs-toggle="modal"
                                data-bs-target="#previewModal"
                            {% endif %}>
                        <i class="bi bi-eye"></i> Vorschau
                    </button>
                    <button type="button" class="btn btn-success" id="send-newsletter-btn">
                        <i class="bi bi-send"></i> Versenden
                    </button>
                </div>
            </div>

            <!-- Save Template Modal -->
            <div class="modal fade" id="saveTemplateModal" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Als Vorlage speichern</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label for="template_name" class="form-label">Vorlagen-Name</label>
                                <input type="text"
                                       class="form-control"
                                       id="template_name"
                                       value="{{ newsletter.title }}">
                            </div>
                            <div class="mb-3">
                                <label for="template_description" class="form-label">Beschreibung</label>
                                <textarea class="form-control" id="template_description" rows="3"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                            <button type="button" class="btn btn-primary" id="save-template-btn">Speichern</button>
                        </div>
                    </div>
                </div>
            </div>

            <button type="button"
                    class="btn btn-sm btn-outline-secondary mt-4"
                    data-bs-toggle="modal"
                    data-bs-target="#saveTemplateModal">
                <i class="bi bi-bookmark"></i> Als Vorlage speichern
            </button>
        </form>

        <div class="modal fade"
             id="previewModal"
             tabindex="-1"
             aria-labelledby="previewModalLabel"
             aria-hidden="true">
            <div class="modal-dialog modal-xl modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="previewModalLabel">Newsletter-Vorschau</h5>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3 pb-3 border-bottom">
                            <h4 id="preview-modal-title" class="mb-1"></h4>
                            <small class="text-muted">
                                Projekt: <span id="preview-modal-project"></span>
                                | Event: <span id="preview-modal-event">Kein Event</span>
                            </small>
                        </div>
                        <div id="preview-modal-content"
                             class="newsletter-content bg-light p-4 rounded"></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Schließen</button>
                    </div>
                </div>
            </div>
        </div>

        <form id="send-form"
              method="post"
              action="/newsletters/{{ newsletter.id }}/send"
              class="d-none">
        </form>
    </div>
{% endblock content %}

{% block scripts %}
    <script src="/js/newsletters-edit.js"></script>
{% endblock scripts %}
