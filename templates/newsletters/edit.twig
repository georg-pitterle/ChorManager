{% extends 'layout.twig' %}

{% block title %}Newsletter bearbeiten{% endblock %}

{% block content %}
<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Newsletter bearbeiten</h1>
            <p class="text-muted">Projekt: <strong>{{ project.name }}</strong></p>
        </div>
    </div>

    <!-- Lock Warning -->
    {% if newsletter.isLocked() and newsletter.locked_by != session.user_id %}
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i>
        <strong>Newsletter wird bearbeitet!</strong>
        Dieser Newsletter wird gerade von
        <strong>{{ newsletter.lockedBy.first_name }} {{ newsletter.lockedBy.last_name }}</strong>
        bearbeitet. Aktualisierung alle 30 Sekunden.
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {% endif %}

    <form id="edit-newsletter-form" method="post" action="/newsletters/{{ newsletter.id }}">
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">Newsletter-Einstellungen</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label for="project_id" class="form-label">Projekt <span class="text-danger">*</span></label>
                    <select class="form-select" id="project_id" name="project_id" required>
                        {% for selectable_project in projects %}
                        <option value="{{ selectable_project.id }}" {% if newsletter.project_id == selectable_project.id %}selected{% endif %}>
                            {{ selectable_project.name }}
                        </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="mb-3">
                    <label for="title" class="form-label">Titel <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="title" name="title"
                           value="{{ newsletter.title }}" required>
                </div>

                <div class="mb-3">
                    <label for="event_id" class="form-label">Event (optional)</label>
                    <select class="form-select" id="event_id" name="event_id">
                        <option value="">-- Keine Auswahl --</option>
                        {% for event in events %}
                        <option value="{{ event.id }}" data-project-id="{{ event.project_id }}"
                                {% if newsletter.event_id == event.id %}selected{% endif %}>
                            {{ event.title }} ({{ event.event_date|date('d.m.Y') }}) - {{ event.project.name }}
                        </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="alert alert-info">
                    <strong>Empfänger:</strong> <span class="badge bg-info">{{ newsletter.recipient_count }}</span>
                    {% if newsletter.event_id %}
                        Teilnehmer des Events
                    {% else %}
                        Alle Projektmitglieder
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">Inhalt</h5>
            </div>
            <div class="card-body">
                <textarea id="content_html" name="content_html" class="tinymce-editor">{{ newsletter.content_html }}</textarea>
            </div>
        </div>

        <div class="d-grid gap-2 d-md-flex justify-content-md-between">
            <div>
                <a href="/newsletters?project_id={{ project.id }}&status=draft" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Zurück
                </a>
            </div>
            <div>
                <button type="button" class="btn btn-outline-warning" id="save-draft-btn">
                    <i class="bi bi-floppy"></i> Speichern
                </button>
                <button type="button" class="btn btn-outline-info" id="preview-btn" data-bs-toggle="modal" data-bs-target="#previewModal">
                    <i class="bi bi-eye"></i> Vorschau
                </button>
                <button type="button" class="btn btn-success" id="send-newsletter-btn">
                    <i class="bi bi-send"></i> Versenden
                </button>
            </div>
        </div>

        <!-- Save Template Modal -->
        <div class="modal fade" id="saveTemplateModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Als Vorlage speichern</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="template_name" class="form-label">Vorlagen-Name</label>
                            <input type="text" class="form-control" id="template_name"
                                   value="{{ newsletter.title }}">
                        </div>
                        <div class="mb-3">
                            <label for="template_category" class="form-label">Kategorie</label>
                            <select class="form-select" id="template_category">
                                <option value="general">Allgemein</option>
                                <option value="event">Event-Ankündigung</option>
                                <option value="update">Update</option>
                                <option value="report">Nachbericht</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="template_description" class="form-label">Beschreibung</label>
                            <textarea class="form-control" id="template_description" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            Abbrechen
                        </button>
                        <button type="button" class="btn btn-primary" id="save-template-btn">
                            Speichern
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <button type="button" class="btn btn-sm btn-outline-secondary mt-4" data-bs-toggle="modal"
                data-bs-target="#saveTemplateModal">
            <i class="bi bi-bookmark"></i> Als Vorlage speichern
        </button>
    </form>

    <div class="modal fade" id="previewModal" tabindex="-1" aria-labelledby="previewModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="previewModalLabel">Newsletter-Vorschau</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3 pb-3 border-bottom">
                        <h4 id="preview-modal-title" class="mb-1"></h4>
                        <small class="text-muted">
                            Projekt: <span id="preview-modal-project"></span>
                            | Event: <span id="preview-modal-event">Kein Event</span>
                        </small>
                    </div>
                    <div id="preview-modal-content" class="newsletter-content bg-light p-4 rounded"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Schließen</button>
                </div>
            </div>
        </div>
    </div>

    <form id="send-form" method="post" action="/newsletters/{{ newsletter.id }}/send" class="d-none"></form>
</div>

<script>
const editForm = document.getElementById('edit-newsletter-form');
const newsletterUpdateUrl = '/newsletters/{{ newsletter.id }}';
let lastSavedSnapshot = null;
let saveInProgress = false;

function filterEventsByProject() {
    const projectId = document.getElementById('project_id').value;
    const eventSelect = document.getElementById('event_id');
    const options = eventSelect.querySelectorAll('option[data-project-id]');

    options.forEach(option => {
        const matches = option.getAttribute('data-project-id') === projectId;
        option.hidden = !matches;
        option.disabled = !matches;
    });

    const selectedOption = eventSelect.options[eventSelect.selectedIndex];
    if (selectedOption && selectedOption.hasAttribute('data-project-id')
        && selectedOption.getAttribute('data-project-id') !== projectId) {
        eventSelect.value = '';
    }
}

function createSnapshot() {
    const projectId = document.getElementById('project_id').value || '';
    const title = document.getElementById('title').value || '';
    const eventId = document.getElementById('event_id').value || '';
    const editor = tinymce.get('content_html');
    const contentHtml = editor ? editor.getContent() : '';

    return JSON.stringify({
        project_id: projectId,
        title: title,
        event_id: eventId,
        content_html: contentHtml
    });
}

async function saveNewsletter(showSuccessMessage = false) {
    if (saveInProgress) {
        return;
    }

    const currentSnapshot = createSnapshot();
    if (lastSavedSnapshot !== null && currentSnapshot === lastSavedSnapshot) {
        return;
    }

    saveInProgress = true;
    const formData = new FormData(editForm);
    const editor = tinymce.get('content_html');
    formData.set('content_html', editor ? editor.getContent() : '');

    try {
        const response = await fetch(newsletterUpdateUrl, {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        });

        if (!response.ok) {
            if (showSuccessMessage) {
                alert('Fehler beim Speichern');
            }
            return;
        }

        lastSavedSnapshot = currentSnapshot;
        if (showSuccessMessage) {
            alert('Newsletter gespeichert');
        }
    } finally {
        saveInProgress = false;
    }
}

// Prevent default HTML form submit to avoid navigating to JSON response.
editForm.addEventListener('submit', function (event) {
    event.preventDefault();
    saveNewsletter(true);
});

// Initialize snapshot after editor has loaded.
window.addEventListener('load', function () {
    filterEventsByProject();
    lastSavedSnapshot = createSnapshot();
});

document.getElementById('project_id').addEventListener('change', filterEventsByProject);

// Auto-save every 30 seconds, but only when something changed.
setInterval(function () {
    saveNewsletter(false);
}, 30000);

// Save Draft
document.getElementById('save-draft-btn').addEventListener('click', function () {
    saveNewsletter(true);
});

// Preview
document.getElementById('preview-btn').addEventListener('click', function() {
    const selectedEvent = document.querySelector('#event_id option:checked');
    document.getElementById('preview-modal-title').textContent = document.getElementById('title').value || 'Ohne Titel';
    document.getElementById('preview-modal-project').textContent = document.querySelector('#project_id option:checked')?.textContent?.trim() || '';
    document.getElementById('preview-modal-event').textContent = selectedEvent && selectedEvent.value
        ? selectedEvent.textContent.trim()
        : 'Kein Event';
    document.getElementById('preview-modal-content').innerHTML = tinymce.get('content_html')?.getContent() || '';
});

document.getElementById('send-newsletter-btn').addEventListener('click', function () {
    if (confirm('Newsletter jetzt versenden?')) {
        document.getElementById('send-form').submit();
    }
});

// Save Template
document.getElementById('save-template-btn').addEventListener('click', async function() {
    const formData = new FormData();
    formData.set('template_name', document.getElementById('template_name').value);
    formData.set('template_category', document.getElementById('template_category').value);
    formData.set('template_description', document.getElementById('template_description').value);

    const response = await fetch('/newsletters/{{ newsletter.id }}/save-as-template', {
        method: 'POST',
        body: formData
    });

    if (!response.ok) {
        alert('Fehler beim Speichern der Vorlage');
        return;
    }

    bootstrap.Modal.getInstance(document.getElementById('saveTemplateModal')).hide();
    alert('Vorlage gespeichert');
});

// Lock Polling
setInterval(async function() {
    const response = await fetch('/newsletters/{{ newsletter.id }}/check-lock');
    if (!response.ok) return;
    const data = await response.json();
    if (data.locked && !data.is_me) {
        alert(`Newsletter wird jetzt von ${data.locked_by_user} bearbeitet`);
        window.location.reload();
    }
}, 30000);
</script>
{% endblock %}
