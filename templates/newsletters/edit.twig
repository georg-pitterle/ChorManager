{% extends is_modal|default(false) ? 'layout_modal.twig' : 'layout.twig' %}

{% block title %}
    Newsletter bearbeiten - {{ app_settings.app_name|default('Chor-Manager') }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Bereiche</p>
            <h1 class="h2 mb-1">Newsletter bearbeiten</h1>
            <p class="text-muted mb-0">
                Projekt: <strong>{{ project.name }}</strong>
            </p>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    <div class="container-fluid px-0">
        <!-- Lock Warning -->
        {% if newsletter.isLocked() and newsletter.locked_by != session.user_id %}
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle"></i>
                <strong>Newsletter wird bearbeitet!</strong>
                Dieser Newsletter wird gerade von
                <strong>{{ newsletter.lockedBy.first_name }} {{ newsletter.lockedBy.last_name }}</strong>
                bearbeitet. Aktualisierung alle 30 Sekunden.
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endif %}

        <form id="edit-newsletter-form"
              method="post"
              action="/newsletters/{{ newsletter.id }}"
              data-newsletter-id="{{ newsletter.id }}"
              data-is-modal="{{ is_modal|default(false) ? '1' : '0' }}">
            <div class="dashboard-shell">
                <section class="dashboard-section dashboard-section--actions"
                         aria-labelledby="newsletter-edit-settings-title">
                    <div class="dashboard-section-head">
                        <h2 class="dashboard-section-title" id="newsletter-edit-settings-title">Newsletter-Einstellungen</h2>
                        <p class="dashboard-section-lead mb-0">Projekt, Titel und Empfängerquellen anpassen.</p>
                    </div>

                    <div class="surface-card form-surface card border-0">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Newsletter-Einstellungen</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label for="project_id" class="form-label">
                                    Projekt <span class="text-danger">*</span>
                                </label>
                                <select class="form-select" id="project_id" name="project_id" required>
                                    {% for selectable_project in projects %}
                                        <option value="{{ selectable_project.id }}"
                                                {% if newsletter.project_id == selectable_project.id %}selected{% endif %}>
                                            {{ selectable_project.name }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="title" class="form-label">
                                    Titel <span class="text-danger">*</span>
                                </label>
                                <input type="text"
                                       class="form-control"
                                       id="title"
                                       name="title"
                                       value="{{ newsletter.title }}"
                                       required>
                            </div>

                            {% set project_source_ids = [] %}
                            {% set event_source_ids = [] %}
                            {% set role_source_ids = [] %}
                            {% set user_source_ids = [] %}
                            {% for source in recipient_sources %}
                                {% if source.type == 'project_members' %}
                                    {% set project_source_ids = project_source_ids|merge([source.reference_id]) %}
                                {% elseif source.type == 'event_attendees' %}
                                    {% set event_source_ids = event_source_ids|merge([source.reference_id]) %}
                                {% elseif source.type == 'role' %}
                                    {% set role_source_ids = role_source_ids|merge([source.reference_id]) %}
                                {% elseif source.type == 'user' %}
                                    {% set user_source_ids = user_source_ids|merge([source.reference_id]) %}
                                {% endif %}
                            {% endfor %}

                            <section class="mb-3" id="recipient-sources" aria-labelledby="recipient-sources-title">
                                <h3 class="h6" id="recipient-sources-title">Empfängerquellen</h3>

                                <div class="mb-3" data-source-type="project_members">
                                    <label class="form-label d-flex justify-content-between align-items-center">
                                        <span>Projektmitglieder</span>
                                        <span class="badge bg-secondary" id="source-project-members-count">{{ project_source_ids|length }}</span>
                                    </label>
                                    <div class="dropdown newsletter-source-dropdown">
                                        <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start"
                                                type="button"
                                                data-bs-toggle="dropdown"
                                                data-bs-auto-close="outside"
                                                aria-expanded="false">
                                            Projekte auswählen
                                        </button>
                                        <div class="dropdown-menu p-2 newsletter-source-dropdown-menu">
                                            {% for selectable_project in projects %}
                                                <div class="form-check">
                                                    <input class="form-check-input newsletter-source-option"
                                                           type="checkbox"
                                                           data-source-type="project_members"
                                                           value="{{ selectable_project.id }}"
                                                           id="edit-source-project-{{ selectable_project.id }}"
                                                           {% if selectable_project.id in project_source_ids %}checked{% endif %}>
                                                    <label class="form-check-label"
                                                           for="edit-source-project-{{ selectable_project.id }}">
                                                        {{ selectable_project.name }}
                                                    </label>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                    <div class="form-text">Mehrfachauswahl per Klick. Dropdown bleibt zum schnellen Auswählen geöffnet.</div>
                                </div>

                                <div class="mb-3" data-source-type="event_attendees">
                                    <label class="form-label d-flex justify-content-between align-items-center">
                                        <span>Veranstaltungsteilnehmer</span>
                                        <span class="badge bg-secondary" id="source-event-attendees-count">{{ event_source_ids|length }}</span>
                                    </label>
                                    <div class="dropdown newsletter-source-dropdown">
                                        <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start"
                                                type="button"
                                                data-bs-toggle="dropdown"
                                                data-bs-auto-close="outside"
                                                aria-expanded="false">
                                            Veranstaltungen auswählen
                                        </button>
                                        <div class="dropdown-menu p-2 newsletter-source-dropdown-menu">
                                            {% for event in events %}
                                                <div class="form-check">
                                                    <input class="form-check-input newsletter-source-option"
                                                           type="checkbox"
                                                           data-source-type="event_attendees"
                                                           value="{{ event.id }}"
                                                           id="edit-source-event-{{ event.id }}"
                                                           {% if event.id in event_source_ids %}checked{% endif %}>
                                                    <label class="form-check-label" for="edit-source-event-{{ event.id }}">
                                                        {{ event.title }} ({{ event.starts_at|date('d.m.Y') }}) - {{ event.project.name }}
                                                    </label>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3" data-source-type="role">
                                    <label class="form-label d-flex justify-content-between align-items-center">
                                        <span>Rollen</span>
                                        <span class="badge bg-secondary" id="source-roles-count">{{ role_source_ids|length }}</span>
                                    </label>
                                    <div class="dropdown newsletter-source-dropdown">
                                        <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start"
                                                type="button"
                                                data-bs-toggle="dropdown"
                                                data-bs-auto-close="outside"
                                                aria-expanded="false">
                                            Rollen auswählen
                                        </button>
                                        <div class="dropdown-menu p-2 newsletter-source-dropdown-menu">
                                            {% for role in roles %}
                                                <div class="form-check">
                                                    <input class="form-check-input newsletter-source-option"
                                                           type="checkbox"
                                                           data-source-type="role"
                                                           value="{{ role.id }}"
                                                           id="edit-source-role-{{ role.id }}"
                                                           {% if role.id in role_source_ids %}checked{% endif %}>
                                                    <label class="form-check-label" for="edit-source-role-{{ role.id }}">
                                                        {{ role.name }}
                                                    </label>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3" data-source-type="user">
                                    <label class="form-label d-flex justify-content-between align-items-center">
                                        <span>Einzelne Mitglieder</span>
                                        <span class="badge bg-secondary" id="source-users-count">{{ user_source_ids|length }}</span>
                                    </label>
                                    <div class="dropdown newsletter-source-dropdown">
                                        <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start"
                                                type="button"
                                                data-bs-toggle="dropdown"
                                                data-bs-auto-close="outside"
                                                aria-expanded="false">
                                            Mitglieder auswählen
                                        </button>
                                        <div class="dropdown-menu p-2 newsletter-source-dropdown-menu">
                                            {% for member in users %}
                                                <div class="form-check">
                                                    <input class="form-check-input newsletter-source-option"
                                                           type="checkbox"
                                                           data-source-type="user"
                                                           value="{{ member.id }}"
                                                           id="edit-source-user-{{ member.id }}"
                                                           {% if member.id in user_source_ids %}checked{% endif %}>
                                                    <label class="form-check-label" for="edit-source-user-{{ member.id }}">
                                                        {{ member.last_name }}, {{ member.first_name }}
                                                    </label>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>

                                <div class="alert alert-info mb-0">
                                    <strong>Empfänger:</strong>
                                    <span id="recipient-count-badge" class="badge bg-info">{{ newsletter.recipient_count }}</span>
                                    <span class="small text-muted ms-2" id="recipient-count-status"></span>
                                </div>
                            </section>
                        </div>
                    </div>
                </section>

                <section class="dashboard-section dashboard-section--actions"
                         aria-labelledby="newsletter-edit-content-title">
                    <div class="dashboard-section-head">
                        <h2 class="dashboard-section-title" id="newsletter-edit-content-title">Inhalt</h2>
                        <p class="dashboard-section-lead mb-0">Inhalt prüfen, bearbeiten und versenden.</p>
                    </div>

                    <div class="surface-card form-surface card border-0">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Inhalt</h5>
                        </div>
                        <div class="card-body">
                            <textarea id="content_html" name="content_html" class="tinymce-editor">{{ newsletter.content_html }}</textarea>
                        </div>
                    </div>
                </section>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-between">
                <div>
                    <a href="/newsletters?project_id={{ project.id }}&status=draft"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Zurück
                    </a>
                </div>
                <div>
                    <form method="post"
                          action="/newsletters/{{ newsletter.id }}/delete"
                          class="d-inline"
                          data-confirm="Diesen Newsletter-Entwurf wirklich löschen?">
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="bi bi-trash"></i> Löschen
                        </button>
                    </form>
                    <button type="button" class="btn btn-outline-warning" id="save-draft-btn">
                        <i class="bi bi-floppy"></i> Speichern
                    </button>
                    <button type="button"
                            class="btn btn-outline-info"
                            id="preview-btn"
                            {% if not is_modal|default(false) %}data-bs-toggle="modal" data-bs-target="#previewModal"{% endif %}>
                        <i class="bi bi-eye"></i> Vorschau
                    </button>
                    <button type="button" class="btn btn-success" id="send-newsletter-btn">
                        <i class="bi bi-send"></i> Versenden
                    </button>
                </div>
            </div>

            <!-- Save Template Modal -->
            <div class="modal fade" id="saveTemplateModal" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Als Vorlage speichern</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label for="template_name" class="form-label">Vorlagen-Name</label>
                                <input type="text"
                                       class="form-control"
                                       id="template_name"
                                       value="{{ newsletter.title }}">
                            </div>
                            <div class="mb-3">
                                <label for="template_description" class="form-label">Beschreibung</label>
                                <textarea class="form-control" id="template_description" rows="3"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                            <button type="button" class="btn btn-primary" id="save-template-btn">Speichern</button>
                        </div>
                    </div>
                </div>
            </div>

            <button type="button"
                    class="btn btn-sm btn-outline-secondary mt-4"
                    data-bs-toggle="modal"
                    data-bs-target="#saveTemplateModal">
                <i class="bi bi-bookmark"></i> Als Vorlage speichern
            </button>
        </form>

        <div class="modal fade"
             id="previewModal"
             tabindex="-1"
             aria-labelledby="previewModalLabel"
             aria-hidden="true">
            <div class="modal-dialog modal-xl modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="previewModalLabel">Newsletter-Vorschau</h5>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3 pb-3 border-bottom">
                            <h4 id="preview-modal-title" class="mb-1"></h4>
                            <small class="text-muted">
                                Projekt: <span id="preview-modal-project"></span>
                            </small>
                        </div>
                        <div id="preview-modal-content"
                             class="newsletter-content bg-light p-4 rounded"></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Schließen</button>
                    </div>
                </div>
            </div>
        </div>

        <form id="send-form"
              method="post"
              action="/newsletters/{{ newsletter.id }}/send"
              class="d-none">
        </form>
    </div>
{% endblock content %}

{% block scripts %}
    <script src="{{ asset_path('/js/newsletters-edit.js') }}"></script>
{% endblock scripts %}
