{% extends "layout.twig" %}

{% block title %}Newsletter-Übersicht{% endblock %}

{% block content %}
<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Newsletter</h1>
            <p class="text-muted">Projekt: <strong>{{ project.name }}</strong></p>
        </div>
        <div class="col-md-4 text-end">
            <a href="{{ request.getQueryParams()['project_id'] }}" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Neuer Newsletter
            </a>
        </div>
    </div>

    <!-- Filter Tabs -->
    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <a class="nav-link {% if status == 'draft' %}active{% endif %}"
               href="?project_id={{ project.id }}&status=draft">
                Entwürfe
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link {% if status == 'sent' %}active{% endif %}"
               href="?project_id={{ project.id }}&status=sent">
                Versendet
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link {% if status == 'archived' %}active{% endif %}"
               href="?project_id={{ project.id }}&status=archived">
                Archiv
            </a>
        </li>
    </ul>

    <!-- Newsletters List -->
    {% if newsletters|length > 0 %}
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Titel</th>
                    <th>Erstellt von</th>
                    <th>Empfänger</th>
                    <th>Erstellt am</th>
                    <th>Status</th>
                    <th>Aktionen</th>
                </tr>
            </thead>
            <tbody>
                {% for newsletter in newsletters %}
                <tr>
                    <td>
                        <strong>{{ newsletter.title }}</strong>
                        {% if newsletter.event_id %}
                        <br><small class="text-muted">Event: {{ newsletter.event.title ?? 'N/A' }}</small>
                        {% endif %}
                    </td>
                    <td>{{ newsletter.createdBy.first_name }} {{ newsletter.createdBy.last_name }}</td>
                    <td>
                        <span class="badge bg-info">{{ newsletter.recipient_count }}</span>
                    </td>
                    <td>{{ newsletter.created_at|date('d.m.Y H:i') }}</td>
                    <td>
                        {% if newsletter.status == 'draft' %}
                            <span class="badge bg-secondary">Entwurf</span>
                        {% elseif newsletter.status == 'sent' %}
                            <span class="badge bg-success">Versendet</span>
                        {% elseif newsletter.status == 'archived' %}
                            <span class="badge bg-dark">Archiv</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if newsletter.status == 'draft' %}
                            <a href="/newsletters/{{ newsletter.id }}/edit?project_id={{ project.id }}"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Bearbeiten
                            </a>
                        {% endif %}
                        <a href="/newsletters/{{ newsletter.id }}/preview"
                           class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-eye"></i> Vorschau
                        </a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i>
        Keine Newsletter in dieser Kategorie vorhanden.
    </div>
    {% endif %}
</div>
{% endblock %}
