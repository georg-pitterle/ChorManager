{% extends is_modal|default(false) ? 'layout_modal.twig' : 'layout.twig' %}

{% block title %}
    Newsletter erstellen - {{ app_settings.app_name|default('Chor-Manager') }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Bereiche</p>
            <h1 class="h2 mb-1">Neuer Newsletter</h1>
            <p class="text-muted mb-0">
                Projekt: <strong>{{ project.name }}</strong>
            </p>
        </div>
        <div class="page-actions">
            <a href="/newsletters?project_id={{ project.id }}&status=draft"
               class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Zurück zur Übersicht
            </a>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    <div class="container-fluid px-0">
        <form id="create-newsletter-form"
              method="post"
              action="/newsletters"
              data-is-modal="{{ is_modal|default(false) ? '1' : '0' }}">
            {% if is_modal|default(false) %}<input type="hidden" name="modal" value="1">{% endif %}
            <div class="dashboard-shell">
                <section class="dashboard-section dashboard-section--actions"
                         aria-labelledby="newsletter-create-settings-title">
                    <div class="dashboard-section-head">
                        <h2 class="dashboard-section-title" id="newsletter-create-settings-title">Newsletter-Einstellungen</h2>
                        <p class="dashboard-section-lead mb-0">Projekt, Titel, Empfängerquellen und optionale Vorlage festlegen.</p>
                    </div>

                    <div class="surface-card form-surface card border-0">
                        <div class="card-body">
                            <div class="mb-3">
                                <label for="project_id" class="form-label">
                                    Projekt <span class="text-danger">*</span>
                                </label>
                                <select class="form-select" id="project_id" name="project_id" required>
                                    {% for selectable_project in projects %}
                                        <option value="{{ selectable_project.id }}"
                                                {% if selectable_project.id == project.id %}selected{% endif %}>
                                            {{ selectable_project.name }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="title" class="form-label">
                                    Titel <span class="text-danger">*</span>
                                </label>
                                <input type="text"
                                       class="form-control"
                                       id="title"
                                       name="title"
                                       placeholder="z.B. Januar Newsletter 2026"
                                       required>
                            </div>

                            {% set default_project_source_id = project.id %}
                            <section class="mb-3" id="recipient-sources" aria-labelledby="recipient-sources-title">
                                <h3 class="h6" id="recipient-sources-title">Empfängerquellen</h3>

                                <div class="mb-3" data-source-type="project_members">
                                    <label class="form-label d-flex justify-content-between align-items-center">
                                        <span>Projektmitglieder</span>
                                        <span class="badge bg-secondary" id="source-project-members-count">1</span>
                                    </label>
                                    <div class="dropdown newsletter-source-dropdown">
                                        <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start"
                                                type="button"
                                                data-bs-toggle="dropdown"
                                                data-bs-auto-close="outside"
                                                aria-expanded="false">
                                            Projekte auswählen
                                        </button>
                                        <div class="dropdown-menu p-2 newsletter-source-dropdown-menu">
                                            {% for selectable_project in projects %}
                                                <div class="form-check">
                                                    <input class="form-check-input newsletter-source-option"
                                                           type="checkbox"
                                                           data-source-type="project_members"
                                                           value="{{ selectable_project.id }}"
                                                           id="create-source-project-{{ selectable_project.id }}"
                                                           {% if selectable_project.id == default_project_source_id %}checked{% endif %}>
                                                    <label class="form-check-label"
                                                           for="create-source-project-{{ selectable_project.id }}">
                                                        {{ selectable_project.name }}
                                                    </label>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                    <div class="form-text">Mehrfachauswahl per Klick. Dropdown bleibt zum schnellen Auswählen geöffnet.</div>
                                </div>

                                <div class="mb-3" data-source-type="event_attendees">
                                    <label class="form-label d-flex justify-content-between align-items-center">
                                        <span>Veranstaltungsteilnehmer</span>
                                        <span class="badge bg-secondary" id="source-event-attendees-count">0</span>
                                    </label>
                                    <div class="dropdown newsletter-source-dropdown">
                                        <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start"
                                                type="button"
                                                data-bs-toggle="dropdown"
                                                data-bs-auto-close="outside"
                                                aria-expanded="false">
                                            Veranstaltungen auswählen
                                        </button>
                                        <div class="dropdown-menu p-2 newsletter-source-dropdown-menu">
                                            {% for event in events %}
                                                <div class="form-check">
                                                    <input class="form-check-input newsletter-source-option"
                                                           type="checkbox"
                                                           data-source-type="event_attendees"
                                                           value="{{ event.id }}"
                                                           id="create-source-event-{{ event.id }}">
                                                    <label class="form-check-label" for="create-source-event-{{ event.id }}">
                                                        {{ event.title }} ({{ event.starts_at|date('d.m.Y') }}) - {{ event.project.name }}
                                                    </label>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3" data-source-type="role">
                                    <label class="form-label d-flex justify-content-between align-items-center">
                                        <span>Rollen</span>
                                        <span class="badge bg-secondary" id="source-roles-count">0</span>
                                    </label>
                                    <div class="dropdown newsletter-source-dropdown">
                                        <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start"
                                                type="button"
                                                data-bs-toggle="dropdown"
                                                data-bs-auto-close="outside"
                                                aria-expanded="false">
                                            Rollen auswählen
                                        </button>
                                        <div class="dropdown-menu p-2 newsletter-source-dropdown-menu">
                                            {% for role in roles %}
                                                <div class="form-check">
                                                    <input class="form-check-input newsletter-source-option"
                                                           type="checkbox"
                                                           data-source-type="role"
                                                           value="{{ role.id }}"
                                                           id="create-source-role-{{ role.id }}">
                                                    <label class="form-check-label" for="create-source-role-{{ role.id }}">
                                                        {{ role.name }}
                                                    </label>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3" data-source-type="user">
                                    <label class="form-label d-flex justify-content-between align-items-center">
                                        <span>Einzelne Mitglieder</span>
                                        <span class="badge bg-secondary" id="source-users-count">0</span>
                                    </label>
                                    <div class="dropdown newsletter-source-dropdown">
                                        <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start"
                                                type="button"
                                                data-bs-toggle="dropdown"
                                                data-bs-auto-close="outside"
                                                aria-expanded="false">
                                            Mitglieder auswählen
                                        </button>
                                        <div class="dropdown-menu p-2 newsletter-source-dropdown-menu">
                                            {% for member in users %}
                                                <div class="form-check">
                                                    <input class="form-check-input newsletter-source-option"
                                                           type="checkbox"
                                                           data-source-type="user"
                                                           value="{{ member.id }}"
                                                           id="create-source-user-{{ member.id }}">
                                                    <label class="form-check-label" for="create-source-user-{{ member.id }}">
                                                        {{ member.last_name }}, {{ member.first_name }}
                                                    </label>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>

                                <div class="alert alert-info mb-0">
                                    <strong>Empfänger:</strong>
                                    <span class="badge bg-info" id="recipient-count-badge">0</span>
                                    <span class="small text-muted ms-2" id="recipient-count-status"></span>
                                </div>
                            </section>

                            <div class="mb-3">
                                <label for="template" class="form-label">Vorlage laden (optional)</label>
                                <select class="form-select" id="template" data-action="load-template">
                                    <option value="">-- Keine Vorlage --</option>
                                    {% for template in templates %}<option value="{{ template.id }}">{{ template.name }}</option>{% endfor %}
                                </select>
                            </div>
                        </div>
                    </div>
                </section>
                <section class="dashboard-section dashboard-section--actions"
                         aria-labelledby="newsletter-create-content-title">
                    <div class="dashboard-section-head">
                        <h2 class="dashboard-section-title" id="newsletter-create-content-title">Inhalt</h2>
                        <p class="dashboard-section-lead mb-0">Erstelle den Newsletter-Inhalt im Editor.</p>
                    </div>

                    <div class="surface-card form-surface card border-0">
                        <div class="card-body">
                            <textarea id="content_html" name="content_html" class="tinymce-editor"></textarea>
                        </div>
                    </div>
                </section>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                <a href="/newsletters?project_id={{ project.id }}&status=draft"
                   class="btn btn-outline-secondary">
                    <i class="bi bi-x-circle"></i> Abbrechen
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle"></i> Erstellen als Entwurf
                </button>
            </div>
        </form>
    </div>

{% endblock content %}

{% block scripts %}
    <script src="{{ asset_path('/js/newsletters-create.js') }}"></script>
{% endblock scripts %}
