{% extends is_modal|default(false) ? 'layout_modal.twig' : 'layout.twig' %}

{% block title %}
    Newsletter-Vorschau ({{ newsletter.title }}) - {{ app_settings.app_name|default('Chor-Manager') }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Bereiche</p>
            <h1 class="h2 mb-1">Newsletter-Vorschau</h1>
            <p class="text-muted mb-0">{{ newsletter.title }}</p>
        </div>
        <div class="page-actions">
            <a href="/newsletters?project_id={{ newsletter.project_id }}&status={{ newsletter.status == 'sent' ? 'sent' : 'draft' }}"
               class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-x-circle"></i> Schließen
            </a>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    <div class="container-fluid px-0">
        <div class="row">
            <div class="col-12">
                <div class="surface-card card border-0">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-1">{{ newsletter.title }}</h5>
                            <small class="text-muted">
                                Von: {{ newsletter.createdBy.first_name }} {{ newsletter.createdBy.last_name }}
                                | Erstellt: {{ newsletter.created_at|date("d.m.Y H:i") }}
                            </small>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="newsletter-content newsletter-content-preview">{{ preview_content_html|raw }}</div>
                    </div>
                    <div class="card-footer">
                        <div class="text-muted text-center">
                            <small>
                                Empfänger: <strong class="badge bg-info">{{ newsletter.recipient_count }}</strong>
                                | Status: <strong>{{ newsletter.status }}</strong>
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock content %}
