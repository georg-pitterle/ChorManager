{% extends 'layout.twig' %}

{% block title %}Newsletter-Vorschau ({{ newsletter.title }}){% endblock %}

{% block page_header %}
<section class="page-header">
    <div>
        <p class="text-uppercase text-muted small mb-1">Kommunikation</p>
        <h1 class="h2 mb-1">Newsletter-Vorschau</h1>
        <p class="text-muted mb-0">{{ newsletter.title }}</p>
    </div>
    <div class="page-actions">
        <a href="/newsletters?project_id={{ newsletter.project_id }}&status={{ newsletter.status == 'sent' ? 'sent' : 'draft' }}"
           class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-x-circle"></i> Schließen
        </a>
    </div>
</section>
{% endblock %}

{% block content %}
<div class="container">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="surface-card card border-0">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1">{{ newsletter.title }}</h5>
                        <small class="text-muted">
                            Von: {{ newsletter.createdBy.first_name }} {{ newsletter.createdBy.last_name }}
                            | Erstellt: {{ newsletter.created_at|date('d.m.Y H:i') }}
                        </small>
                    </div>
                </div>
                <div class="card-body">
                    <div class="newsletter-content" style="background-color: #f8f9fa; padding: 20px; border-radius: 4px;">
                        {{ newsletter.content_html|raw }}
                    </div>
                </div>
                <div class="card-footer">
                    <div class="text-muted text-center">
                        <small>
                            Empfänger: <strong class="badge bg-info">{{ newsletter.recipient_count }}</strong>
                            | Status: <strong>{{ newsletter.status }}</strong>
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .newsletter-content img {
        max-width: 100%;
        height: auto;
    }

    .newsletter-content table {
        width: 100%;
        border-collapse: collapse;
    }

    .newsletter-content table, .newsletter-content th, .newsletter-content td {
        border: 1px solid #ddd;
    }

    .newsletter-content th, .newsletter-content td {
        padding: 12px;
        text-align: left;
    }

    .newsletter-content th {
        background-color: #f2f2f2;
    }
</style>
{% endblock %}
