{% extends "layout.twig" %}

{% block title %}Newsletter-Archiv{% endblock %}

{% block content %}
<div class="container mt-4">
    <h1>Meine Newsletter</h1>
    <p class="text-muted">Alle Newsletter, die an Sie versendet wurden</p>

    {% if archived_newsletters|length > 0 %}
    <div class="row">
        {% for archive_item in archived_newsletters %}
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-1">{{ archive_item.newsletter.title }}</h6>
                    <small class="text-muted">
                        {{ archive_item.sent_at|date('d.m.Y H:i') }}
                        {% if archive_item.read_at %}
                            | Gelesen: {{ archive_item.read_at|date('d.m.Y H:i') }}
                        {% else %}
                            | <span class="badge bg-warning">Ungelesen</span>
                        {% endif %}
                    </small>
                </div>
                <div class="card-body" style="max-height: 200px; overflow: hidden;">
                    <div style="opacity: 0.8;">
                        {{ archive_item.newsletter.content_html|striptags|slice(0, 150) }}...
                    </div>
                </div>
                <div class="card-footer">
                    <button type="button" class="btn btn-sm btn-outline-primary"
                            data-bs-toggle="modal" data-bs-target="#archiveModal{{ archive_item.id }}">
                        <i class="bi bi-eye"></i> Volltext anzeigen
                    </button>
                </div>
            </div>
        </div>

        <!-- Modal -->
        <div class="modal fade" id="archiveModal{{ archive_item.id }}" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">{{ archive_item.newsletter.title }}</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        {{ archive_item.newsletter.content_html|raw }}
                    </div>
                    <div class="modal-footer">
                        <small class="text-muted">
                            Versendet: {{ archive_item.sent_at|date('d.m.Y H:i') }}
                        </small>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            Schließen
                        </button>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i>
        Noch keine Newsletter erhalten.
    </div>
    {% endif %}
</div>
{% endblock %}
