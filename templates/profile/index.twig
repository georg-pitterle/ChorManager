{% extends "layout.twig" %}

{% block title %}
    Mein Profil - {{ app_settings.app_name|default('Chor-Manager') }}
{% endblock title %}

{% block content %}
    <div class="row mt-4 mb-3">
        <div class="col-12">
            <h1>Mein Profil</h1>
        </div>
    </div>

    {% if success %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ success }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}
    {% if error %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ error }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}

    <div class="row">
        <!-- User Info Card -->
        <div class="col-md-5 mb-4 mb-md-0">
            <div class="card shadow-sm h-100">
                <div class="card-header">
                    <h5 class="mb-0">Persönliche Informationen</h5>
                </div>
                <div class="card-body">
                    <form action="/profile" method="post">
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label for="first_name"
                                       class="form-label text-muted small fw-bold text-uppercase">Vorname</label>
                                <input type="text"
                                       class="form-control"
                                       id="first_name"
                                       name="first_name"
                                       value="{{ user.first_name }}"
                                       required>
                            </div>
                            <div class="col-6 mb-3">
                                <label for="last_name"
                                       class="form-label text-muted small fw-bold text-uppercase">Nachname</label>
                                <input type="text"
                                       class="form-control"
                                       id="last_name"
                                       name="last_name"
                                       value="{{ user.last_name }}"
                                       required>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label for="email"
                                   class="form-label text-muted small fw-bold text-uppercase">E-Mail Adresse</label>
                            <input type="email"
                                   class="form-control"
                                   id="email"
                                   name="email"
                                   value="{{ user.email }}"
                                   required>
                        </div>

                        <div class="d-grid justify-content-md-end mb-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-person-check"></i> Profil speichern
                            </button>
                        </div>
                    </form>

                    <hr>

                    <div class="row mt-4">
                        <div class="col-6 mb-3">
                            <label class="text-muted small fw-bold text-uppercase">Rolle(n)</label>
                            <p class="fs-5 mb-0">
                                {% for role in user.roles %}
                                    <span class="badge bg-primary">{{ role.name }}</span>
                                {% else %}
                                    -
                                {% endfor %}
                            </p>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="text-muted small fw-bold text-uppercase">Stimmgruppe(n)</label>
                            <p class="fs-5 mb-0">
                                {% if user.voice_group_ids|length > 0 %}
                                    {% for group_id in user.voice_group_ids %}
                                        {% for g in voice_groups %}
                                            {% if g.id == group_id %}
                                                <span class="d-inline-block border p-1 rounded mb-1 text-nowrap fs-6">
                                                    {{ g.name }}
                                                    {% set sv_id = user.voice_group_pivots[group_id] %}
                                                    {% if sv_id %}
                                                        {% for sv in sub_voices %}
                                                            {% if sv.id == sv_id %}<small class="text-muted">({{ sv.name }})</small>{% endif %}
                                                        {% endfor %}
                                                    {% endif %}
                                                </span>
                                                <br>
                                            {% endif %}
                                        {% endfor %}
                                    {% endfor %}
                                {% else %}
                                    -
                                {% endif %}
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Change Password Card -->
        <div class="col-md-7">
            <div class="card shadow-sm h-100">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-key"></i> Passwort ändern
                    </h5>
                </div>
                <div class="card-body">
                    <form action="/profile/password" method="post">

                        <div class="mb-4">
                            <label for="old_password" class="form-label">Aktuelles Passwort</label>
                            <input type="password"
                                   class="form-control"
                                   id="old_password"
                                   name="old_password"
                                   required>
                        </div>
                        <hr>

                        <div class="mb-3">
                            <label for="new_password" class="form-label">Neues Passwort</label>
                            <input type="password"
                                   class="form-control"
                                   id="new_password"
                                   name="new_password"
                                   required
                                   minlength="6">
                            <div class="form-text">Das Passwort muss aus mindestens 6 Zeichen bestehen.</div>
                        </div>

                        <div class="mb-4">
                            <label for="new_password_confirm" class="form-label">Neues Passwort bestätigen</label>
                            <input type="password"
                                   class="form-control"
                                   id="new_password_confirm"
                                   name="new_password_confirm"
                                   required
                                   minlength="6">
                        </div>

                        <div class="d-grid justify-content-md-end">
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-arrow-repeat"></i> Passwort aktualisieren
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <!-- Mailbox Card -->
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-envelope"></i> Mailbox / Webmail-Zugang
                    </h5>
                </div>
                <div class="card-body">
                    <form action="/profile/mailbox" method="post">
                        <div class="mb-3">
                            <label for="imap_host" class="form-label text-muted small fw-bold text-uppercase">Host</label>
                            <input type="text"
                                   class="form-control"
                                   id="imap_host"
                                   name="imap_host"
                                   value="{{ mail_account.imap_host|default('') }}"
                                   maxlength="255"
                                   required>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label for="imap_port"
                                       class="form-label text-muted small fw-bold text-uppercase">Port</label>
                                <input type="number"
                                       class="form-control"
                                       id="imap_port"
                                       name="imap_port"
                                       value="{{ mail_account.imap_port|default('') }}"
                                       placeholder="993"
                                       min="1"
                                       max="65535"
                                       required>
                            </div>
                            <div class="col-6 mb-3">
                                <label for="imap_encryption"
                                       class="form-label text-muted small fw-bold text-uppercase">Verschlüsselung</label>
                                {% set _encryption = mail_account.imap_encryption|default('ssl') %}
                                <select class="form-select" id="imap_encryption" name="imap_encryption" required>
                                    <option value="ssl" {{ _encryption == 'ssl' ? 'selected' : '' }}>SSL</option>
                                    <option value="tls" {{ _encryption == 'tls' ? 'selected' : '' }}>TLS</option>
                                    <option value="none" {{ _encryption == 'none' ? 'selected' : '' }}>Keine</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="imap_username"
                                   class="form-label text-muted small fw-bold text-uppercase">Benutzername</label>
                            <input type="text"
                                   class="form-control"
                                   id="imap_username"
                                   name="imap_username"
                                   value="{{ mail_account.imap_username|default('') }}"
                                   maxlength="255"
                                   required>
                        </div>
                        <div class="mb-3">
                            <label for="imap_password" class="form-label">Passwort</label>
                            <input type="password" class="form-control" id="imap_password" name="imap_password">
                            {% if has_saved_account %}
                                <div class="form-text">Gespeichert – leer lassen, um aktuelles Passwort zu behalten.</div>
                            {% endif %}
                        </div>
                        <hr class="my-3">
                        <p class="text-muted small fw-bold text-uppercase mb-2">SMTP (optional, zum Versenden)</p>
                        <div class="mb-3">
                            <label for="smtp_host" class="form-label text-muted small fw-bold text-uppercase">SMTP-Host</label>
                            <input type="text"
                                   class="form-control"
                                   id="smtp_host"
                                   name="smtp_host"
                                   value="{{ mail_account.smtp_host|default('') }}"
                                   maxlength="255"
                                   placeholder="z. B. send.one.com">
                        </div>
                        <div class="row mb-3">
                            <div class="col-6">
                                <label for="smtp_port" class="form-label text-muted small fw-bold text-uppercase">SMTP-Port</label>
                                <input type="number"
                                       class="form-control"
                                       id="smtp_port"
                                       name="smtp_port"
                                       value="{{ mail_account.smtp_port|default('') }}"
                                       placeholder="587"
                                       min="1"
                                       max="65535">
                            </div>
                            <div class="col-6">
                                <label for="smtp_encryption" class="form-label text-muted small fw-bold text-uppercase">Verschlüsselung</label>
                                {% set _smtp_enc = mail_account.smtp_encryption|default('tls') %}
                                <select class="form-select" id="smtp_encryption" name="smtp_encryption">
                                    <option value="ssl" {{ _smtp_enc == 'ssl' ? 'selected' : '' }}>SSL</option>
                                    <option value="tls" {{ _smtp_enc == 'tls' ? 'selected' : '' }}>TLS</option>
                                    <option value="none" {{ _smtp_enc == 'none' ? 'selected' : '' }}>Keine</option>
                                </select>
                            </div>
                        </div>
                        <hr class="my-3">
                        <div class="form-check mb-2">
                            <input type="checkbox"
                                   class="form-check-input"
                                   id="imap_enabled"
                                   name="imap_enabled"
                                   {{ mail_account.imap_enabled ? 'checked' : '' }}>
                            <label class="form-check-label" for="imap_enabled">Aktiv</label>
                        </div>
                        <div class="form-check mb-4">
                            <input type="checkbox"
                                   class="form-check-input"
                                   id="mail_badge_enabled"
                                   name="mail_badge_enabled"
                                   {{ mail_account.mail_badge_enabled ? 'checked' : '' }}>
                            <label class="form-check-label" for="mail_badge_enabled">Badge anzeigen</label>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <button type="submit"
                                    class="btn btn-outline-secondary"
                                    formaction="/profile/mailbox/test">
                                <i class="bi bi-plug"></i> Verbindung testen
                            </button>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-envelope-check"></i> Mailbox speichern
                            </button>
                        </div>
                    </form>

                    {% if webmail_available %}
                        <hr>
                        <form action="/profile/webmail/start" method="post" target="_blank" rel="noopener noreferrer">
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-box-arrow-up-right"></i> Webmail öffnen
                                </button>
                            </div>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock content %}
