{% extends "layout.twig" %}

{% block title %}Sponsoring - Chor Manager{% endblock %}

{% block content %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 border-bottom mt-4">
    <h1 class="h2"><i class="bi bi-briefcase me-2"></i>Sponsoring</h1>
    <div class="btn-group">
        <a href="/sponsoring/sponsors" class="btn btn-outline-secondary btn-sm"><i class="bi bi-people me-1"></i> Sponsoren</a>
        <a href="/sponsoring/packages" class="btn btn-outline-secondary btn-sm"><i class="bi bi-box-seam me-1"></i> Pakete</a>
    </div>
</div>

{# KPI-Karten #}
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <i class="bi bi-people-fill fs-2 text-success"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Aktive Sponsoren</div>
                        <div class="fs-3 fw-bold">{{ total_active }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <i class="bi bi-cash-coin fs-2 text-primary"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Gesamtbetrag aktiv</div>
                        <div class="fs-3 fw-bold">{{ total_amount|number_format(2, '.', ',') }} €</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <i class="bi bi-graph-up-arrow fs-2 text-warning"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Pipeline (in Verhandlung)</div>
                        <div class="fs-3 fw-bold">{{ pipeline|number_format(2, '.', ',') }} €</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 me-3">
                        <i class="bi bi-bell-fill fs-2 {% if open_follow_ups > 0 %}text-danger{% else %}text-secondary{% endif %}"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Fällige Wiedervorlagen</div>
                        <div class="fs-3 fw-bold">
                            {{ open_follow_ups }}
                            {% if open_follow_ups > 0 %}
                            <span class="badge bg-danger ms-1">!</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# Fällige Wiedervorlagen #}
{% if upcoming_follow_ups|length > 0 %}
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white border-bottom fw-semibold">
        <i class="bi bi-alarm me-1 text-danger"></i> Wiedervorlagen (fällig / nächste 7 Tage)
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Datum</th>
                    <th>Sponsor</th>
                    <th>Vereinbarung</th>
                    <th>Zuständig</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for contact in upcoming_follow_ups %}
                <tr {% if contact.follow_up_date.format('Y-m-d') <= date().format('Y-m-d') %}class="table-warning"{% endif %}>
                    <td class="text-nowrap">{{ contact.follow_up_date ? contact.follow_up_date.format('d.m.Y') : '' }}</td>
                    <td>
                        <a href="/sponsoring/sponsors/{{ contact.sponsor.id }}">{{ contact.sponsor.name }}</a>
                    </td>
                    <td>{{ contact.sponsorship ? contact.sponsorship.id : '–' }}</td>
                    <td>{{ contact.user ? contact.user.first_name ~ ' ' ~ contact.user.last_name : '–' }}</td>
                    <td>
                        <form method="post" action="/sponsoring/contacts/{{ contact.id }}/done" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-success">
                                <i class="bi bi-check-lg"></i> Erledigt
                            </button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{# Letzte Kontakte #}
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom fw-semibold">
        <i class="bi bi-clock-history me-1"></i> Letzte Kontakte
    </div>
    {% if recent_contacts|length > 0 %}
    <div class="table-responsive">
        <table class="table table-sm table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Datum</th>
                    <th>Sponsor</th>
                    <th>Art</th>
                    <th>Zusammenfassung</th>
                    <th>Protokolliert von</th>
                </tr>
            </thead>
            <tbody>
                {% for contact in recent_contacts %}
                <tr>
                    <td class="text-nowrap">{{ contact.contact_date ? contact.contact_date.format('d.m.Y') : '' }}</td>
                    <td>
                        <a href="/sponsoring/sponsors/{{ contact.sponsor.id }}">{{ contact.sponsor.name }}</a>
                    </td>
                    <td>
                        {% if contact.type == 'call' %}<i class="bi bi-telephone" title="Anruf"></i>
                        {% elseif contact.type == 'email' %}<i class="bi bi-envelope" title="E-Mail"></i>
                        {% elseif contact.type == 'meeting' %}<i class="bi bi-people" title="Treffen"></i>
                        {% elseif contact.type == 'letter' %}<i class="bi bi-file-text" title="Brief"></i>
                        {% else %}<i class="bi bi-chat-dots" title="Sonstiges"></i>{% endif %}
                        <span class="ms-1 d-none d-md-inline">
                            {% if contact.type == 'call' %}Anruf
                            {% elseif contact.type == 'email' %}E-Mail
                            {% elseif contact.type == 'meeting' %}Treffen
                            {% elseif contact.type == 'letter' %}Brief
                            {% else %}Sonstiges{% endif %}
                        </span>
                    </td>
                    <td class="text-truncate" style="max-width:300px;">{{ contact.summary }}</td>
                    <td>{{ contact.user ? contact.user.first_name ~ ' ' ~ contact.user.last_name : '–' }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="card-body text-muted">Noch keine Kontakte vorhanden.</div>
    {% endif %}
</div>
{% endblock %}
