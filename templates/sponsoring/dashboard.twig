{% extends 'layout.twig' %}

{% block title %}Sponsoring - Chor Manager{% endblock %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Kommunikation</p>
            <h1 class="h2 mb-1">
                <i class="bi bi-briefcase me-2"></i>Sponsoring
            </h1>
            <p class="text-muted mb-0">Sponsoren, Pakete und Kontaktverlauf an einem Ort steuern.</p>
        </div>
        <div class="page-actions d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center gap-2">
            <a href="/sponsoring/sponsors" class="btn btn-outline-secondary btn-sm"><i class="bi bi-people me-1"></i> Sponsoren</a>
            <a href="/sponsoring/packages" class="btn btn-outline-secondary btn-sm"><i class="bi bi-box-seam me-1"></i> Pakete</a>
        </div>
    </section>
{% endblock %}

{% block content %}
    {# KPI-Karten #}
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 me-3">
                            <i class="bi bi-people-fill fs-2 text-success"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Aktive Sponsoren</div>
                            <div class="fs-3 fw-bold">{{ total_active }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 me-3">
                            <i class="bi bi-cash-coin fs-2 text-primary"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Gesamtbetrag aktiv</div>
                            <div class="fs-3 fw-bold">{{ total_amount|number_format(2, '.', ',') }} €</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 me-3">
                            <i class="bi bi-graph-up-arrow fs-2 text-warning"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Pipeline (in Verhandlung)</div>
                            <div class="fs-3 fw-bold">{{ pipeline|number_format(2, '.', ',') }} €</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 me-3">
                            <i class="bi bi-bell-fill fs-2
                                      {% if open_follow_ups > 0 %}
                                          text-danger
                                      {% else %}
                                          text-secondary
                                      {% endif %}"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Fällige Wiedervorlagen</div>
                            <div class="fs-3 fw-bold">
                                {{ open_follow_ups }}
                                {% if open_follow_ups > 0 %}<span class="badge bg-danger ms-1">!</span>{% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Fällige Wiedervorlagen #}
    <div class="card border-0 shadow-sm mb-4 table-shell"
         data-table-engine="true"
         data-table-id="sponsoring.dashboard.followups"
         data-default-view="auto"
         data-default-page-size="100"
         data-page-size-options="25,50,100,200"
         data-default-sort-key="follow_up_date">
        <div class="card-header bg-white border-bottom fw-semibold">
            <i class="bi bi-alarm me-1 text-danger"></i> Wiedervorlagen (fällig / nächste 7 Tage)
        </div>
        {% if upcoming_follow_ups|length > 0 %}
            {{ include('partials/table_toolbar.twig') }}
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0 align-middle table-responsive-cards"
                       id="sponsoringFollowUpsTable">
                    <thead class="table-light">
                        <tr>
                            <th data-sort-key="follow_up_date" data-sort-type="date">Datum</th>
                            <th data-sort-key="sponsor_name" data-sort-type="text">Sponsor</th>
                            <th data-sort-key="agreement_amount" data-sort-type="number">Vereinbarung</th>
                            <th data-sort-key="owner_name" data-sort-type="text">Zuständig</th>
                            <th class="text-end">Aktionen</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for contact in upcoming_follow_ups %}
                            <tr data-sort-follow_up_date="{{ contact.follow_up_date_sort }}"
                                data-sort-sponsor_name="{{ contact.sponsor_name|lower }}"
                                data-sort-agreement_amount="{{ contact.agreement_amount_sort }}"
                                data-sort-owner_name="{{ contact.owner_name_sort }}"
                                {% if contact.is_overdue %}class="table-warning"{% endif %}>
                                <td data-label="Datum" class="text-nowrap">{{ contact.follow_up_date_display }}</td>
                                <td data-label="Sponsor">
                                    {% if contact.sponsor_url %}
                                        <a href="{{ contact.sponsor_url }}">{{ contact.sponsor_name }}</a>
                                    {% else %}
                                        {{ contact.sponsor_name }}
                                    {% endif %}
                                </td>
                                <td data-label="Vereinbarung">
                                    {% if contact.agreement_package_name == '-' %}
                                        -
                                    {% else %}
                                        <div class="fw-semibold">{{ contact.agreement_package_name }}</div>
                                        <div class="small text-muted">{{ contact.agreement_amount_display }} | {{ contact.agreement_status_label }}</div>
                                    {% endif %}
                                </td>
                                <td data-label="Zuständig">{{ contact.owner_name }}</td>
                                <td data-label="Aktionen" class="text-end">
                                    <form method="post" action="{{ contact.mark_done_url }}" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-success">
                                            <i class="bi bi-check-lg"></i> Erledigt
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="card-body text-muted">Keine Wiedervorlagen in den nächsten 7 Tagen vorhanden.</div>
        {% endif %}
    </div>

    {# Letzte Kontakte #}
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom fw-semibold">
            <i class="bi bi-clock-history me-1"></i> Letzte Kontakte
        </div>
        {% if recent_contacts|length > 0 %}
            <div class="table-shell"
                 data-table-engine="true"
                 data-table-id="sponsoring.dashboard.recent_contacts"
                 data-default-view="auto"
                 data-default-page-size="100"
                 data-page-size-options="25,50,100,200"
                 data-default-sort-key="contact_date"
                 data-default-sort-dir="desc">
                {{ include('partials/table_toolbar.twig') }}
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0 align-middle table-responsive-cards"
                           id="sponsoringRecentContactsTable">
                        <thead class="table-light">
                            <tr>
                                <th data-sort-key="contact_date" data-sort-type="date">Datum</th>
                                <th data-sort-key="sponsor_name" data-sort-type="text">Sponsor</th>
                                <th data-sort-key="contact_type" data-sort-type="text">Art</th>
                                <th>Zusammenfassung</th>
                                <th data-sort-key="owner_name" data-sort-type="text">Protokolliert von</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for contact in recent_contacts %}
                                <tr data-sort-contact_date="{{ contact.contact_date_sort }}"
                                    data-sort-sponsor_name="{{ contact.sponsor_name|lower }}"
                                    data-sort-contact_type="{{ contact.contact_type_sort }}"
                                    data-sort-owner_name="{{ contact.owner_name_sort }}">
                                    <td data-label="Datum" class="text-nowrap">{{ contact.contact_date_display }}</td>
                                    <td data-label="Sponsor">
                                        {% if contact.sponsor_url %}
                                            <a href="{{ contact.sponsor_url }}">{{ contact.sponsor_name }}</a>
                                        {% else %}
                                            {{ contact.sponsor_name }}
                                        {% endif %}
                                    </td>
                                    <td data-label="Art">
                                        {% if contact.contact_type_sort == 'call' %}
                                            <i class="bi bi-telephone" title="Anruf"></i>
                                        {% elseif contact.contact_type_sort == 'email' %}
                                            <i class="bi bi-envelope" title="E-Mail"></i>
                                        {% elseif contact.contact_type_sort == 'meeting' %}
                                            <i class="bi bi-people" title="Treffen"></i>
                                        {% elseif contact.contact_type_sort == 'letter' %}
                                            <i class="bi bi-file-text" title="Brief"></i>
                                        {% else %}
                                            <i class="bi bi-chat-dots" title="Sonstiges"></i>
                                        {% endif %}
                                        <span class="ms-1 d-none d-md-inline">{{ contact.contact_type_label }}</span>
                                    </td>
                                    <td data-label="Zusammenfassung" class="table-summary-cell">
                                        <span class="table-summary-content">{{ contact.summary }}</span>
                                    </td>
                                    <td data-label="Protokolliert von">{{ contact.owner_name }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% else %}
            <div class="card-body text-muted">Noch keine Kontakte vorhanden.</div>
        {% endif %}
    </div>
{% endblock %}
