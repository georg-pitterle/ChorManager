{% extends "layout.twig" %}

{% block title %}
    Sponsoren - {{ app_settings.app_name|default("Chor-Manager") }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Kommunikation</p>
            <h1 class="h2 mb-1">
                <i class="bi bi-people me-2"></i>Sponsoren
            </h1>
            <p class="text-muted mb-0">Sponsorenstammdaten und Vereinbarungen verwalten.</p>
        </div>
        <div class="page-actions d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center gap-2">
            <a href="/sponsoring" class="btn btn-outline-secondary btn-sm"><i class="bi bi-house me-1"></i> Dashboard</a>
            <button class="btn btn-primary btn-sm"
                    data-bs-toggle="modal"
                    data-bs-target="#createSponsorModal">
                <i class="bi bi-plus-lg"></i> Neuer Sponsor
            </button>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    {% if success %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ success }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}
    {% if error %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ error }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}

    {# Filter #}
    <section class="surface-card filter-surface p-3 mb-3">
        <form method="get" action="/sponsoring/sponsors" class="row g-2 mb-0">
            <div class="col-sm-5 col-md-4">
                <input type="text"
                       name="q"
                       class="form-control form-control-sm"
                       placeholder="Suche (Name, Kontakt, E-Mail)..."
                       value="{{ q }}">
            </div>
            <div class="col-sm-4 col-md-3">
                <select name="status" class="form-select form-select-sm">
                    <option value="">– Alle Status –</option>
                    {% for s in statuses %}
                        <option value="{{ s }}" {{ s == status ? 'selected' : '' }}>{{ s|capitalize }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-secondary btn-sm">
                    <i class="bi bi-funnel"></i> Filtern
                </button>
                {% if q or status %}
                    <a href="/sponsoring/sponsors"
                       class="btn btn-outline-secondary btn-sm ms-1"><i class="bi bi-x"></i> Zurücksetzen</a>
                {% endif %}
            </div>
        </form>
    </section>

    <div class="surface-card table-shell"
         data-table-engine="true"
         data-table-id="sponsoring.sponsors.index"
         data-default-view="auto"
         data-default-page-size="100"
         data-page-size-options="25,50,100,200"
         data-default-sort-key="sponsor_name">
        {{ include("partials/table_toolbar.twig") }}
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 table-responsive-cards"
                   id="sponsorsTable">
                <thead class="table-light">
                    <tr>
                        <th data-sort-key="sponsor_name" data-sort-type="text">Name</th>
                        <th data-sort-key="category" data-sort-type="text">Typ</th>
                        <th data-sort-key="status" data-sort-type="text">Status</th>
                        <th>E-Mail</th>
                        <th>Telefon</th>
                        <th data-sort-key="sponsorship_count" data-sort-type="number">Vereinbarungen</th>
                        <th class="text-end">Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    {% for sponsor in sponsors %}
                        <tr data-sort-sponsor_name="{{ sponsor.name|lower }}"
                            data-sort-category="{{ sponsor.type == 'organization' ? 'organisation' : 'einzelperson' }}"
                            data-sort-status="{{ sponsor.status|lower }}"
                            data-sort-sponsorship_count="{{ sponsor.sponsorships|length }}">
                            <td data-label="Name">
                                <a href="/sponsoring/sponsors/{{ sponsor.id }}"
                                   class="fw-semibold text-decoration-none">{{ sponsor.name }}</a>
                                {% if sponsor.contact_person %}<div class="text-muted small">{{ sponsor.contact_person }}</div>{% endif %}
                            </td>
                            <td data-label="Typ">
                                {% if sponsor.type == 'organization' %}
                                    <i class="bi bi-building" title="Organisation"></i>
                                {% else %}
                                    <i class="bi bi-person" title="Einzelperson"></i>
                                {% endif %}
                            </td>
                            <td data-label="Status">
                                {% set status_colors = {
                                    "prospect": "secondary",
                                    "contacted": "info",
                                    "negotiating": "warning",
                                    "active": "success",
                                    "paused": "secondary",
                                    "closed": "dark"
                                } %}
                                {% set status_labels = {
                                    "prospect": "Interessent",
                                    "contacted": "Kontaktiert",
                                    "negotiating": "Verhandlung",
                                    "active": "Aktiv",
                                    "paused": "Pausiert",
                                    "closed": "Abgeschlossen"
                                } %}
                                <span class="badge bg-{{ status_colors[sponsor.status] ?? 'secondary' }}">{{ status_labels[sponsor.status] ?? sponsor.status }}</span>
                            </td>
                            <td data-label="E-Mail">
                                {% if sponsor.email %}
                                    <a href="mailto:{{ sponsor.email }}" class="text-decoration-none small">{{ sponsor.email }}</a>
                                {% else %}
                                    –
                                {% endif %}
                            </td>
                            <td data-label="Telefon" class="small">{{ sponsor.phone ?? '–' }}</td>
                            <td data-label="Vereinbarungen"
                                data-sort-key="sponsorship_count"
                                data-sort-value="{{ sponsor.sponsorships|length }}">
                                <span class="badge bg-light text-dark border">{{ sponsor.sponsorships|length }}</span>
                            </td>
                            <td data-label="Aktionen" class="text-end text-nowrap">
                                <a href="/sponsoring/sponsors/{{ sponsor.id }}"
                                   class="btn btn-sm btn-outline-secondary"
                                   title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <form method="post"
                                      action="/sponsoring/sponsors/{{ sponsor.id }}/delete"
                                      class="d-inline"
                                      data-confirm="Sponsor {{ sponsor.name }} wirklich löschen? Alle verknüpften Daten werden ebenfalls gelöscht.">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Löschen">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">Keine Sponsoren gefunden.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# Modal: Neuer Sponsor #}
    <div class="modal fade"
         id="createSponsorModal"
         tabindex="-1"
         aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <form method="post" action="/sponsoring/sponsors">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header">
                        <h5 class="modal-title">
                            <i class="bi bi-person-plus me-2"></i>Neuer Sponsor
                        </h5>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Typ</label>
                                <select name="type" class="form-select">
                                    <option value="organization">Organisation / Firma</option>
                                    <option value="person">Einzelperson</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Status</label>
                                <select name="status" class="form-select">
                                    <option value="prospect">Interessent</option>
                                    <option value="contacted">Kontaktiert</option>
                                    <option value="negotiating">Verhandlung</option>
                                    <option value="active">Aktiv</option>
                                    <option value="paused">Pausiert</option>
                                    <option value="closed">Abgeschlossen</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">
                                    Name <span class="text-danger">*</span>
                                </label>
                                <input type="text" name="name" class="form-control" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Kontaktperson</label>
                                <input type="text" name="contact_person" class="form-control">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">E-Mail</label>
                                <input type="email" name="email" class="form-control">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Telefon</label>
                                <input type="text" name="phone" class="form-control">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Website</label>
                                <input type="url"
                                       name="website"
                                       class="form-control"
                                       placeholder="https://...">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Adresse</label>
                                <textarea name="address" class="form-control" rows="2"></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Anlegen
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
{% endblock content %}
