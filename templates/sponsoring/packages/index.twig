{% extends "layout.twig" %}

{% block title %}
    Sponsoring-Pakete - {{ app_settings.app_name|default('Chor-Manager') }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Bereiche</p>
            <h1 class="h2 mb-1">
                <i class="bi bi-box-seam me-2"></i>Sponsoring-Pakete
            </h1>
            <p class="text-muted mb-0">Pakete, Mindestbeträge und Farben zentral verwalten.</p>
        </div>
        <div class="page-actions">
            <a href="/sponsoring" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Zurück zum Dashboard</a>
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    {% if success %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ success }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}
    {% if error %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ error }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}

    <form id="createPackageForm" method="post" action="/sponsoring/packages">
    </form>

    <div class="dashboard-shell">
        <section class="dashboard-section dashboard-section--context"
                 aria-labelledby="packages-list-title">
            <div class="dashboard-section-head">
                <h2 class="dashboard-section-title" id="packages-list-title">Paketübersicht</h2>
                <p class="dashboard-section-lead mb-0">Pakete bearbeiten oder neue Pakete direkt in der Tabelle anlegen.</p>
            </div>

            <div class="surface-card table-shell"
                 data-table-engine="true"
                 data-table-id="sponsoring.packages.index"
                 data-default-view="auto"
                 data-default-page-size="100"
                 data-page-size-options="25,50,100,200"
                 data-default-sort-key="name">
                {{ include('partials/table_toolbar.twig') }}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 table-responsive-cards"
                           id="sponsorPackagesTable">
                        <thead class="table-light">
                            <tr>
                                <th data-sort-key="name" data-sort-type="text">Name</th>
                                <th>Beschreibung</th>
                                <th data-sort-key="min_amount" data-sort-type="number">Mindestbetrag</th>
                                <th data-sort-key="color" data-sort-type="text">Farbe</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for pkg in packages %}
                                <tr data-sort-name="{{ pkg.name|lower }}"
                                    data-sort-min_amount="{{ pkg.min_amount }}"
                                    data-sort-color="{{ pkg.color|lower }}">
                                    <td data-label="Name">
                                        <span class="badge bg-{{ pkg.color }} fs-6">{{ pkg.name }}</span>
                                    </td>
                                    <td data-label="Beschreibung" class="small text-muted">{{ pkg.description ?? '–' }}</td>
                                    <td data-label="Mindestbetrag" class="text-nowrap">{{ pkg.min_amount|number_format(2, '.', ',') }} €</td>
                                    <td data-label="Farbe">
                                        <span class="badge bg-{{ pkg.color }}">{{ pkg.color }}</span>
                                    </td>
                                    <td data-label="Aktionen" class="text-end text-nowrap">
                                        <div class="btn-group"
                                             role="group"
                                             aria-label="Aktionen für Paket {{ pkg.name }}">
                                            <button class="btn btn-sm btn-outline-primary"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#editPackageModal{{ pkg.id }}">
                                                <i class="bi bi-pencil"></i> Bearbeiten
                                            </button>
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-secondary dropdown-toggle dropdown-toggle-split"
                                                    data-bs-toggle="dropdown"
                                                    aria-expanded="false"
                                                    data-bs-boundary="viewport">
                                                <span class="visually-hidden">Weitere Aktionen</span>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <form method="post"
                                                          action="/sponsoring/packages/{{ pkg.id }}/delete"
                                                          data-confirm="Paket {{ pkg.name }} löschen?">
                                                        <button type="submit" class="dropdown-item text-danger">
                                                            <i class="bi bi-trash me-2"></i> Löschen
                                                        </button>
                                                    </form>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">Noch keine Pakete angelegt.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                        <tfoot>
                            <tr class="table-light">
                                <td data-label="Name">
                                    <input type="text"
                                           name="name"
                                           form="createPackageForm"
                                           class="form-control form-control-sm"
                                           placeholder="Name *"
                                           required>
                                </td>
                                <td data-label="Beschreibung">
                                    <input type="text"
                                           name="description"
                                           form="createPackageForm"
                                           class="form-control form-control-sm"
                                           placeholder="Beschreibung">
                                </td>
                                <td data-label="Mindestbetrag">
                                    <input type="number"
                                           name="min_amount"
                                           form="createPackageForm"
                                           class="form-control form-control-sm"
                                           step="0.01"
                                           min="0"
                                           placeholder="0.00">
                                </td>
                                <td data-label="Farbe">
                                    <select name="color"
                                            form="createPackageForm"
                                            class="form-select form-select-sm">
                                        {% for c in ['info', 'primary', 'success', 'warning', 'danger', 'secondary', 'dark'] %}
                                            <option value="{{ c }}">{{ c }}</option>
                                        {% endfor %}
                                    </select>
                                </td>
                                <td data-label="Aktionen" class="text-end">
                                    <button type="submit" form="createPackageForm" class="btn btn-primary btn-sm">
                                        <i class="bi bi-plus-lg me-1"></i>Hinzufügen
                                    </button>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </section>
    </div>

    {% for pkg in packages %}
        <div class="modal fade"
             id="editPackageModal{{ pkg.id }}"
             tabindex="-1"
             aria-hidden="true">
            <div class="modal-dialog">
                <form method="post" action="/sponsoring/packages/{{ pkg.id }}">
                    <div class="modal-content border-0 shadow">
                        <div class="modal-header">
                            <h5 class="modal-title">Paket bearbeiten</h5>
                            <button type="button"
                                    class="btn-close"
                                    data-bs-dismiss="modal"
                                    aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">
                                    Name <span class="text-danger">*</span>
                                </label>
                                <input type="text"
                                       name="name"
                                       class="form-control"
                                       value="{{ pkg.name }}"
                                       required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Beschreibung</label>
                                <textarea name="description" class="form-control" rows="2">{{ pkg.description }}</textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Mindestbetrag (€)</label>
                                <input type="number"
                                       name="min_amount"
                                       class="form-control"
                                       step="0.01"
                                       min="0"
                                       value="{{ pkg.min_amount }}">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Farbe</label>
                                <select name="color" class="form-select">
                                    {% for c in ['primary', 'success', 'warning', 'danger', 'info', 'secondary', 'dark'] %}
                                        <option value="{{ c }}" {{ c == pkg.color ? 'selected' : '' }}>{{ c }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check me-1"></i>Speichern
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    {% endfor %}
{% endblock content %}
