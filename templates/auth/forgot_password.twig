{% extends 'layout.twig' %}

{% block title %}Passwort vergessen - {{ app_settings.app_name|default('Chor Manager') }}{% endblock %}

{% block content %}
<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-lg border-0">
            <div class="login-header text-center">
                <img src="/logo" alt="Logo" height="60" class="mb-2">
                <h2 class="h4 mt-2 font-weight-bold">Passwort zurücksetzen</h2>
                <p class="mb-0 text-white-50">Gib deine E-Mail-Adresse ein und wir schicken dir einen Reset-Link.</p>
            </div>
            <div class="card-body p-4 p-md-5">

                {% if error %}
                    <div class="alert alert-danger" role="alert">
                        {{ error }}
                    </div>
                {% endif %}
                {% if success %}
                    <div class="alert alert-success" role="alert">
                        {{ success }}
                    </div>
                {% endif %}

                <form action="/forgot-password" method="post">
                    <div class="form-floating mb-3">
                        <input type="email" class="form-control" id="emailInput" name="email" placeholder="name@example.com" required autofocus>
                        <label for="emailInput">E-Mail-Adresse</label>
                    </div>
                    <div class="d-grid gap-2 mt-4">
                        <button class="btn btn-primary btn-lg" type="submit">Reset-Link senden</button>
                    </div>
                    <div class="text-center mt-3">
                        <a href="/login" class="text-muted small">Zurück zur Anmeldung</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
