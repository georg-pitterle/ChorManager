{% extends 'layout.twig' %}

{% block title %}Neues Passwort setzen - {{ app_settings.app_name|default('Chor Manager') }}{% endblock %}

{% block content %}
<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-lg border-0">
            <div class="login-header text-center">
                <img src="/logo" alt="Logo" height="60" class="mb-2">
                <h2 class="h4 mt-2 font-weight-bold">Neues Passwort setzen</h2>
                <p class="mb-0 text-white-50">Bitte gib dein neues Passwort ein.</p>
            </div>
            <div class="card-body p-4 p-md-5">

                {% if error %}
                    <div class="alert alert-danger" role="alert">
                        {{ error }}
                    </div>
                {% endif %}

                <form action="/reset-password" method="post">
                    <input type="hidden" name="token" value="{{ token }}">
                    <input type="hidden" name="email" value="{{ email }}">

                    <div class="form-floating mb-3">
                        <input type="password" class="form-control" id="passwordInput" name="password" placeholder="Neues Passwort" required minlength="6" autofocus>
                        <label for="passwordInput">Neues Passwort</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="password" class="form-control" id="passwordConfirmInput" name="password_confirm" placeholder="Passwort bestätigen" required minlength="6">
                        <label for="passwordConfirmInput">Passwort bestätigen</label>
                    </div>
                    <div class="d-grid gap-2 mt-4">
                        <button class="btn btn-primary btn-lg" type="submit">Passwort speichern</button>
                    </div>
                    <div class="text-center mt-3">
                        <a href="/login" class="text-muted small">Zurück zur Anmeldung</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
