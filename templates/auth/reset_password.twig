{% extends 'layout.twig' %}

{% block title %}
    Neues Passwort setzen - {{ app_settings.app_name|default("Chor Manager") }}
{% endblock title %}

{% block content %}
    <section class="auth-shell">
        <div class="auth-card surface-card">
            <div class="auth-brand-panel">
                <img src="/logo" alt="Logo" class="auth-logo mb-3">
                <h1 class="h4 mb-2">Neues Passwort setzen</h1>
                <p class="mb-0">Bitte gib dein neues Passwort ein.</p>
            </div>

            <div class="auth-form-panel p-4 p-md-5">
                {% if error %}<div class="alert alert-danger" role="alert">{{ error }}</div>{% endif %}

                <form action="/reset-password" method="post" class="d-grid gap-3">
                    <input type="hidden" name="token" value="{{ token }}">
                    <input type="hidden" name="email" value="{{ email }}">

                    <div class="form-floating">
                        <input type="password"
                               class="form-control"
                               id="passwordInput"
                               name="password"
                               placeholder="Neues Passwort"
                               required
                               minlength="6"
                               autofocus>
                        <label for="passwordInput">Neues Passwort</label>
                    </div>
                    <div class="form-floating">
                        <input type="password"
                               class="form-control"
                               id="passwordConfirmInput"
                               name="password_confirm"
                               placeholder="Passwort bestätigen"
                               required
                               minlength="6">
                        <label for="passwordConfirmInput">Passwort bestätigen</label>
                    </div>
                    <button class="btn btn-primary btn-lg w-100" type="submit">Passwort speichern</button>
                    <div class="text-center">
                        <a href="/login" class="text-muted small">Zurück zur Anmeldung</a>
                    </div>
                </form>
            </div>
        </div>
    </section>
{% endblock content %}
