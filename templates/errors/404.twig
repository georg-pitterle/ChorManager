{% extends "layout.twig" %}

{% block title %}
    Seite nicht gefunden - {{ app_settings.app_name|default("Chor-Manager") }}
{% endblock title %}

{% block content %}
    <section class="py-4 py-md-5">
        <div class="row justify-content-center">
            <div class="col-12 col-md-10 col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4 p-md-5 text-center">
                        <p class="display-5 fw-semibold text-primary mb-2">404</p>
                        <h1 class="h3 mb-3">Seite nicht gefunden</h1>
                        <p class="text-muted mb-4">
                            Die angeforderte Seite
                            <code class="text-break">{{ requested_path|default("/") }}</code>
                            wurde nicht gefunden oder ist nicht mehr verfuegbar.
                        </p>
                        <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
                            <a href="/dashboard" class="btn btn-primary">Zum Dashboard</a>
                            <a href="/" class="btn btn-outline-secondary">Zur Startseite</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock content %}
