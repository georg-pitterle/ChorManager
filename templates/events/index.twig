{% extends "layout.twig" %}

{% import "macros/modal_form.twig" as modal %}

{% block title %}
    Events (Termine) - {{ app_settings.app_name|default("Chor-Manager") }}
{% endblock title %}

{% block page_header %}
    <section class="page-header">
        <div>
            <p class="text-uppercase text-muted small mb-1">Termine</p>
            <h1 class="h2 mb-1">Events</h1>
            <p class="text-muted mb-0">Plane Termine, filtere Ergebnisse und bearbeite Serien konsistent an einem Ort.</p>
        </div>
        <div class="page-actions">
            <div class="btn-group me-2" role="group" aria-label="Ansicht wählen">
                <a href="/events?view=list&project_id={{ filters.project_id|default('') }}&event_type_id={{ filters.event_type_id|default('') }}&show_old_events={{ filters.show_old_events|default('') }}"
                   class="btn btn-sm {{ view_mode == 'list' ? 'btn-secondary' : 'btn-outline-secondary' }}">
                    <i class="bi bi-list-ul"></i> Liste
                </a>
                <a href="/events?view=calendar&project_id={{ filters.project_id|default('') }}&event_type_id={{ filters.event_type_id|default('') }}&show_old_events={{ filters.show_old_events|default('') }}"
                   class="btn btn-sm {{ view_mode == 'calendar' ? 'btn-secondary' : 'btn-outline-secondary' }}">
                    <i class="bi bi-calendar3"></i> Kalender
                </a>
            </div>
            {% if session.can_manage_users %}
                <button type="button"
                        class="btn btn-primary"
                        data-bs-toggle="modal"
                        data-bs-target="#addEventModal">
                    <i class="bi bi-calendar-plus"></i> Termin erstellen
                </button>
                {% if calendar_subscription_url %}
                    <button type="button"
                            class="btn btn-outline-secondary me-2"
                            data-bs-toggle="modal"
                            data-bs-target="#calendarSubscriptionModal">
                        <i class="bi bi-calendar2-week me-1"></i> Kalender abonnieren
                    </button>
                {% endif %}
            {% endif %}
        </div>
    </section>
{% endblock page_header %}

{% block content %}
    {% if success %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ success }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}
    {% if error and not create_form.open_modal %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ error }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}

    <div class="dashboard-shell">
        <section class="dashboard-section dashboard-section--actions"
                 aria-labelledby="events-filter-title">
            <div class="dashboard-section-head">
                <h2 class="dashboard-section-title" id="events-filter-title">Filter</h2>
                <p class="dashboard-section-lead mb-0">Projekt, Event-Typ und Anzeige vergangener Termine steuern.</p>
            </div>

            <div class="surface-card card border-0 filter-surface">
                <div class="card-body">
                    <form method="get"
                          action="/events"
                          id="event-filter-form"
                          class="row g-3 align-items-end">
                        <input type="hidden" name="view" value="{{ view_mode }}">
                        <div class="col-12 col-md-5 mb-2">
                            <label for="filter_project" class="form-label small">Projekt</label>
                            <select name="project_id" id="filter_project" class="form-select">
                                <option value="">Alle Projekte</option>
                                {% for p in projects %}
                                    <option value="{{ p.id }}"
                                            {% if filters.project_id == p.id %}selected{% endif %}>
                                        {{ p.name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-12 col-md-5 mb-2">
                            <label for="filter_type" class="form-label small">Event-Typ</label>
                            <select name="event_type_id" id="filter_type" class="form-select">
                                <option value="">Alle Typen</option>
                                {% for et in event_types %}
                                    <option value="{{ et.id }}"
                                            {% if filters.event_type_id == et.id %}selected{% endif %}>
                                        {{ et.name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-12 col-md-2 mb-2">
                            <div class="form-check">
                                <input type="checkbox"
                                       class="form-check-input"
                                       id="show_old_events"
                                       name="show_old_events"
                                       value="1"
                                       {% if filters.show_old_events %}checked{% endif %}>
                                <label class="form-check-label small" for="show_old_events">Vergangene Termine anzeigen</label>
                            </div>
                        </div>
                        <div class="col-12 col-md-2 d-flex align-items-end mb-2">
                            <a href="/events" class="btn btn-outline-secondary w-100">
                                <i class="bi bi-x-circle"></i> Reset
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </section>

        {% if calendar_subscription_url %}
            <div class="modal fade" id="calendarSubscriptionModal" tabindex="-1" aria-labelledby="calendarSubscriptionModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow-sm">
                        <div class="modal-header">
                            <h5 class="modal-title" id="calendarSubscriptionModalLabel">Kalender abonnieren</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
                        </div>
                        <div class="modal-body">
                            <p class="mb-3">Kopiere den persönlichen Kalenderlink in deine Kalender-App oder füge ihn als URL-Abonnement hinzu.</p>
                            <div class="input-group">
                                <input id="calendarSubscriptionUrlInput"
                                       type="text"
                                       class="form-control"
                                       value="{{ calendar_subscription_url }}"
                                       readonly>
                                <button id="copyCalendarSubscriptionUrl" type="button" class="btn btn-outline-secondary">
                                    <i class="bi bi-clipboard"></i>
                                </button>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Schließen</button>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}

        {% if view_mode == 'list' %}
            <section class="dashboard-section dashboard-section--context"
                     aria-labelledby="events-list-title">
                <div class="dashboard-section-head">
                    <h2 class="dashboard-section-title" id="events-list-title">Event-Liste</h2>
                    <p class="dashboard-section-lead mb-0">{{ events|length }} Einträge im aktuellen Ergebnis.</p>
                </div>

                <div class="surface-card card border-0 table-shell">
                    <div class="card-body p-0"
                         data-table-engine="true"
                         data-table-id="events.index"
                         data-default-view="auto"
                         data-default-page-size="100"
                         data-page-size-options="25,50,100,200"
                         data-default-sort-key="starts_at"
                         data-default-sort-dir="asc">
                        {{ include('partials/table_toolbar.twig') }}
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 table-responsive-cards"
                                   id="eventsTable">
                                <thead class="table-dark">
                                    <tr>
                                        <th data-sort-key="starts_at" data-sort-type="date">Datum / Zeit</th>
                                        <th data-sort-key="title" data-sort-type="text">Titel</th>
                                        <th data-sort-key="has_note" data-sort-type="text">Bemerkung</th>
                                        <th data-sort-key="location" data-sort-type="text">Ort</th>
                                        <th data-sort-key="type" data-sort-type="text">Typ</th>
                                        <th data-sort-key="project_name" data-sort-type="text">Projekt</th>
                                        <th class="text-end">Aktionen</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for event in events %}
                                        {% set public_notes_count = event.comments|filter(note => not note.is_private)|length %}
                                        {% set private_notes_count = event.comments|filter(note => note.is_private)|length %}
                                        <tr data-sort-starts_at="{{ event.starts_at|date('Y-m-d') }}"
                                            data-sort-title="{{ event.title|lower }}"
                                            data-sort-has_note="{{ event.comments|length > 0 ? 'ja' : 'nein' }}"
                                            data-sort-location="{{ event.location|default('')|lower }}"
                                            data-sort-type="{{ event.type_name|lower }}"
                                            data-sort-project_name="{{ event.project_name|default('')|lower }}">
                                            <td data-label="Datum / Zeit">
                                                <strong>{{ event.starts_at|date('d.m.Y') }}</strong>
                                                <br>
                                                <span class="text-muted small">{{ event.starts_at|date('H:i') }} - {{ event.ends_at|date('H:i') }}</span>
                                                {% if event.series_id %}<i class="bi bi-repeat text-muted ms-1" title="Serientermin"></i>{% endif %}
                                            </td>
                                            <td data-label="Titel">{{ event.title }}</td>
                                            <td data-label="Bemerkung"
                                                data-has-note="{{ event.comments|length > 0 ? '1' : '0' }}">
                                                {% if event.comments|length > 0 %}
                                                    <span class="badge text-bg-success">Ja</span>
                                                {% else %}
                                                    <span class="badge text-bg-secondary">Nein</span>
                                                {% endif %}
                                            </td>
                                            <td data-label="Ort">{{ event.location|default('-') }}</td>
                                            <td data-label="Typ">
                                                <span class="badge bg-{{ event.type_color }}">{{ event.type_name }}</span>
                                            </td>
                                            <td data-label="Projekt">{{ event.project_name|default('-') }}</td>
                                            <td data-label="Aktionen" class="text-end">
                                                <div class="btn-group">
                                                    <a href="/events/{{ event.id }}"
                                                       class="btn btn-sm btn-outline-secondary">
                                                        <i class="bi bi-chat-left-text"></i>
                                                        Bemerkungen ({{ public_notes_count }}/{{ private_notes_count }})
                                                    </a>
                                                    {% if session.can_manage_attendance or session.can_manage_users %}
                                                        <a href="/attendance/{{ event.id }}"
                                                           class="btn btn-sm btn-outline-primary">
                                                            <i class="bi bi-person-check"></i> Anwesenheit
                                                        </a>
                                                    {% endif %}
                                                    {% if session.can_manage_users or session.role_level >= 40 %}
                                                        <button type="button"
                                                                class="btn btn-sm btn-outline-secondary dropdown-toggle dropdown-toggle-split"
                                                                data-bs-toggle="dropdown"
                                                                aria-expanded="false"
                                                                data-bs-boundary="viewport">
                                                            <span class="visually-hidden">Toggle Dropdown</span>
                                                        </button>
                                                        <ul class="dropdown-menu dropdown-menu-end">
                                                            <li>
                                                                <a href="/events/{{ event.id }}/edit" class="dropdown-item">
                                                                    <i class="bi bi-pencil me-2"></i> Termin bearbeiten
                                                                </a>
                                                            </li>
                                                            <li>
                                                                <form action="/events/{{ event.id }}/delete"
                                                                      method="post"
                                                                      data-confirm="Diesen Termin wirklich löschen?">
                                                                    <button type="submit" class="dropdown-item text-danger">
                                                                        <i class="bi bi-trash me-2"></i> Termin löschen
                                                                    </button>
                                                                </form>
                                                            </li>
                                                            {% if event.series_id %}
                                                                <li>
                                                                    <form action="/events/{{ event.id }}/delete-series"
                                                                          method="post"
                                                                          data-confirm="Die gesamte Serie ab diesem Termin wirklich löschen?">
                                                                        <button type="submit" class="dropdown-item text-danger">
                                                                            <i class="bi bi-repeat me-2"></i> Serie löschen
                                                                        </button>
                                                                    </form>
                                                                </li>
                                                            {% endif %}
                                                        </ul>
                                                    {% endif %}
                                                </div>
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="7" class="text-center py-4 text-muted">Keine Termine geplant.</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </section>
        {% endif %}

        {% if view_mode == 'calendar' %}
            <section class="dashboard-section dashboard-section--context"
                     aria-labelledby="events-calendar-title">
                <div class="dashboard-section-head">
                    <h2 class="dashboard-section-title" id="events-calendar-title">Kalender</h2>
                    <p class="dashboard-section-lead mb-0">Monats- und Wochenübersicht aller gefilterten Termine.</p>
                </div>
                <div class="surface-card card border-0">
                    <div class="card-body">
                        <div id="event-calendar"
                             data-calendar-events="{{ calendar_events|e('html_attr') }}"
                             {% if session.can_manage_users %}data-calendar-admin="1"{% endif %}></div>
                    </div>
                </div>
            </section>
        {% endif %}
    </div>

    {% if session.can_manage_users %}
        <!-- Add Event Modal -->
        <div class="modal fade"
             id="addEventModal"
             data-open-create-modal="{{ create_form.open_modal ? '1' : '0' }}"
             tabindex="-1"
             aria-labelledby="addEventModalLabel"
             aria-hidden="true">
            <div class="modal-dialog">
                <form action="/events" method="post" class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="addEventModalLabel">Neuen Termin anlegen</h5>
                        <button type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        {{ modal.show_modal_error(error, create_form.error, 'event_create') }}

                        <div class="mb-3">
                            <label for="title" class="form-label">Titel *</label>
                            <input type="text"
                                   class="form-control"
                                   id="title"
                                   name="title"
                                   value="{{ create_form.form.title|default('') }}"
                                   required>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="starts_at" class="form-label">Datum *</label>
                                <input type="date"
                                       class="form-control"
                                       id="starts_at"
                                       name="starts_at"
                                       value="{{ create_form.form.starts_at|default('') }}"
                                       required>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label for="start_time" class="form-label">Von *</label>
                                <input type="time"
                                       class="form-control"
                                       id="start_time"
                                       name="start_time"
                                       value="{{ create_form.form.start_time|default('') }}"
                                       required>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label for="end_time" class="form-label">Bis *</label>
                                <input type="time"
                                       class="form-control"
                                       id="end_time"
                                       name="end_time"
                                       value="{{ create_form.form.end_time|default('') }}"
                                       required>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="event_type_id" class="form-label">Typ *</label>
                                <select class="form-select" id="event_type_id" name="event_type_id" required>
                                    {% for et in event_types %}
                                        <option value="{{ et.id }}"
                                                {% if create_form.form.event_type_id is not empty and create_form.form.event_type_id == et.id %}selected{% endif %}>
                                            {{ et.name }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="location" class="form-label">Ort (Optional)</label>
                            <input type="text"
                                   class="form-control"
                                   id="location"
                                   name="location"
                                   value="{{ create_form.form.location|default('') }}">
                        </div>

                        <div class="mb-3">
                            <label for="project_id" class="form-label">Projekt (Optional)</label>
                            <select class="form-select" id="project_id" name="project_id">
                                <option value="">Keinem Projekt zuordnen</option>
                                {% for project in projects %}
                                    <option value="{{ project.id }}"
                                            {% if create_form.form.project_id is not empty and create_form.form.project_id == project.id %}selected{% endif %}>
                                        {{ project.name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        {% set _attendance_default_checked = create_form.form.attendance_required is not defined %}
                        <div class="form-check mb-3">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="attendance-required"
                                   name="attendance_required"
                                   value="1"
                                   {% if _attendance_default_checked or create_form.form.attendance_required %}checked{% endif %}>
                            <label class="form-check-label" for="attendance-required">Anwesenheitsliste führen</label>
                        </div>
                        {% if settings.modules.registration %}
                            <div class="form-check mb-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       id="registration-enabled"
                                       name="registration_enabled"
                                       value="1"
                                       {% if create_form.form.registration_enabled %}checked{% endif %}>
                                <label class="form-check-label" for="registration-enabled">Anmeldung freischalten</label>
                            </div>
                            <div class="mb-3">
                                <label for="registration-deadline" class="form-label">
                                    Anmeldeschluss (optional, sonst Terminbeginn)
                                </label>
                                <input type="datetime-local"
                                       class="form-control"
                                       id="registration-deadline"
                                       name="registration_deadline"
                                       value="{{ create_form.form.registration_deadline|default('') }}">
                            </div>
                        {% endif %}

                        <hr class="my-4">

                        <div class="form-check mb-3">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="repeat_event"
                                   name="repeat"
                                   value="1"
                                   {% if create_form.form.repeat %}checked{% endif %}>
                            <label class="form-check-label fw-bold" for="repeat_event">Termin wiederholen</label>
                        </div>

                        <div id="recurrence_options"
                             {% if not create_form.form.repeat %}style="display:none;"{% endif %}>
                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label small text-muted">Wiederhole jeden</label>
                                    <input type="number"
                                           class="form-control"
                                           name="recurrence_interval"
                                           value="{{ create_form.form.recurrence_interval|default('1') }}"
                                           min="1">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small text-muted"></label>
                                    <select class="form-select" name="frequency" id="frequency">
                                        <option value="daily"
                                                {% if create_form.form.frequency == 'daily' %}selected{% endif %}>
                                            Tag
                                        </option>
                                        <option value="weekly"
                                                {% if create_form.form.frequency == 'weekly' %}selected{% endif %}>
                                            Woche
                                        </option>
                                        <option value="monthly"
                                                {% if create_form.form.frequency == 'monthly' %}selected{% endif %}>
                                            Monat
                                        </option>
                                        <option value="yearly"
                                                {% if create_form.form.frequency == 'yearly' %}selected{% endif %}>
                                            Jahr
                                        </option>
                                    </select>
                                </div>
                            </div>

                            <div id="weekday_selector"
                                 class="mb-3"
                                 {% if create_form.form.frequency != 'weekly' %}style="display:none;"{% endif %}>
                                <label class="form-label small text-muted">am</label>
                                <div class="d-flex flex-wrap gap-1">
                                    {% for day in ['Mo', 'Di', 'Mi', 'Do', 'Fr', 'Sa', 'So'] %}
                                        <input type="checkbox"
                                               class="btn-check"
                                               id="day_{{ loop.index }}"
                                               name="weekdays[]"
                                               value="{{ loop.index }}"
                                               {% if loop.index in create_form.form.weekdays|default([1]) %}checked{% endif %}>
                                        <label class="btn btn-outline-primary btn-sm px-3"
                                               for="day_{{ loop.index }}">{{ day }}</label>
                                    {% endfor %}
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="series_end_date" class="form-label small text-muted">Wiederholung beenden am</label>
                                <input type="date"
                                       class="form-control"
                                       id="series_end_date"
                                       name="series_end_date"
                                       value="{{ create_form.form.series_end_date|default('') }}"
                                       {% if create_form.form.repeat %}required{% endif %}>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                        <button type="submit" class="btn btn-primary">Speichern</button>
                    </div>
                </form>
            </div>
        </div>
    {% endif %}
{% endblock content %}

{% block scripts %}
    <script src="/js/events.js"></script>
    {% if view_mode == 'calendar' %}
        <script src="/vendor/fullcalendar/core/index.global.min.js"></script>
        <script src="/vendor/fullcalendar/core/locales/de.global.min.js"></script>
        <script src="/vendor/fullcalendar/daygrid/index.global.min.js"></script>
        <script src="/vendor/fullcalendar/timegrid/index.global.min.js"></script>
        <script src="/vendor/fullcalendar/list/index.global.min.js"></script>
        <script src="/vendor/fullcalendar/interaction/index.global.min.js"></script>
        <script src="/js/event-calendar.js"></script>
    {% endif %}
    {% if calendar_subscription_url %}
        {# copy button behavior is handled by /js/events.js #}
    {% endif %}
{% endblock scripts %}
