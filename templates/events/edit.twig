{% extends "layout.twig" %}

{% block title %}
    Termin bearbeiten - {{ app_settings.app_name|default('Chor-Manager') }}
{% endblock title %}

{% block content %}
    {% set form = edit_form|default({}) %}
    <div class="row mt-4">
        <div class="col-12 mb-4">
            <h1>Termin bearbeiten</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="/events">Termine</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">{{ event.title }}</li>
                </ol>
            </nav>
        </div>
    </div>

    {% if error %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ error }}
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"></button>
        </div>
    {% endif %}

    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <form action="/events/{{ event.id }}/update" method="post">
                        <div class="mb-3">
                            <label for="title" class="form-label">Titel *</label>
                            <input type="text"
                                   class="form-control"
                                   id="title"
                                   name="title"
                                   value="{{ form.title|default(event.title) }}"
                                   required>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="starts_at" class="form-label">Datum *</label>
                                <input type="date"
                                       class="form-control"
                                       id="starts_at"
                                       name="starts_at"
                                       value="{{ form.starts_at|default(event.starts_at|date('Y-m-d')) }}"
                                       required>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label for="start_time" class="form-label">Von *</label>
                                <input type="time"
                                       class="form-control"
                                       id="start_time"
                                       name="start_time"
                                       value="{{ form.start_time|default(event.starts_at|date('H:i')) }}"
                                       required>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label for="end_time" class="form-label">Bis *</label>
                                <input type="time"
                                       class="form-control"
                                       id="end_time"
                                       name="end_time"
                                       value="{{ form.end_time|default(event.ends_at|date('H:i')) }}"
                                       required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="event_type_id" class="form-label">Typ *</label>
                                <select class="form-select" id="event_type_id" name="event_type_id" required>
                                    {% for et in event_types %}
                                        <option value="{{ et.id }}"
                                                {% if form.event_type_id|default(event.event_type_id) == et.id %}selected{% endif %}>
                                            {{ et.name }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="location" class="form-label">Ort (Optional)</label>
                            <input type="text"
                                   class="form-control"
                                   id="location"
                                   name="location"
                                   value="{{ form.location|default(event.location) }}">
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="attendance-required"
                                   name="attendance_required"
                                   value="1"
                                   {% if form.attendance_required %}checked{% endif %}>
                            <label class="form-check-label" for="attendance-required">Anwesenheitsliste führen</label>
                        </div>
                        {% if settings.modules.registration %}
                            <div class="form-check mb-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       id="registration-enabled"
                                       name="registration_enabled"
                                       value="1"
                                       {% if form.registration_enabled %}checked{% endif %}>
                                <label class="form-check-label" for="registration-enabled">Anmeldung freischalten</label>
                            </div>
                            <div class="mb-3">
                                <label for="registration-deadline" class="form-label">
                                    Anmeldeschluss (optional, sonst Terminbeginn)
                                </label>
                                <input type="datetime-local"
                                       class="form-control"
                                       id="registration-deadline"
                                       name="registration_deadline"
                                       value="{{ form.registration_deadline|default('') }}">
                            </div>
                        {% else %}
                            {% if event.registration_enabled %}
                                <input type="hidden" name="registration_enabled" value="1">
                            {% endif %}
                            {% if event.registration_deadline %}
                                <input type="hidden"
                                       name="registration_deadline"
                                       value="{{ event.registration_deadline|date("Y-m-d\\TH:i") }}">
                            {% endif %}
                        {% endif %}

                        <div class="mb-3">
                            <label for="project_id" class="form-label">Projekt (Optional)</label>
                            <select class="form-select" id="project_id" name="project_id">
                                <option value="">Keinem Projekt zuordnen</option>
                                {% for project in projects %}
                                    <option value="{{ project.id }}"
                                            {% if form.project_id|default(event.project_id) == project.id %}selected{% endif %}>
                                        {{ project.name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        {% if event.series_id %}
                            <div class="mb-3 form-check">
                                <input type="checkbox"
                                       class="form-check-input"
                                       id="update_series"
                                       name="update_series"
                                       value="1"
                                       {% if form.update_series|default(false) %}checked{% endif %}>
                                <label class="form-check-label" for="update_series">Änderungen auf zukünftige Termine der Serie anwenden?</label>
                            </div>
                        {% endif %}

                        <div class="d-flex justify-content-between mt-4">
                            <a href="/events" class="btn btn-secondary">Abbrechen</a>
                            <button type="submit" class="btn btn-primary">Änderungen speichern</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock content %}
