ARG APP_IMAGE=ghcr.io/georg-pitterle/chormanager-app:latest
FROM ${APP_IMAGE} AS app

FROM nginx:1.28-alpine

# Use the project Nginx vhost that proxies PHP to the app service.
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Ship prepared web root from app image (includes copied vendor assets).
COPY --from=app /var/www/html/public /var/www/html/public

EXPOSE 80
