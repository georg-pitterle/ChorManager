# =========================================
# Anwendung
# =========================================
# Laufzeitmodus: development, dev, local, production
APP_ENV=development

# Optional: Öffentliche Basis-URL der Anwendung (inkl. http/https), z.B. https://chor.example.org
# Wird für E-Mail-Links verwendet und hat Vorrang vor Request-/Proxy-Erkennung.
APP_URL=

# Kommagetrennte Liste vertrauenswürdiger Reverse-Proxies (IP oder CIDR),
# z.B. 127.0.0.1,10.0.0.0/24. Nur dann werden Forwarded/X-Forwarded-* Header ausgewertet.
TRUSTED_PROXIES=

# Optionaler Debug-Flag (nur Dev)
APP_DEBUG=true

# Anwendungszeitzone (wirkt global auf PHP, Carbon, Twig und DB-Session)
APP_TIMEZONE=Europe/Vienna

# =========================================
# Datenbank (App + Migrationen + Seed)
# =========================================
# Datenbank-Host (bei DDEV meist db)
DB_HOST=db

# Datenbankname
DB_DATABASE=db

# Datenbank-Benutzer
DB_USERNAME=db

# Datenbank-Passwort
DB_PASSWORD=db

# Datenbank-Port
DB_PORT=3306

# =========================================
# Auth / Sessions
# =========================================
# Gültigkeit von Remember-Login-Tokens in Tagen
REMEMBER_ME_DAYS=30

# =========================================
# SMTP / E-Mail (Dev mit Mailhog)
# =========================================
# SMTP-Host
SMTP_HOST=mailhog

# SMTP-Port
SMTP_PORT=1025

# SMTP-Authentifizierung aktiv (1/0, true/false)
SMTP_AUTH=0

# SMTP-Benutzername (in Prod meist erforderlich)
SMTP_USERNAME=

# SMTP-Passwort (in Prod erforderlich)
SMTP_PASSWORD=

# SMTP-Verschlüsselung: tls, ssl, none
SMTP_ENCRYPTION=none

# Absender-Adresse
SMTP_FROM_EMAIL=noreply@chor.local

# Absender-Name
SMTP_FROM_NAME=Chor-Manager

# =========================================
# Mail-Versand-Unterdrückung
# =========================================
# Wenn true, werden keine echten Mails versendet.
# Stattdessen erscheint eine Flash-Meldung mit der Anzahl der Empfänger.
# Für lokale Entwicklung auf true belassen, in Produktion auf false setzen.
DISABLE_MAIL_SEND=true

# =========================================
# Dev-Seed
# =========================================
# Muss auf 1 gesetzt werden, damit der Dev-Seed laufen darf
ALLOW_DEV_SEED=0

# =========================================
# Optional für Production-Compose
# =========================================
# Root-Passwort für MySQL im Prod-Compose
MYSQL_ROOT_PASSWORD=change_me

# Exponierter Nginx-Port im Prod-Compose
NGINX_PORT=8080

# =========================================
# Feature-Flags
# =========================================
# Sheet Archive Modul
FEATURE_SHEET_ARCHIVE=false

# =========================================
# Backup-Verwaltung
# =========================================
# Verzeichnis fuer DB-Backups (ausserhalb des Webroots)
BACKUP_DIR=/var/backups/chormanager

# Maximale Anzahl manueller Backups (0 = unbegrenzt)
BACKUP_MAX_MANUAL=5

# Maximale Anzahl automatischer Backups (0 = unbegrenzt)
BACKUP_MAX_AUTO=7

# Backup-Dateien gzip-komprimieren
BACKUP_GZIP=true

# =========================================
# SnappyMail / Mail-Account-Verschlüsselung
# =========================================
# Symmetrischer Schlüssel (base64, 32 Bytes) zur Verschlüsselung der IMAP-Passwörter.
# Erzeugen mit: php -r "echo base64_encode(random_bytes(32)) . PHP_EOL;"
MAIL_CREDENTIAL_KEY=

# =========================================
# SnappyMail Webmail-Container (DDEV-Add-on, .ddev/docker-compose.snappymail.yaml)
# =========================================
# Maximale Upload-Groesse innerhalb des SnappyMail-Containers (PHP + nginx dort).
# Optional, Default im Compose-File: 25M.
SNAPPYMAIL_UPLOAD_MAX_SIZE=25M

# PHP memory_limit innerhalb des SnappyMail-Containers.
# Optional, Default im Compose-File: 128M.
SNAPPYMAIL_MEMORY_LIMIT=128M
