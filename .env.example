# =========================================
# Anwendung
# =========================================
# Laufzeitmodus: development, dev, local, production
APP_ENV=development

# Optionaler Debug-Flag (nur Dev)
APP_DEBUG=true

# =========================================
# Datenbank (App + Migrationen + Seed)
# =========================================
# Datenbank-Host (bei DDEV meist db)
DB_HOST=db

# Datenbankname
DB_DATABASE=db

# Datenbank-Benutzer
DB_USERNAME=db

# Datenbank-Passwort
DB_PASSWORD=db

# Datenbank-Port
DB_PORT=3306

# =========================================
# Auth / Sessions
# =========================================
# Gültigkeit von Remember-Login-Tokens in Tagen
REMEMBER_ME_DAYS=30

# =========================================
# SMTP / E-Mail (Dev mit Mailhog)
# =========================================
# SMTP-Host
SMTP_HOST=mailhog

# SMTP-Port
SMTP_PORT=1025

# SMTP-Authentifizierung aktiv (1/0, true/false)
SMTP_AUTH=0

# SMTP-Benutzername (in Prod meist erforderlich)
SMTP_USERNAME=

# SMTP-Passwort (in Prod erforderlich)
SMTP_PASSWORD=

# SMTP-Verschlüsselung: tls, ssl, none
SMTP_ENCRYPTION=none

# Absender-Adresse
SMTP_FROM_EMAIL=noreply@chor.local

# Absender-Name
SMTP_FROM_NAME=Chor Manager

# =========================================
# Dev-Seed
# =========================================
# Muss auf 1 gesetzt werden, damit der Dev-Seed laufen darf
ALLOW_DEV_SEED=0

# =========================================
# Optional für Production-Compose
# =========================================
# Root-Passwort für MySQL im Prod-Compose
MYSQL_ROOT_PASSWORD=change_me

# Exponierter Nginx-Port im Prod-Compose
NGINX_PORT=8080