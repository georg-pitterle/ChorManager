# Normalize text files to LF in the repository to avoid cross-platform EOL drift.
* text=auto eol=lf

# Common source and config files should always use LF.
*.php text eol=lf
*.js text eol=lf
*.css text eol=lf
*.twig text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.env text eol=lf

# Keep Windows command scripts on CRLF for compatibility.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets must never be normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
